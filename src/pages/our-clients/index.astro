---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Our Clients - The Demski Group">
<style is:global>
@import url('https://api.fontshare.com/v2/css?f[]=general-sans@700,600,500,400&display=swap');
html { overflow-x: hidden; }

/* ══ HERO ══ */
.clients-hero {
  background: #fff;
  padding: 80px 60px;
  overflow: hidden;
  min-height: 600px;
}
.clients-hero-inner {
  max-width: 1300px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}
.clients-eyebrow {
  font-family: 'Outfit', sans-serif;
  font-size: 12px; font-weight: 600;
  letter-spacing: 3px; text-transform: uppercase;
  color: #888; margin-bottom: 20px;
}
.clients-hero h1 {
  font-family: 'Outfit', sans-serif;
  font-size: 58px; font-weight: 700;
  color: #0A0000; line-height: 1.08;
  margin-bottom: 22px; letter-spacing: -0.5px;
}
.clients-hero-left p {
  font-size: 17px; color: #555;
  line-height: 1.75; margin-bottom: 34px;
  max-width: 460px;
}
.btn-schedule {
  display: inline-flex; align-items: center; justify-content: center;
  background: #F09300; color: #fff;
  font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 600;
  padding: 14px 36px; border-radius: 8px;
  text-decoration: none; transition: background 0.3s;
}
.btn-schedule:hover { background: #d98200; }

/* Hero right: masonry cards */
.clients-hero-right {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 260px 260px;
  gap: 16px;
}
.hero-img-card {
  border-radius: 18px; overflow: hidden;
  position: relative; text-decoration: none;
  display: block; background: #1a1a2e;
}
.hero-img-card:first-child { grid-row: span 2; }
.hero-img-card-bg {
  position: absolute; inset: 0;
  background-size: cover; background-position: center;
  transition: transform 0.4s;
}
.hero-img-card:hover .hero-img-card-bg { transform: scale(1.04); }
.hero-img-card::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.65) 100%);
  z-index: 1;
}
.hero-img-card-content {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 20px 22px; z-index: 2;
}
.hero-img-card-name {
  font-family: 'Outfit', sans-serif;
  font-size: 16px; font-weight: 700; color: #fff;
  margin-bottom: 10px; line-height: 1.3;
}
.hero-img-card-link {
  font-family: 'Outfit', sans-serif;
  font-size: 13px; font-weight: 700;
  color: rgba(255,255,255,0.9);
}
/* Skeleton loading */
.hero-card-skeleton {
  border-radius: 18px;
  background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
.hero-card-skeleton:first-child { grid-row: span 2; }
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* ══ BRANDS BAR ══ */
.brands-outer { background: #f0f0f0; padding: 0 60px 70px; }
.brands-wrap {
  max-width: 1200px; margin: 0 auto;
  background: #2a2a2a; border-radius: 16px;
  display: flex; overflow: hidden;
}
.brands-label {
  font-family: 'Outfit', sans-serif; font-size: 17px; color: #fff;
  min-width: 250px; padding: 36px; border-right: 1px solid #444;
  flex-shrink: 0; display: flex; align-items: center;
  justify-content: center; text-align: center; line-height: 1.65;
}
.brands-logos { flex: 1; padding: 24px 44px; display: flex; align-items: center; }
.brands-logos img { width: 100%; max-height: 120px; object-fit: contain; }

/* ══ ALL CLIENTS ══ */
.all-clients-section { background: #fff; padding: 100px 60px; }
.all-clients-inner { max-width: 1300px; margin: 0 auto; }
.all-clients-heading {
  font-family: 'Outfit', sans-serif; font-size: 46px; font-weight: 700;
  color: #0A0000; line-height: 1.15; margin-bottom: 48px;
}

/* BIOPAC + 4 */
.clients-top-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
.biopac-card {
  background: #0a1628; border-radius: 18px; padding: 36px;
  display: flex; flex-direction: column; justify-content: space-between;
  min-height: 320px; text-decoration: none;
  transition: transform 0.25s, box-shadow 0.25s; grid-row: span 2;
}
.biopac-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,0,0,0.3); }
.biopac-logo { margin-bottom: 12px; }
.biopac-logo img { height: 64px; width: auto; object-fit: contain; filter: brightness(0) invert(1); }
.biopac-name-text { font-family:'Outfit',sans-serif; font-size:22px; font-weight:700; color:#fff; }
.biopac-desc { font-size: 18px; color: rgba(255,255,255,0.8); line-height: 1.7; margin: 16px 0; }
.biopac-link { font-family:'Outfit',sans-serif; font-size:16px; font-weight:600; color:#fff; }
.top-four-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

/* Standard card */
.client-card {
  background: #fff; border: 1px solid #ebebeb; border-radius: 16px;
  padding: 28px 20px 20px; display: flex; flex-direction: column;
  justify-content: space-between; align-items: center;
  text-decoration: none; transition: box-shadow 0.25s, transform 0.25s;
  min-height: 148px;
}
.client-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.09); transform: translateY(-2px); }
.client-card-img-wrap {
  flex: 1; display: flex; align-items: center; justify-content: center;
  width: 100%; margin-bottom: 16px;
}
.client-card img { max-height: 100%; max-width: 70%; object-fit: contain; display: block; }
.client-card-name { font-family:'Outfit',sans-serif; font-size:13px; font-weight:600; color:#333; text-align:center; }
.client-card-link { font-family:'Outfit',sans-serif; font-size:16px; font-weight:600; color:#0154b1; text-decoration:none; white-space:nowrap; }
.clients-main-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }

/* Card skeleton */
.card-skeleton {
  border-radius: 16px; min-height: 148px;
  background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
  background-size: 200% 100%; animation: shimmer 1.5s infinite;
}

/* ══ FINAL CTA ══ */
.clients-cta { position:relative; min-height:300px; display:flex; align-items:center; justify-content:center; overflow:hidden; }
.clients-cta-bg {
  position:absolute; inset:0;
  background-image: url('https://demskigroup.com/wp-content/uploads/2025/02/executives-shaking-hands-in-the-meeting-2023-11-27-04-58-12-utc-1.jpg');
  background-size:cover; background-position:center; filter:brightness(0.4); z-index:0;
}
.clients-cta-inner { position:relative; z-index:2; text-align:center; padding:80px 30px; }
.clients-cta-inner h2 { font-family:'Outfit',sans-serif; font-size:38px; font-weight:700; color:#fff; line-height:1.25; margin-bottom:32px; }
.cta-btns { display:flex; flex-direction:column; align-items:center; gap:14px; }
.btn-orange, .btn-call {
  display:inline-flex; align-items:center; justify-content:center; gap:10px;
  background:#F09300; color:#fff; font-family:'Outfit',sans-serif;
  font-size:16px; font-weight:600; padding:15px 0; border-radius:8px;
  text-decoration:none; width:300px; transition:background 0.3s;
}
.btn-orange:hover, .btn-call:hover { background:#d98200; }

/* ══ RESPONSIVE ══ */
@media (max-width: 1024px) {
  .clients-main-grid { grid-template-columns: repeat(3,1fr); }
  .clients-hero-inner { gap: 40px; }
  .clients-hero h1 { font-size: 44px; }
}
@media (max-width: 900px) {
  .clients-hero-inner { grid-template-columns: 1fr; }
  .clients-hero-right { grid-template-rows: 200px 200px; }
  .clients-main-grid { grid-template-columns: repeat(2,1fr); }
  .brands-wrap { flex-direction: column; }
  .brands-label { border-right:none; border-bottom:1px solid #444; }
  .clients-top-wrap { grid-template-columns: 1fr; }
  .biopac-card { grid-row: span 1; min-height: 220px; }
}
@media (max-width: 600px) {
  .clients-hero { padding: 60px 24px; }
  .clients-hero h1 { font-size: 36px; }
  .clients-hero-right { grid-template-columns:1fr; grid-template-rows:200px 200px 200px; }
  .hero-img-card:first-child { grid-row: span 1; }
  .brands-outer, .all-clients-section { padding-left:24px; padding-right:24px; }
  .clients-main-grid { grid-template-columns:1fr 1fr; gap:12px; }
  .top-four-grid { grid-template-columns:1fr 1fr; }
  .all-clients-heading { font-size: 28px; }
}
</style>

<!-- ══ HERO ══ -->
<section class="clients-hero">
  <div class="clients-hero-inner">
    <div class="clients-hero-left">
      <div class="clients-eyebrow">Case Studies</div>
      <h1>Success Speaks for Itself</h1>
      <p>See our portfolio of clients who improved their business with better software.</p>
      <a href="/contact-us/" class="btn-schedule">Schedule a Consultation</a>
    </div>
    <!-- Cards injected by JS -->
    <div class="clients-hero-right" id="hero-cards">
      <div class="hero-card-skeleton"></div>
      <div class="hero-card-skeleton"></div>
      <div class="hero-card-skeleton"></div>
    </div>
  </div>
</section>

<!-- ══ BRANDS BAR ══ -->
<div class="brands-outer">
  <div class="brands-wrap">
    <div class="brands-label">Companies that trust our<br/>experienced team</div>
    <div class="brands-logos">
      <img src="https://demskigroup.com/wp-content/uploads/2024/06/logoswhite-1024x366.png" alt="companies we work with" />
    </div>
  </div>
</div>

<!-- ══ ALL CLIENTS ══ -->
<section class="all-clients-section">
  <div class="all-clients-inner">
    <h2 class="all-clients-heading">
      Over 600 Projects Delivered Successfully.<br/>Here Are Some of Our Clients.
    </h2>
    <!-- BIOPAC + 4 -->
    <div class="clients-top-wrap" id="biopac-section">
      <div class="card-skeleton biopac-card" style="grid-row:span 2"></div>
      <div class="top-four-grid">
        <div class="card-skeleton"></div>
        <div class="card-skeleton"></div>
        <div class="card-skeleton"></div>
        <div class="card-skeleton"></div>
      </div>
    </div>
    <!-- All remaining -->
    <div class="clients-main-grid" id="all-clients-grid">
      {Array(8).fill(0).map(() => <div class="card-skeleton"></div>)}
    </div>
  </div>
</section>

<!-- ══ FINAL CTA ══ -->
<section class="clients-cta">
  <div class="clients-cta-bg"></div>
  <div class="clients-cta-inner">
    <h2>Ready to Become Our Next<br/>Success Story?</h2>
    <div class="cta-btns">
      <a href="/contact-us/" class="btn-orange">Contact Us</a>
      <a href="tel:+14068681034" class="btn-call">
        <i class="fa-solid fa-phone-alt"></i> Call Us
      </a>
    </div>
  </div>
</section>

<script is:inline>
(async function() {
  // ── Fetch from WP REST API (browser-side, works on any host) ──
  const WP_URLS = [
    'https://demskigroup.com/wp-json/wp/v2/our-clients',
    'https://demskigrdev.wpenginepowered.com/wp-json/wp/v2/our-clients',
  ];

  function clean(str) {
    return (str || '').replace(/&amp;/g,'&').replace(/&#8217;/g,"'")
      .replace(/&#8216;/g,"'").replace(/<[^>]*>/g,'').trim();
  }

  function normalizeLink(link, slug) {
    return (link || '')
      .replace('https://demskigrdev.wpenginepowered.com','')
      .replace('https://demskigroup.com','')
      || `/our-clients/${slug}/`;
  }

  async function fetchClients() {
    for (const base of WP_URLS) {
      try {
        let all = [], page = 1, totalPages = 1;
        do {
          const res = await fetch(
            `${base}?_embed&per_page=100&page=${page}`
          );
          if (!res.ok) break;
          const tp = res.headers.get('X-WP-TotalPages');
          if (tp) totalPages = parseInt(tp);
          const data = await res.json();
          if (!Array.isArray(data) || !data.length) break;
          all = [...all, ...data];
          page++;
        } while (page <= totalPages);

        if (all.length > 0) return all.map(item => ({
          id:    item.id,
          name:  clean(item.title?.rendered),
          slug:  item.slug || '',
          link:  normalizeLink(item.link, item.slug),
          photo: item._embedded?.['wp:featuredmedia']?.[0]?.source_url || '',
          desc:  clean(item.excerpt?.rendered).replace(/\[&hellip;\]/g,''),
        }));
      } catch(e) { continue; }
    }
    return [];
  }

  function heroCard(c, tall) {
    const style = c.photo ? `background-image:url('${c.photo}')` : 'background:#0a1628';
    return `<a class="hero-img-card" href="${c.link}" ${tall ? 'style="grid-row:span 2"' : ''}>
      <div class="hero-img-card-bg" style="${style}"></div>
      <div class="hero-img-card-content">
        <div class="hero-img-card-name">${c.name}</div>
        <span class="hero-img-card-link">Read case study <span class="btn-arrow-icon"></span></span>
      </div>
    </a>`;
  }

  function clientCard(c) {
    const img = c.photo
      ? `<img src="${c.photo}" alt="${c.name}" loading="lazy" />`
      : `<span class="client-card-name">${c.name}</span>`;
    return `<a class="client-card" href="${c.link}">
      <div class="client-card-img-wrap">${img}</div>
      <span class="client-card-link">Read full case study <span class="btn-arrow-icon"></span></span>
    </a>`;
  }

  // Fetch
  const clients = await fetchClients();
  if (!clients.length) return;

  // ── Hero cards ──
  const biopacSlugs = ['hewlett-packard-enterprise', 'willo', 'farmers-daughter-fibers'];
  let heroCards = biopacSlugs.map(s => clients.find(c => c.slug === s)).filter(Boolean);
  if (heroCards.length < 2) heroCards = clients.filter(c => c.photo).slice(0, 3);

  const heroEl = document.getElementById('hero-cards');
  if (heroEl && heroCards.length) {
    heroEl.innerHTML = heroCards.slice(0,3).map((c,i) => heroCard(c, i===0)).join('');
  }

  // ── BIOPAC section ──
  const biopac = clients.find(c => c.slug?.includes('biopac')) || clients[0];
  const others = clients.filter(c => c.id !== biopac?.id);
  const topFour = others.slice(0, 4);
  const rest = others.slice(4);

  const biopacDesc = biopac?.desc?.length > 20
    ? biopac.desc
    : 'The Demski Group successfully delivered a scalable and efficient web application for Biopac, enabling users to perform and track scientific studies online.';

  const biopacLogoHtml = biopac?.photo
    ? `<img src="${biopac.photo}" alt="${biopac.name}" style="height:64px;object-fit:contain;filter:brightness(0) invert(1)" />`
    : `<span class="biopac-name-text">${biopac?.name || ''}</span>`;

  const biopacSection = document.getElementById('biopac-section');
  if (biopacSection && biopac) {
    biopacSection.innerHTML = `
      <a class="biopac-card" href="${biopac.link}" style="grid-row:span 2">
        <div class="biopac-logo">${biopacLogoHtml}</div>
        <p class="biopac-desc">${biopacDesc}</p>
        <span class="biopac-link">Read full case study <span class="btn-arrow-icon"></span></span>
      </a>
      <div class="top-four-grid">
        ${topFour.map(c => clientCard(c)).join('')}
      </div>
    `;
  }

  // ── All remaining clients ──
  const grid = document.getElementById('all-clients-grid');
  if (grid) {
    grid.innerHTML = rest.map(c => clientCard(c)).join('');
  }
})();
</script>

</Layout>