---
import Layout from '../../layouts/Layout.astro';
import { CLIENT_FALLBACKS } from '../../data/clientFallbacks';
Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=3600');

const WP_BASE = 'https://demskigroup.com/wp-json/wp/v2/our-clients';

function clean(s: string) {
  return (s||'').replace(/&amp;/g,'&').replace(/&#8217;/g,"'").replace(/&#8216;/g,"'").replace(/<[^>]*>/g,'').trim();
}
function normalizeLink(link: string, slug: string) {
  return (link||'').replace('https://demskigroup.com','') || `/our-clients/${slug}/`;
}
function extractPhoto(item: any) {
  return item._embedded?.['wp:featuredmedia']?.[0]?.source_url
    || item.acf?.featured_image?.url || item.acf?.image?.url || '';
}

const KNOWN_IMAGES: Record<string,string> = {
  'biopac':'https://demskigroup.com/wp-content/uploads/2024/07/Biopac.png',
  'shop-orthopedics':'https://demskigroup.com/wp-content/uploads/2024/06/ShopOrthopedics-1.png',
  'property-gauge':'https://demskigroup.com/wp-content/uploads/2024/07/PropertyGauge.png',
  'mister-quik':'https://demskigroup.com/wp-content/uploads/2024/07/mrquick.png',
  'pnc-bank':'https://demskigroup.com/wp-content/uploads/2024/06/company-logo-4.png',
  'jackson-hewitt':'https://demskigroup.com/wp-content/uploads/2024/06/jacksonhewitt-1.png',
  'seen-dating':'https://demskigroup.com/wp-content/uploads/2024/06/SEENDating-1.png',
  'nu-borders':'https://demskigroup.com/wp-content/uploads/2024/07/Nuborders.png',
  'robomaster':'https://demskigroup.com/wp-content/uploads/2024/06/Robomaster-1.png',
  'zoomifi':'https://demskigroup.com/wp-content/uploads/2024/06/Zoomifi-1.png',
  'yawye':'https://demskigroup.com/wp-content/uploads/2024/06/Yawye-1.png',
  'tausi-brands':'https://demskigroup.com/wp-content/uploads/2024/06/Tausi-1.png',
  'corning-glass':'https://demskigroup.com/wp-content/uploads/2024/07/corning-300x201-1.png',
  'flower-moxie-case-study':'https://demskigroup.com/wp-content/uploads/2024/07/Flowermoxie.png',
  'golf-daddy':'https://demskigroup.com/wp-content/uploads/2024/07/Branded-300x159.png',
  'audiojack':'https://demskigroup.com/wp-content/uploads/2024/06/audiojackhighres-300x159.png',
  'willo':'https://demskigroup.com/wp-content/uploads/2024/07/Willo-1.png',
  'impact-team-tennis':'https://demskigroup.com/wp-content/uploads/2025/02/ITTLogo-300x159.png',
  'bite':'https://demskigroup.com/wp-content/uploads/2024/08/newbitelogo.png',
  'hewlett-packard-enterprise':'https://demskigroup.com/wp-content/uploads/2024/07/HP-1.png',
  'farmers-daughter-fibers':'https://demskigroup.com/wp-content/uploads/2024/07/FarmersDaughter.png',
};

const HERO_CARDS = [
  { name:'Hewlett Packard Enterprise', link:'/our-clients/hewlett-packard-enterprise/', photo:'https://demskigroup.com/wp-content/uploads/2024/05/group-of-people-working.jpg' },
  { name:'Willo',                      link:'/our-clients/willo/',                      photo:'https://demskigroup.com/wp-content/uploads/2024/07/Willo-1.png' },
  { name:"Farmer's Daughter Fibers",   link:'/our-clients/farmers-daughter-fibers/',    photo:'https://demskigroup.com/wp-content/uploads/2024/07/FarmersDaughter.png' },
];

// Static fallback grid, sourced from CLIENT_FALLBACKS, used whenever the
// live WordPress API is unreachable or returns no results. Keeps the
// "All Clients" grid from ever disappearing.
const FALLBACK_CLIENTS: any[] = Object.entries(CLIENT_FALLBACKS).map(([slug, data]) => ({
  id: `fallback-${slug}`,
  name: data.title,
  slug,
  link: `/our-clients/${slug}/`,
  photo: data.logo,
  desc: data.tagline,
}));

let clients: any[] = [];
try {
  let all: any[] = [], page = 1, totalPages = 1;
  do {
    const res = await fetch(`${WP_BASE}?_embed&per_page=100&page=${page}`, { signal: AbortSignal.timeout(8000) });
    if (!res.ok) break;
    const tp = res.headers.get('X-WP-TotalPages');
    if (tp) totalPages = parseInt(tp);
    const data = await res.json();
    if (!Array.isArray(data) || !data.length) break;
    all = [...all, ...data];
    page++;
  } while (page <= totalPages);
  clients = all.map((item: any) => ({
    id: item.id, name: clean(item.title?.rendered), slug: item.slug||'',
    link: normalizeLink(item.link, item.slug), photo: extractPhoto(item),
    desc: clean(item.excerpt?.rendered||'').replace(/\[&hellip;\]/g,''),
  }));
} catch(e) { console.warn('SSR clients fetch failed:', e); }

if (!clients.length) clients = FALLBACK_CLIENTS;

const biopac = clients.find(c => c.slug?.includes('biopac')) || clients[0];
const others = clients.filter(c => c.id !== biopac?.id);
const topFour = others.slice(0, 4);
const rest = others.slice(4);
const biopacDesc = biopac?.desc?.length > 20 ? biopac.desc : 'The Demski Group successfully delivered a scalable and efficient web application for Biopac, enabling users to perform and track scientific studies online.';
const biopacPhoto = biopac?.photo || KNOWN_IMAGES[biopac?.slug] || '';
---

<Layout
  title="Our Clients | The Demski Group"
  description="Explore The Demski Group's client portfolio — from Fortune 500 companies like HP and PNC Bank to innovative startups. See how we've helped businesses grow with custom software."
>
<style is:global>
@import url('https://api.fontshare.com/v2/css?f[]=general-sans@700,600,500,400&display=swap');
html { overflow-x: hidden; }

/* ══ HERO ══ */
.clients-hero {
  background: #fff;
  padding: 80px 60px 80px;
  overflow: visible;
}
.clients-hero-inner {
  max-width: 1300px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}
.clients-eyebrow {
  font-family: 'Outfit', sans-serif;
  font-size: 20px; font-weight: 300;
  letter-spacing: 3px; text-transform: uppercase;
  color: #000; margin-bottom: 20px;
}
.clients-hero h1 {
  font-family: 'Outfit', sans-serif;
  font-size: 60px; font-weight: 700;
  color: #282828; line-height: 1.08;
  margin-bottom: 48px; letter-spacing: -0.5px;
}
.clients-hero-left p {
  font-size: 20px; color: #000;
  line-height: 1.75; margin-bottom: 34px;
}
.btn-schedule {
  display: inline-flex; align-items: center; justify-content: center;
  background: #F09300; color: #fff;
  font-family: 'Outfit', sans-serif; font-size: 20px; font-weight: 600;
  padding: 14px 36px; border-radius: 8px;
  text-decoration: none; transition: background 0.3s;
}
.btn-schedule:hover { background: #d98200; }

/* Hero right: masonry cards */
.clients-hero-right {
  display: grid;
  grid-template-columns: 0.81fr 0.81fr;
  grid-template-rows: 500px 20px;
  gap: 16px;
  align-items: stretch;
}
.hero-img-card {
  border-radius: 32px; overflow: hidden;
  position: relative; text-decoration: none;
  display: block; background: #1a1a2e;
  min-height: 0; min-width: 0;
}
.hero-img-card:nth-child(1) { grid-column: 1; grid-row: 1; }
.hero-img-card:nth-child(2) { grid-column: 2; grid-row: 1; height: 420px; align-self: end; }
.hero-img-card:nth-child(3) { grid-column: 1 / 3; grid-row: 2; width: 70%; height: 170px; justify-self: center; margin-top: 10px; position: relative; z-index: 10; }
.hero-img-card-bg {
  position: absolute; inset: 0;
  background-size: cover; background-position: center;
  transition: transform 0.4s;
}
.hero-img-card:hover .hero-img-card-bg { transform: scale(1.04); }
.hero-img-card::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.65) 100%);
  z-index: 1;
}
.hero-img-card-content {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 20px 22px; z-index: 2;
}
.hero-img-card-name {
  font-family: 'Outfit', sans-serif;
  font-size: 16px; font-weight: 700; color: #fff;
  margin-bottom: 10px; line-height: 1.3;
}
.hero-img-card-link {
  font-family: 'Outfit', sans-serif;
  font-size: 13px; font-weight: 700;
  color: rgba(255,255,255,0.9);
}
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* ══ BRANDS BAR ══ */
.brands-outer { background: #2a2a2a; padding: 0; }
.brands-wrap {
  max-width: 100%; margin: 0;
  background: #2a2a2a; border-radius: 0;
  display: flex; overflow: hidden;
}
.brands-label {
  font-family: 'Outfit', sans-serif; font-size: 20px; color: #fff;
  min-width: 250px; padding: 36px 36px 36px 86px; border-right: 3px solid #ffffff;
  flex-shrink: 0; display: flex; align-items: center;
  justify-content: center; text-align: center; line-height: 1.65;
}
.brands-logos { flex: 1; padding: 24px 44px 24px 0; margin-left: -700px; display: flex; align-items: center; }
.brands-logos img { width: 100%; max-height: 120px; object-fit: contain; }

/* ══ ALL CLIENTS ══ */
.all-clients-section { background: #fff; padding: 100px 60px 160px; }
.all-clients-inner { max-width: 1300px; margin: 0 auto; }
.all-clients-heading {
  font-family: 'Outfit', sans-serif; font-size: 50px; font-weight: 700;
  color: #282828; line-height: 1.15; margin-bottom: 48px;
  max-width: 800px;
}

/* BIOPAC + 4 */
.clients-top-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 50px; }
.biopac-card {
  background-color: #0a1628;
  background-image:
    radial-gradient(ellipse 80% 60% at 20% 15%, rgba(70, 130, 200, 0.22), transparent 60%),
    radial-gradient(ellipse 70% 60% at 85% 80%, rgba(40, 90, 160, 0.20), transparent 60%),
    repeating-linear-gradient(45deg, transparent 0, transparent 38px, rgba(120, 180, 230, 0.05) 38px, rgba(120, 180, 230, 0.05) 39px),
    repeating-linear-gradient(-45deg, transparent 0, transparent 38px, rgba(120, 180, 230, 0.05) 38px, rgba(120, 180, 230, 0.05) 39px),
    linear-gradient(135deg, #0a1628 0%, #0e1f3a 50%, #0a1628 100%);
  border-radius: 18px; padding: 36px;
  display: flex; flex-direction: column; justify-content: space-between;
  min-height: 320px; text-decoration: none;
  transition: transform 0.25s, box-shadow 0.25s; grid-row: span 2;
  position: relative; overflow: hidden;
}
.biopac-card > * { position: relative; z-index: 1; }
.biopac-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(0,0,0,0.3); }
.biopac-logo { margin-bottom: 12px; }
.biopac-logo img { height: 64px; width: auto; object-fit: contain; filter: brightness(0) invert(1); }
.biopac-name-text { font-family:'Outfit',sans-serif; font-size:22px; font-weight:700; color:#fff; }
.biopac-desc { font-size: 18px; color: rgba(255,255,255,0.8); line-height: 1.7; margin: 16px 0; }
.biopac-link { font-family:'Outfit',sans-serif; font-size:16px; font-weight:600; color:#fff; }
.top-four-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

/* Standard card */
.client-card {
  background: #fff; border: 1px solid #ebebeb; border-radius: 28px;
  padding: 16px 20px 12px; display: flex; flex-direction: column;
  justify-content: space-between; align-items: center;
  text-decoration: none; transition: box-shadow 0.25s;
  height: 160px; min-height: 160px; max-height: 160px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0,0,0,0.18);
}
.client-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.35); }
.client-card-img-wrap {
  flex: 1; display: flex; align-items: center; justify-content: center;
  width: 100%; overflow: hidden;
}
.client-card img { max-height: 90px; max-width: 75%; object-fit: contain; display: block; }
.client-card-name { font-family:'Outfit',sans-serif; font-size:13px; font-weight:600; color:#333; text-align:center; }
.client-card-link { font-family:'Outfit',sans-serif; font-size:16px; font-weight:600; color:#000; text-decoration:none; white-space:nowrap; transition: color 0.2s; }
.client-card:hover .client-card-link { color:#0154b1; }
.clients-main-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }


/* ══ FINAL CTA ══ */
.clients-cta {
  background: #0C0C0C; padding: 0; overflow: visible; position: relative; margin-top: -20px;
}
.clients-cta-inner {
  max-width: 100%; display: flex; align-items: center; min-height: 340px;
}
.clients-cta-text {
  flex: 0 0 44%; padding: 55px 70px 75px 110px;
  display: flex; flex-direction: column; justify-content: center; gap: 24px;
}
.clients-cta-text h2 {
  font-family: 'Outfit', sans-serif; font-size: 30px; font-weight: 700;
  color: white; line-height: 1.3; margin: 0;
}
.clients-cta-text h2 span { color: #4798ed; display: block; }
.clients-cta-image {
  flex: 1; padding: 0; overflow: visible; display: flex; align-items: flex-start; margin-left: -150px;
}
.clients-cta-image img {
  width: 926px; height: 375px; object-fit: cover; object-position: left center;
  display: block; border-radius: 19px 0 0 19px; margin-top: -100px; margin-bottom: 0;
}
.btn-cta-orange {
  display: inline-flex; align-items: center; justify-content: center;
  background: #F09300; color: #fff; font-family: 'Outfit', sans-serif;
  font-size: 16px; font-weight: 600; padding: 14px 32px; border-radius: 8px;
  text-decoration: none; width: fit-content; transition: background 0.3s;
}
.btn-cta-orange:hover { background: #d98200; }

/* ══ RESPONSIVE ══ */
@media (max-width: 1024px) {
  .clients-main-grid { grid-template-columns: repeat(3,1fr); }
  .clients-hero-inner { gap: 40px; }
  .clients-hero h1 { font-size: 48px; }
}
@media (max-width: 900px) {
  .clients-hero-inner { grid-template-columns: 1fr; }
  .clients-hero-right { grid-template-rows: 300px 120px; }
  .clients-main-grid { grid-template-columns: repeat(2,1fr); }
  .brands-wrap { flex-direction: column; padding: 40px 20px 48px; }
  .brands-label {
    min-width: 0; width: 100%; padding: 0 0 28px; border-right: none; border-bottom: none;
    font-size: 22px; font-weight: 600; line-height: 1.3;
  }
  .brands-label br { display: none; }
  .brands-logos { margin: 0; padding: 0; width: 100%; justify-content: center; }
  .brands-logos img { width: 100%; max-width: 480px; max-height: none; height: auto; margin: 0 auto; }
  .clients-top-wrap { grid-template-columns: 1fr; }
  .biopac-card { grid-row: span 1; min-height: 220px; }
  .clients-cta-inner { flex-direction: column; }
  .clients-cta-text { flex: none; padding: 50px 24px 30px; }
  .clients-cta-image { margin: 0; padding: 0 10px 40px; width: 100%; box-sizing: border-box; display: flex; justify-content: center; }
  .clients-cta-image img { width: 354px; max-width: 100%; height: 375px; object-fit: cover; border-radius: 20px; margin: 0; display: block; }
}
@media (max-width: 600px) {
  .clients-hero { padding: 60px 24px 70px; }
  .clients-hero-inner { gap: 36px; }
  .clients-hero-left { text-align: center; display: flex; flex-direction: column; align-items: center; }
  .clients-eyebrow { font-size: 15px; letter-spacing: 3px; font-weight: 500; margin-bottom: 28px; color: #2a2a2a; }
  .clients-hero h1 { font-size: 64px; line-height: 1.05; margin-bottom: 36px; letter-spacing: -1px; }
  .clients-hero-left p { font-size: 19px; line-height: 1.55; margin-bottom: 30px; max-width: 360px; }
  .clients-hero-left p br { display: none; }
  .btn-schedule { font-size: 18px; padding: 16px 32px; }
  .clients-hero-right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 290px auto;
    gap: 16px;
    margin-top: 40px;
  }
  .hero-img-card:nth-child(1) { grid-column: 1; grid-row: 1; height: 290px; align-self: stretch; }
  .hero-img-card:nth-child(2) { grid-column: 2; grid-row: 1; height: 240px; align-self: end; }
  .hero-img-card:nth-child(3) { grid-column: 1 / 3; grid-row: 2; width: 75%; height: 150px; justify-self: center; margin-top: 4px; }
  .brands-outer, .all-clients-section { padding-left:24px; padding-right:24px; }
  .clients-main-grid { grid-template-columns:1fr 1fr; gap:12px; }
  .top-four-grid { grid-template-columns:1fr 1fr; }
  .all-clients-heading { font-size: 28px; }
  .client-card { padding: 14px 6px 12px; height: 170px; min-height: 170px; max-height: 170px; }
  .client-card-link { font-size: 11px; white-space: nowrap; text-align: center; line-height: 1.3; letter-spacing: -0.2px; }
  .biopac-card { padding: 28px 22px; }
  .biopac-link { font-size: 14px; white-space: nowrap; }
}
</style>

<!-- ══ HERO ══ -->
<section class="clients-hero">
  <div class="clients-hero-inner">
    <div class="clients-hero-left">
      <div class="clients-eyebrow">Case Studies</div>
      <h1>Success Speaks for Itself</h1>
      <p>See our portfolio of clients who improved their business with<br/>better software.</p>
      <a href="/contact-us/" class="btn-schedule">Schedule a Consultation</a>
    </div>
    <div class="clients-hero-right">
      {HERO_CARDS.map(c => (
        <a class="hero-img-card" href={c.link}>
          <div class="hero-img-card-bg" style={`background-image:url('${c.photo}')`}></div>
          <div class="hero-img-card-content">
            <div class="hero-img-card-name">{c.name}</div>
            <span class="hero-img-card-link">Read case study →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ══ BRANDS BAR ══ -->
<div class="brands-outer">
  <div class="brands-wrap">
    <div class="brands-label">Companies that trust our<br/>experienced team.</div>
    <div class="brands-logos">
      <img src="https://demskigroup.com/wp-content/uploads/2024/06/logoswhite-1024x366.png" alt="companies we work with" width="1024" height="366" loading="lazy" decoding="async" />
    </div>
  </div>
</div>

<!-- ══ ALL CLIENTS ══ -->
<section class="all-clients-section">
  <div class="all-clients-inner">
    <h2 class="all-clients-heading">
      Over 600 Projects Delivered<br/>Successfully. Here Are Some of<br/>Our Clients.
    </h2>
    <!-- BIOPAC + 4 -->
    {biopac && (
      <div class="clients-top-wrap">
        <a class="biopac-card" href={biopac.link} style="grid-row:span 2">
          <div class="biopac-logo">
            {biopacPhoto
              ? <img src={biopacPhoto} alt={biopac.name} style="height:64px;object-fit:contain;filter:brightness(0) invert(1)" loading="lazy" decoding="async" />
              : <span class="biopac-name-text">{biopac.name}</span>}
          </div>
          <p class="biopac-desc">{biopacDesc}</p>
          <span class="biopac-link">Read full case study →</span>
        </a>
        <div class="top-four-grid">
          {topFour.map((c: any) => {
            const photo = c.photo || KNOWN_IMAGES[c.slug] || '';
            return (
              <a class="client-card" href={c.link}>
                <div class="client-card-img-wrap">
                  {photo ? <img src={photo} alt={c.name} loading="lazy" /> : <span class="client-card-name">{c.name}</span>}
                </div>
                <span class="client-card-link">Read full case study →</span>
              </a>
            );
          })}
        </div>
      </div>
    )}
    <!-- All remaining -->
    <div class="clients-main-grid">
      {rest.map((c: any) => {
        const photo = c.photo || KNOWN_IMAGES[c.slug] || '';
        return (
          <a class="client-card" href={c.link}>
            <div class="client-card-img-wrap">
              {photo ? <img src={photo} alt={c.name} loading="lazy" /> : <span class="client-card-name">{c.name}</span>}
            </div>
            <span class="client-card-link">Read full case study →</span>
          </a>
        );
      })}
    </div>
  </div>
</section>

<!-- ══ FINAL CTA ══ -->
<section class="clients-cta">
  <div class="clients-cta-inner">
    <div class="clients-cta-text">
      <h2>
        <span>Transform Your Vision into Reality:</span>
        <span style="color: white;">Partner with Our Expert Team Today!</span>
      </h2>
      <div>
        <a href="/contact-us/" class="btn-cta-orange">Schedule a Consultation</a>
      </div>
    </div>
    <div class="clients-cta-image">
      <img src="https://demskigroup.com/wp-content/uploads/2024/06/cropped-shot-of-a-group-of-creatives-having-a-meet-2023-11-27-04-53-10-utc-1.jpg" alt="Team meeting" width="926" height="375" loading="lazy" />
    </div>
  </div>
</section>


</Layout>
