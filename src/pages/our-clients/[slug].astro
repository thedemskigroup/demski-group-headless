    .cs-willo .cs-content .wpr-ba-divider-icons i.fa-angle-left::before { content: '\2039'; }
    .cs-willo .cs-content .wpr-ba-divider-icons i.fa-angle-right::before { content: '\203A'; }
    .cs-willo .cs-content .wpr-ba-label {
