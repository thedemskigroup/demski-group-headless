---
import Layout from '../../layouts/Layout.astro';
import { normalizeClient, CLIENT_FALLBACKS } from '../../data/clientFallbacks';

const { slug } = Astro.params as { slug: string };

// Companies with a featured "graphic card" (background image + blurb). For
// these, the first card renders large instead of a plain logo card. Add an
// entry here to give any company its own graphic card.
const GRAPHIC_CARDS: Record<string, { bg: string; blurb: string }> = {
  'farmers-daughter-fibers': {
    // TODO: replace with the real yarn background image URL.
    bg: 'https://demskigroup.com/wp-content/uploads/2025/02/Blue-Abstract-Background-1-768x432.jpg',
    blurb: "The Demski Group developed a new website for The Farmer's Daughter Fibers using Shopify, prioritizing conversion rate optimization and site performance. See how we achieved 1,144.27% Return on Investment.",
  },
};

// Real per-slug case-study logos (mirrors the map used on the Our Clients
// listing page). Used instead of CLIENT_FALLBACKS.logo, which is the Demski
// default / a stock photo for some clients.
const KNOWN_LOGOS: Record<string, string> = {
  'biopac': '/logos/Biopac.png',
  'shop-orthopedics': 'https://demskigroup.com/wp-content/uploads/2024/06/ShopOrthopedics-1.png',
  'property-gauge': 'https://demskigroup.com/wp-content/uploads/2024/07/PropertyGauge.png',
  'mister-quik': 'https://demskigroup.com/wp-content/uploads/2024/07/mrquick.png',
  'pnc-bank': 'https://demskigroup.com/wp-content/uploads/2024/06/company-logo-4.png',
  'jackson-hewitt': 'https://demskigroup.com/wp-content/uploads/2024/06/jacksonhewitt-1.png',
  'seen-dating': 'https://demskigroup.com/wp-content/uploads/2024/06/SEENDating-1.png',
  'nu-borders': 'https://demskigroup.com/wp-content/uploads/2024/07/Nuborders.png',
  'robomaster': 'https://demskigroup.com/wp-content/uploads/2024/06/Robomaster-1.png',
  'zoomifi': 'https://demskigroup.com/wp-content/uploads/2024/06/Zoomifi-1.png',
  'yawye': 'https://demskigroup.com/wp-content/uploads/2024/06/Yawye-1.png',
  'tausi-brands': 'https://demskigroup.com/wp-content/uploads/2024/06/Tausi-1.png',
  'corning-glass': 'https://demskigroup.com/wp-content/uploads/2024/07/corning-300x201-1.png',
  'flower-moxie-case-study': 'https://demskigroup.com/wp-content/uploads/2024/07/Flowermoxie.png',
  'golf-daddy': 'https://demskigroup.com/wp-content/uploads/2024/07/Branded-300x159.png',
  'audiojack': 'https://demskigroup.com/wp-content/uploads/2024/06/audiojackhighres-300x159.png',
  'willo': 'https://demskigroup.com/wp-content/uploads/2024/06/Willo.png',
  'impact-team-tennis': 'https://demskigroup.com/wp-content/uploads/2025/02/ITTLogo-300x159.png',
  'bite': 'https://demskigroup.com/wp-content/uploads/2024/08/newbitelogo.png',
  'hewlett-packard-enterprise': '/logos/hpe.png',
  'farmers-daughter-fibers': 'https://demskigroup.com/wp-content/uploads/2024/07/FarmersDaughter.png',
};

// "Other Success Stories" cards — every other case-study client.
// Graphic-card companies are sorted first so the featured card leads the grid.
const otherClients = Object.entries(CLIENT_FALLBACKS)
  .filter(([s]) => s !== slug)
  .map(([s, d]) => ({ slug: s, title: d.title, logo: KNOWN_LOGOS[s] || d.logo, graphic: GRAPHIC_CARDS[s] || null }))
  .sort((a, b) => (b.graphic ? 1 : 0) - (a.graphic ? 1 : 0));

const WP_URLS = [
  `https://demskigroup.com/wp-json/wp/v2/our-clients?slug=${slug}&_embed`,
  `https://demskigrdev.wpenginepowered.com/wp-json/wp/v2/our-clients?slug=${slug}&_embed`,
];

let apiItem: any = null;
for (const url of WP_URLS) {
  try {
    const res = await fetch(url, { signal: AbortSignal.timeout(8000) });
    if (!res.ok) continue;
    const data = await res.json();
    if (Array.isArray(data) && data.length) { apiItem = data[0]; break; }
  } catch (_) { continue; }
}

// Always produces a complete object — title/logo/industries/sections are
// guaranteed even if the API is down or returned nothing for this slug.
// normalizeClient() extracts the full case-study narrative from WordPress's
// Elementor content.rendered (all sections/sub-sections/images/lists as
// authored, with global page-chrome stripped). When the live API is
// unavailable or has no usable content, client.content is empty and we fall
// back to the static structured sections (Project / Solution / Key Features
// / Results / Conclusion) below.
const client = normalizeClient(slug, apiItem);
const hasLiveContent = client.content.trim().length > 0;
if (!apiItem && !CLIENT_FALLBACKS[slug]) Astro.response.status = 404;
Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=7200');
---

<Layout title={`${client.title} | Case Study – The Demski Group`} description={client.excerpt} ogImage={client.logo}>

  <style slot="head">
    .cs-page { font-family: 'Outfit', sans-serif; color: #1b1c1d; }

    /* ── Hero ── */
    .cs-hero {
      background: #fff;
      padding: 60px 60px 40px;
      border-bottom: 1px solid #ececec;
    }
    .cs-hero-inner {
      max-width: 1280px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
    }
    .cs-hero .breadcrumb { font-size: 14px; color: #888; margin-bottom: 18px; }
    .cs-hero .breadcrumb a { color: #888; text-decoration: none; }
    .cs-hero .breadcrumb a:hover { color: #001629; }
    .cs-hero h1 {
      font-size: clamp(32px, 4.5vw, 48px);
      font-weight: 700;
      color: #0a0000;
      line-height: 1.15;
      max-width: 640px;
      margin: 0;
    }
    .cs-hero-logo {
      flex-shrink: 0;
      width: 220px;
      height: 110px;
      border: 1px solid #ececec;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
      background: #fff;
    }
    .cs-hero-logo img { max-width: 100%; max-height: 100%; object-fit: contain; }

    /* ── Body layout ── */
    .cs-body-wrap {
      max-width: 1280px;
      margin: 0 auto;
      padding: 50px 60px 80px;
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 60px;
      align-items: flex-start;
    }
    .cs-sidebar { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 28px; }
    .cs-sb-group { padding-bottom: 20px; border-bottom: 1px solid #ececec; }
    .cs-sb-group:last-child { border-bottom: none; padding-bottom: 0; }
    .cs-sb-label {
      font-size: 13px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
      color: #555; margin-bottom: 12px;
    }
    .cs-sb-tags { display: flex; flex-wrap: wrap; gap: 8px; }
    .cs-sb-tag {
      font-size: 13px; font-weight: 700; color: #1b1c1d; background: transparent;
      border: 1px solid #b0b0b0; padding: 5px 14px;
      border-radius: 20px; white-space: nowrap;
    }

    .cs-article { min-width: 0; overflow: hidden; }

    /* ── Feature list ── */
    .cs-feature { margin-bottom: 28px; }
    .cs-feature:last-child { margin-bottom: 0; }
    .cs-feature p { margin-bottom: 0; }

    /* ── Screenshot ── */
    .cs-screenshot-wrap { margin: 36px 0; text-align: center; }
    .cs-screenshot-wrap img {
      max-width: 100%; max-height: 480px; width: auto;
      border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.12);
      background: #f5f5f5; object-fit: contain;
    }

    /* ── Quote ── */
    .cs-quote { background: #f0f6ff; border-left: 4px solid #001629; border-radius: 0 8px 8px 0; padding: 24px 28px; margin: 36px 0; }
    .cs-quote p { font-style: italic; color: #444; font-size: 18px; line-height: 1.7; margin: 0 0 10px; }
    .cs-quote-author { font-weight: 700; color: #0a0000; font-size: 15px; }

    /* ── Results stats ── */
    .cs-stats-row { display: flex; gap: 20px; margin: 24px 0 36px; flex-wrap: wrap; }
    .cs-stat-box {
      background: #f09300; color: #fff; border-radius: 12px; padding: 24px 32px;
      text-align: center; flex: 1; min-width: 140px;
    }
    .cs-stat-value { font-size: 36px; font-weight: 800; line-height: 1.1; }
    .cs-stat-label { font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 6px; }

    .back-link {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 15px; color: #5B7486; font-weight: 600;
      text-decoration: none; margin-top: 40px;
    }
    .back-link:hover { color: #005cb9; }
    .back-link svg { transform: rotate(180deg); }

    /* ── CTA banner ── */
    .cs-cta {
      background: #0C0C0C; margin-top: 20px; overflow: visible; position: relative;
    }
    .cs-cta-inner {
      max-width: 100%; display: flex; align-items: center; min-height: 180px;
    }
    .cs-cta-text {
      flex: 0 0 46%; padding: 50px 60px; display: flex; flex-direction: column;
      justify-content: center; gap: 22px;
    }
    .cs-cta-text h2 { font-size: 28px; font-weight: 700; color: #fff; line-height: 1.3; margin: 0; }
    .cs-cta-text h2 span { color: #4798ed; display: block; }
    .cs-cta-image { flex: 1; overflow: visible; display: flex; align-items: flex-start; }
    .cs-cta-image img {
      width: 100%; height: 280px; object-fit: cover; object-position: center 65%;
      display: block; border-radius: 16px 0 0 16px; margin-top: -50px;
    }
    .btn-cta-orange {
      display: inline-flex; align-items: center; justify-content: center;
      background: #F09300; color: #fff; font-family: 'Outfit', sans-serif;
      font-size: 16px; font-weight: 600; padding: 14px 32px; border-radius: 8px;
      text-decoration: none; width: fit-content; transition: background 0.3s;
    }
    .btn-cta-orange:hover { background: #d98200; }

    /* ── Other Success Stories grid (shop-orthopedics) ── */
    .cs-other-stories { background: #fff; }
    .cs-other-inner { max-width: 1280px; margin: 0 auto; padding: 30px 60px 70px; }
    .cs-other-stories h2 {
      font-size: 34px; font-weight: 800; color: #0a0000; line-height: 1.2;
      margin: 0 0 14px; font-family: 'Outfit', sans-serif;
    }
    .cs-other-inner > p { color: #555; font-size: 17px; line-height: 1.6; max-width: 680px; margin: 0 0 40px; }
    .cs-other-grid { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 175px; gap: 20px; }
    .cs-other-card {
      display: flex; flex-direction: column; align-items: center; justify-content: space-between;
      gap: 16px; background: #fff; border: 1px solid #ebebeb; border-radius: 28px;
      padding: 28px 18px; text-decoration: none;
      box-shadow: 0 4px 20px rgba(0,0,0,0.18);
      transition: box-shadow 0.25s;
    }
    .cs-other-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.35); }
    .cs-other-card-logo { flex: 1; display: flex; align-items: center; justify-content: center; }
    .cs-other-card-logo img { max-height: 70px; max-width: 80%; object-fit: contain; }
    .cs-other-card-link { font-size: 14px; font-weight: 600; color: #0a0000; white-space: nowrap; }
    .cs-other-card:hover .cs-other-card-link { color: #0154b1; }
    /* Featured graphic card — spans 2×2, bg image + dark overlay + white logo. */
    .cs-other-card--featured {
      grid-column: span 2; grid-row: span 2; padding: 0; overflow: hidden;
      position: relative; background-size: cover; background-position: center;
      align-items: stretch; justify-content: stretch;
    }
    .cs-other-card--featured::before { content: ''; position: absolute; inset: 0; background: rgba(15,18,26,0.62); z-index: 0; }
    .cs-other-feat-body { position: relative; z-index: 1; display: flex; flex-direction: column; height: 100%; padding: 32px; }
    .cs-other-feat-logo { height: 110px; object-fit: contain; object-position: left center; filter: brightness(0) invert(1); }
    .cs-other-feat-desc { color: rgba(255,255,255,0.9); font-size: 16px; line-height: 1.6; margin-top: auto; margin-bottom: 14px; }
    .cs-other-feat-link { color: #fff; align-self: flex-start; }

    @media (max-width: 900px) {
      .cs-other-inner { padding: 24px 20px 50px; }
      .cs-other-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
    /* Phones: a 2-col card grid overflows (card min-content > half the width),
       so stack to a single column and let the featured card go full-width. */
    @media (max-width: 600px) {
      .cs-other-inner { padding: 22px 16px 44px; }
      .cs-other-grid { grid-template-columns: 1fr; grid-auto-rows: auto; gap: 14px; }
      .cs-other-card { min-height: 150px; }
      .cs-other-card--featured { grid-column: auto; grid-row: auto; min-height: 300px; }
      .cs-other-card-link { white-space: normal; }
    }

    @media (max-width: 900px) {
      .cs-hero { padding: 32px 20px 24px; }
      .cs-hero-inner { flex-direction: column; align-items: flex-start; gap: 28px; }
      .cs-hero-logo {
        width: 100%; max-width: 280px; height: 200px; border: none; border-radius: 0;
        margin: 0 auto; padding: 0;
      }
      .cs-body-wrap { grid-template-columns: 1fr; padding: 32px 20px 60px; gap: 28px; }
      .cs-sidebar { position: static; flex-direction: column; gap: 0; }
      .cs-sb-group { width: 100%; }
      .cs-content p, .cs-section p, .cs-feature p { font-size: 16px; }
      .cs-content h2, .cs-section h2 { font-size: 26px; margin: 36px 0 12px !important; }
      .cs-content img { margin: 16px auto !important; }
      .cs-content blockquote::before { font-size: 40px; }
      .cs-stats-row { flex-direction: column; }
      .cs-cta-inner { flex-direction: column; min-height: 0; }
      .cs-cta-text { flex: none; padding: 36px 24px 30px; }
      .cs-cta-image { flex: none; margin: 0; padding: 0 10px 30px; width: 100%; box-sizing: border-box; display: flex; justify-content: center; }
      .cs-cta-image img { width: 100%; max-width: 100%; height: 220px; object-fit: cover; object-position: center 65%; border-radius: 16px; margin: 0; }
    }
  </style>

  <!--
    The styles below are global (not Astro-scoped) because .cs-content's
    contents come from set:html — raw HTML injected from WordPress that never
    receives Astro's data-astro-cid-* scoping attributes. Scoped selectors
    like ".cs-content h2[data-astro-cid-x]" would never match this markup.
  -->
  <style is:global slot="head">
    /* Reset Elementor's structural wrapper divs (sections/containers/columns/
       widgets) to plain block flow — Elementor's own CSS isn't loaded here,
       so without this reset these divs default to flex/grid containers that
       break out of .cs-content's single-column layout. Only the actual
       content elements (h2/h3/p/img/ul/etc.) should be styled. */
    .cs-content .e-con,
    .cs-content .e-con-inner,
    .cs-content .e-con-full,
    .cs-content .e-con-boxed,
    .cs-content .e-parent,
    .cs-content .e-child,
    .cs-content .elementor-element,
    .cs-content .elementor-widget-container {
      display: block; width: 100%; max-width: 100%;
      flex: none; margin: 0; padding: 0;
    }

    /* ── WILLO desktop zigzag (scope: .cs-willo only) ──
       Re-enable the two-column rows WordPress/Elementor authored but the
       reset above flattened. Targets only the four clean image/text rows by
       their stable Elementor element ids. Desktop only — mobile/tablet keep
       the stacked single-column layout untouched. */
    @media (min-width: 901px) {
      .cs-willo .cs-content .elementor-element-67fd5fb > .e-con-inner,
      .cs-willo .cs-content .elementor-element-3cfbc4a > .e-con-inner,
      .cs-willo .cs-content .elementor-element-7e72035 > .e-con-inner,
      .cs-willo .cs-content .elementor-element-db2834a > .e-con-inner {
        display: flex; gap: 48px; align-items: center;
      }
      .cs-willo .cs-content .elementor-element-67fd5fb > .e-con-inner > .elementor-element,
      .cs-willo .cs-content .elementor-element-3cfbc4a > .e-con-inner > .elementor-element,
      .cs-willo .cs-content .elementor-element-7e72035 > .e-con-inner > .elementor-element,
      .cs-willo .cs-content .elementor-element-db2834a > .e-con-inner > .elementor-element {
        flex: 1 1 0; min-width: 0;
      }
      /* Key Features [2a3f537]: intro (left) | feature accordion (right),
         top-aligned because the two columns are unequal-height lists. */
      .cs-willo .cs-content .elementor-element-2a3f537 > .e-con-inner {
        display: flex; gap: 48px; align-items: flex-start;
      }
      .cs-willo .cs-content .elementor-element-2a3f537 > .e-con-inner > .elementor-element {
        flex: 1 1 0; min-width: 0;
      }
      /* Seamless Sync header row [67fd5fb]: heading/text wide-left, the two
         CTA buttons narrow-right and top-aligned beside the heading. */
      .cs-willo .cs-content .elementor-element-67fd5fb > .e-con-inner {
        align-items: flex-start;
      }
      .cs-willo .cs-content .elementor-element-67fd5fb > .e-con-inner > .elementor-element:first-child {
        flex: 2 1 0;
      }
      .cs-willo .cs-content .elementor-element-67fd5fb > .e-con-inner > .elementor-element:last-child {
        flex: 1 1 0;
      }

      /* Pairing row [44ad9c7]: toothbrush (left) | caption (mid) | phone
         (right) — the inner wrapper 2193ffa holds the three columns. */
      .cs-willo .cs-content .elementor-element-2193ffa {
        display: flex; gap: 32px; align-items: center;
      }
      .cs-willo .cs-content .elementor-element-2193ffa > .elementor-element {
        flex: 1 1 0; min-width: 0;
      }
      /* Portrait phone / before-after images in the zigzag rows are very tall
         (≈585×1023). Cap their height and centre them in the column so they
         match the reference scale instead of filling the half-width. */
      .cs-willo .cs-content .elementor-element-3cfbc4a img,
      .cs-willo .cs-content .elementor-element-7e72035 img,
      .cs-willo .cs-content .elementor-element-2193ffa img,
      .cs-willo .cs-content .elementor-element-db2834a img {
        max-height: 480px; width: auto; max-width: 100%; margin: 0 auto;
      }

      /* CTA buttons (Schedule a Consultation / Call Us) in the Seamless Sync
         row and the Unlock the Benefits intro → match the site-wide orange
         CTA button instead of the default grey pill. willo only. */
      .cs-willo .cs-content .elementor-element-67fd5fb a.elementor-button,
      .cs-willo .cs-content .elementor-element-f8ea4ab a.elementor-button,
      .cs-shop-orthopedics .cs-content .elementor-element-67fd5fb a.elementor-button,
      .cs-shop-orthopedics .cs-content .elementor-element-2a3f537 a.elementor-button,
      .cs-farmers-daughter-fibers .cs-content .elementor-element-67fd5fb a.elementor-button,
      .cs-farmers-daughter-fibers .cs-content .elementor-element-2a3f537 a.elementor-button {
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        background: #F09300; color: #fff; text-decoration: none;
        font-size: 16px; font-weight: 600; font-family: 'Outfit', sans-serif;
        padding: 14px 28px; border-radius: 8px; margin: 0 12px 12px 0;
        border: none; transition: all 0.4s ease;
      }
      .cs-willo .cs-content .elementor-element-67fd5fb a.elementor-button:hover,
      .cs-willo .cs-content .elementor-element-f8ea4ab a.elementor-button:hover,
      .cs-shop-orthopedics .cs-content .elementor-element-67fd5fb a.elementor-button:hover,
      .cs-shop-orthopedics .cs-content .elementor-element-2a3f537 a.elementor-button:hover,
      .cs-farmers-daughter-fibers .cs-content .elementor-element-67fd5fb a.elementor-button:hover,
      .cs-farmers-daughter-fibers .cs-content .elementor-element-2a3f537 a.elementor-button:hover {
        background: #ffffff; color: #222; border: none;
      }
      .cs-willo .cs-content .elementor-element-67fd5fb a[href^="tel:"].elementor-button::before,
      .cs-willo .cs-content .elementor-element-f8ea4ab a[href^="tel:"].elementor-button::before,
      .cs-shop-orthopedics .cs-content .elementor-element-67fd5fb a[href^="tel:"].elementor-button::before,
      .cs-shop-orthopedics .cs-content .elementor-element-2a3f537 a[href^="tel:"].elementor-button::before,
      .cs-farmers-daughter-fibers .cs-content .elementor-element-67fd5fb a[href^="tel:"].elementor-button::before,
      .cs-farmers-daughter-fibers .cs-content .elementor-element-2a3f537 a[href^="tel:"].elementor-button::before {
        content: '\260E'; font-size: 15px; line-height: 1;
      }

      /* Animated dashed connector line between the toothbrush and phone in the
         pairing row (empty html widget 97cbb75). Marching purple dashes. */
      .cs-willo .cs-content .elementor-element-97cbb75 {
        height: 5px; width: 100%; margin: 22px 0 6px; border-radius: 3px;
        background-image: repeating-linear-gradient(90deg,
          #7c3aed 0 18px, transparent 18px 30px);
        background-size: 30px 100%; background-repeat: repeat-x;
        animation: willo-pairing-dash 0.7s linear infinite;
      }


      /* ── Unlock the Benefits [b1228f9] benefit grid (55000c0) ──
         Six benefit items into a 2-column grid; each item keeps its top
         divider line, gets a blue circled check, and an icon-left /
         title+description-right layout to match the reference. */
      .cs-willo .cs-content .elementor-element-55000c0 {
        display: grid; grid-template-columns: 1fr 1fr; column-gap: 56px;
      }
      .cs-willo .cs-content .elementor-element-55000c0 > .elementor-element {
        padding-bottom: 26px;
      }
      .cs-willo .cs-content .elementor-element-55000c0 .elementor-divider {
        margin: 0 0 18px;
      }
      .cs-willo .cs-content .elementor-element-55000c0 .elementor-icon-box-wrapper {
        display: flex; align-items: flex-start; gap: 14px;
      }
      .cs-willo .cs-content .elementor-element-55000c0 .elementor-icon-box-icon {
        flex: 0 0 auto; display: block; margin: 0;
      }
      /* the source icon glyph is empty — draw the blue circled check here */
      .cs-willo .cs-content .elementor-element-55000c0 .elementor-icon-box-icon::before {
        content: '\2713'; display: flex; align-items: center; justify-content: center;
        width: 26px; height: 26px; border-radius: 50%;
        border: 2px solid #005cb9; color: #005cb9;
        font-size: 14px; font-weight: 700; line-height: 1;
      }
