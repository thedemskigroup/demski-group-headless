---
import Layout from '../../layouts/Layout.astro';
import { normalizeClient } from '../../data/clientFallbacks';

const { slug } = Astro.params as { slug: string };

const WP_URLS = [
  `https://demskigroup.com/wp-json/wp/v2/our-clients?slug=${slug}&_embed`,
  `https://demskigrdev.wpenginepowered.com/wp-json/wp/v2/our-clients?slug=${slug}&_embed`,
];

let apiItem: any = null;
for (const url of WP_URLS) {
  try {
    const res = await fetch(url, { signal: AbortSignal.timeout(8000) });
    if (!res.ok) continue;
    const data = await res.json();
    if (Array.isArray(data) && data.length) { apiItem = data[0]; break; }
  } catch (_) { continue; }
}

// Always produces a complete object — title/logo/industries/sections are
// guaranteed even if the API is down or returned nothing for this slug.
// normalizeClient() extracts the full case-study narrative from WordPress's
// Elementor content.rendered (all sections/sub-sections/images/lists as
// authored, with global page-chrome stripped). When the live API is
// unavailable or has no usable content, client.content is empty and we fall
// back to the static structured sections (Project / Solution / Key Features
// / Results / Conclusion) below.
const client = normalizeClient(slug, apiItem);
const hasLiveContent = client.content.trim().length > 0;
Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=7200');
---

<Layout title={`${client.title} | Case Study – The Demski Group`} description={client.excerpt}>

  <style slot="head">
    .cs-page { font-family: 'Outfit', sans-serif; color: #1b1c1d; }

    /* ── Hero ── */
    .cs-hero {
      background: #fff;
      padding: 60px 60px 40px;
      border-bottom: 1px solid #ececec;
    }
    .cs-hero-inner {
      max-width: 1280px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
    }
    .cs-hero .breadcrumb { font-size: 14px; color: #888; margin-bottom: 18px; }
    .cs-hero .breadcrumb a { color: #888; text-decoration: none; }
    .cs-hero .breadcrumb a:hover { color: #001629; }
    .cs-hero h1 {
      font-size: clamp(32px, 4.5vw, 48px);
      font-weight: 700;
      color: #0a0000;
      line-height: 1.15;
      max-width: 640px;
      margin: 0;
    }
    .cs-hero-logo {
      flex-shrink: 0;
      width: 220px;
      height: 110px;
      border: 1px solid #ececec;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
      background: #fff;
    }
    .cs-hero-logo img { max-width: 100%; max-height: 100%; object-fit: contain; }

    /* ── Body layout ── */
    .cs-body-wrap {
      max-width: 1280px;
      margin: 0 auto;
      padding: 50px 60px 80px;
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 60px;
      align-items: flex-start;
    }
    .cs-sidebar { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 28px; }
    .cs-sb-group { padding-bottom: 20px; border-bottom: 1px solid #ececec; }
    .cs-sb-group:last-child { border-bottom: none; padding-bottom: 0; }
    .cs-sb-label {
      font-size: 13px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
      color: #555; margin-bottom: 12px;
    }
    .cs-sb-tags { display: flex; flex-wrap: wrap; gap: 8px; }
    .cs-sb-tag {
      font-size: 13px; font-weight: 700; color: #1b1c1d; background: transparent;
      border: 1px solid #b0b0b0; padding: 5px 14px;
      border-radius: 20px; white-space: nowrap;
    }

    .cs-article { min-width: 0; overflow: hidden; }

    /* ── Feature list ── */
    .cs-feature { margin-bottom: 28px; }
    .cs-feature:last-child { margin-bottom: 0; }
    .cs-feature p { margin-bottom: 0; }

    /* ── Screenshot ── */
    .cs-screenshot-wrap { margin: 36px 0; text-align: center; }
    .cs-screenshot-wrap img {
      max-width: 100%; max-height: 480px; width: auto;
      border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.12);
      background: #f5f5f5; object-fit: contain;
    }

    /* ── Quote ── */
    .cs-quote { background: #f0f6ff; border-left: 4px solid #001629; border-radius: 0 8px 8px 0; padding: 24px 28px; margin: 36px 0; }
    .cs-quote p { font-style: italic; color: #444; font-size: 18px; line-height: 1.7; margin: 0 0 10px; }
    .cs-quote-author { font-weight: 700; color: #0a0000; font-size: 15px; }

    /* ── Results stats ── */
    .cs-stats-row { display: flex; gap: 20px; margin: 24px 0 36px; flex-wrap: wrap; }
    .cs-stat-box {
      background: #f09300; color: #fff; border-radius: 12px; padding: 24px 32px;
      text-align: center; flex: 1; min-width: 140px;
    }
    .cs-stat-value { font-size: 36px; font-weight: 800; line-height: 1.1; }
    .cs-stat-label { font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 6px; }

    .back-link {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 15px; color: #5B7486; font-weight: 600;
      text-decoration: none; margin-top: 40px;
    }
    .back-link:hover { color: #005cb9; }
    .back-link svg { transform: rotate(180deg); }

    /* ── CTA banner ── */
    .cs-cta {
      background: #0C0C0C; margin-top: 20px; overflow: visible; position: relative;
    }
    .cs-cta-inner {
      max-width: 100%; display: flex; align-items: center; min-height: 180px;
    }
    .cs-cta-text {
      flex: 0 0 46%; padding: 50px 60px; display: flex; flex-direction: column;
      justify-content: center; gap: 22px;
    }
    .cs-cta-text h2 { font-size: 28px; font-weight: 700; color: #fff; line-height: 1.3; margin: 0; }
    .cs-cta-text h2 span { color: #4798ed; display: block; }
    .cs-cta-image { flex: 1; overflow: visible; display: flex; align-items: flex-start; }
    .cs-cta-image img {
      width: 100%; height: 280px; object-fit: cover; object-position: center 65%;
      display: block; border-radius: 16px 0 0 16px; margin-top: -50px;
    }
    .btn-cta-orange {
      display: inline-flex; align-items: center; justify-content: center;
      background: #F09300; color: #fff; font-family: 'Outfit', sans-serif;
      font-size: 16px; font-weight: 600; padding: 14px 32px; border-radius: 8px;
      text-decoration: none; width: fit-content; transition: background 0.3s;
    }
    .btn-cta-orange:hover { background: #d98200; }

    @media (max-width: 900px) {
      .cs-hero { padding: 32px 20px 24px; }
      .cs-hero-inner { flex-direction: column; align-items: flex-start; gap: 28px; }
      .cs-hero-logo {
        width: 100%; max-width: 280px; height: 200px; border: none; border-radius: 0;
        margin: 0 auto; padding: 0;
      }
      .cs-body-wrap { grid-template-columns: 1fr; padding: 32px 20px 60px; gap: 28px; }
      .cs-sidebar { position: static; flex-direction: column; gap: 0; }
      .cs-sb-group { width: 100%; }
      .cs-section p, .cs-feature p { font-size: 16px; }
      .cs-section h2 { font-size: 26px; }
      .cs-stats-row { flex-direction: column; }
      .cs-cta-inner { flex-direction: column; min-height: 0; }
      .cs-cta-text { flex: none; padding: 36px 24px 30px; }
      .cs-cta-image { flex: none; margin: 0; padding: 0 10px 30px; width: 100%; box-sizing: border-box; display: flex; justify-content: center; }
      .cs-cta-image img { width: 100%; max-width: 100%; height: 220px; object-fit: cover; object-position: center 65%; border-radius: 16px; margin: 0; }
    }
  </style>

  <!--
    The styles below are global (not Astro-scoped) because .cs-content's
    contents come from set:html — raw HTML injected from WordPress that never
    receives Astro's data-astro-cid-* scoping attributes. Scoped selectors
    like ".cs-content h2[data-astro-cid-x]" would never match this markup.
  -->
  <style is:global slot="head">
    /* Reset Elementor's structural wrapper divs (sections/containers/columns/
       widgets) to plain block flow — Elementor's own CSS isn't loaded here,
       so without this reset these divs default to flex/grid containers that
       break out of .cs-content's single-column layout. Only the actual
       content elements (h2/h3/p/img/ul/etc.) should be styled. */
    .cs-content .e-con,
    .cs-content .e-con-inner,
    .cs-content .e-con-full,
    .cs-content .e-con-boxed,
    .cs-content .e-parent,
    .cs-content .e-child,
    .cs-content .elementor-element,
    .cs-content .elementor-widget-container {
      display: block; width: 100%; max-width: 100%;
      flex: none; margin: 0; padding: 0;
    }

    .cs-content { font-size: 17px; line-height: 1.7; color: #333; word-break: break-word; }
    .cs-content h2 {
      font-size: 34px; font-weight: 800; color: #0a0000; line-height: 1.2;
      margin: 48px 0 14px; font-family: 'Outfit', sans-serif;
    }
    .cs-content h2:first-child { margin-top: 0; }
    .cs-content h3 {
      font-size: 17px; font-weight: 700; color: #0a0000; line-height: 1.5;
      margin: 28px 0 8px; font-family: 'Outfit', sans-serif;
    }
    .cs-content h2 + h3, .cs-content > h3:first-child { margin-top: 0; }
    .cs-content p { margin: 0 0 20px; }
    .cs-content a { color: #005cb9; text-decoration: underline; }
    .cs-content a:hover { color: #f09300; }
    .cs-content ul, .cs-content ol { list-style: none; padding-left: 0; margin: 0 0 20px; }
    .cs-content li { position: relative; padding-left: 20px; margin-bottom: 2px; line-height: 1.7; }
    .cs-content li::before { content: '•'; position: absolute; left: 0; color: #333; }
    /* Elementor icon-list: hide the icon widget, use our ::before bullet instead */
    .cs-content .elementor-icon-list-icon { display: none; }
    .cs-content .elementor-icon-list-text { display: inline; }
    .cs-content img { max-width: 100%; height: auto; border-radius: 12px; margin: 24px 0; display: block; }
    .cs-content blockquote {
      border: none; padding: 0; margin: 36px 0; background: transparent;
      font-style: italic; color: #555; border-radius: 0;
    }
    .cs-content blockquote::before {
      content: '\201C'; display: block; font-family: Georgia, serif;
      font-size: 56px; font-weight: 700; color: #005cb9; line-height: 1; margin-bottom: 4px;
    }
    .cs-content blockquote p { font-size: 18px; line-height: 1.7; color: #555; margin: 0 0 4px; }
    .cs-content blockquote + p {
      font-style: normal; color: #0a0000; font-weight: 700; font-size: 15px;
      margin-top: -16px; margin-bottom: 32px;
    }
    .cs-content p.cs-quote-cite {
      font-style: normal; color: #0a0000; font-weight: 700; font-size: 15px;
      line-height: 1.6; margin: -16px 0 32px;
    }
    .cs-content table { width: 100%; border-collapse: collapse; margin: 24px 0; }
    .cs-content table th, .cs-content table td { border: 1px solid #ececec; padding: 10px 14px; text-align: left; }
    .cs-content table th { background: #f7f7f7; font-weight: 700; }
    .cs-content hr { border: none; border-top: 1px solid #ececec; margin: 36px 0; }
    .cs-content .elementor-divider { margin: 36px 0; }
    .cs-content .elementor-divider-separator {
      border-top-color: #ececec !important;
      border-top-style: solid !important;
      border-top-width: 1px !important;
      background-color: #ececec !important;
    }
    /* hide any Elementor divider that appears before the first heading
       (Willo hero area purple dashed line) */
    .cs-content > .elementor-element:first-child .elementor-divider,
    .cs-content > .e-con:first-child .elementor-divider { display: none; }
    .cs-content .elementor-icon,
    .cs-content i[class*="elementor"],
    .cs-content i[aria-hidden="true"] { display: none; }

    /* Elementor "button" widgets (e.g. Tech Stack links) → render as pills */
    .cs-content a.elementor-button {
      display: inline-flex; align-items: center; justify-content: center;
      background: #f2f2f2; color: #333; text-decoration: none;
      font-size: 13px; font-weight: 600; padding: 6px 16px; margin: 4px 6px 4px 0;
      border-radius: 20px;
    }
    .cs-content a.elementor-button:hover { background: #e6e6e6; color: #333; }

    /* Elementor renders the same image twice for responsive breakpoints —
       show only the desktop copy on desktop and only the mobile copy on
       mobile to avoid duplicate images. */
    .cs-content .elementor-hidden-desktop { display: none; }

    /* Elementor's "nested accordion" widget renders as native <details open>/
       <summary> elements. Treat each item as an always-open sub-section
       (matching the plain sub-heading + paragraph pattern used elsewhere):
       hide the native disclosure marker and the +/- icons, and style the
       title text like .cs-content h3. */
    .cs-content details.e-n-accordion-item { margin: 0; }
    .cs-content details.e-n-accordion-item > summary.e-n-accordion-item-title {
      list-style: none; cursor: default;
      display: flex; align-items: center; justify-content: space-between;
      margin: 28px 0 8px;
    }
    .cs-content details.e-n-accordion-item > summary.e-n-accordion-item-title::-webkit-details-marker,
    .cs-content details.e-n-accordion-item > summary.e-n-accordion-item-title::marker {
      display: none; content: '';
    }
    .cs-content .e-n-accordion-item-title-text {
      font-size: 17px; font-weight: 700; color: #0a0000; line-height: 1.5;
      font-family: 'Outfit', sans-serif;
    }
    .cs-content .e-n-accordion-item-title-icon { display: none; }
    .cs-content .e-n-accordion-item > h2:first-child,
    .cs-content .e-n-accordion-item > h3:first-child { margin-top: 0; }

    /* Elementor "Posts Timeline" widget renders sub-section pairs as a
       vertical timeline (icon + line + title/description). Strip the
       timeline decoration and present each entry as a plain sub-heading +
       paragraph, matching the rest of the case study. */
    .cs-content .wpr-wrapper,
    .cs-content .wpr-timeline-centered,
    .cs-content .wpr-timeline-entry,
    .cs-content .wpr-timeline-entry-inner,
    .cs-content .wpr-story-info-vertical,
    .cs-content .wpr-timeline-content-wrapper,
    .cs-content .wpr-content-wrapper,
    .cs-content .wpr-title-wrap,
    .cs-content .wpr-description {
      display: block; width: 100%; max-width: 100%;
      flex: none; margin: 0; padding: 0;
    }
    .cs-content .wpr-middle-line,
    .cs-content .wpr-timeline-fill,
    .cs-content .wpr-main-line-icon { display: none; }
    .cs-content .wpr-title {
      display: block; font-size: 17px; font-weight: 700; color: #0a0000;
      line-height: 1.5; margin: 28px 0 8px; font-family: 'Outfit', sans-serif;
    }
    .cs-content .wpr-description p { margin: 0 0 20px; }

    @media (max-width: 900px) {
      .cs-content, .cs-content p { font-size: 16px; }
      .cs-content h2 { font-size: 26px; margin: 36px 0 12px; }
      .cs-content h3 { font-size: 16px; margin: 22px 0 8px; }
      .cs-content blockquote::before { font-size: 44px; }
      .cs-content .elementor-hidden-mobile,
      .cs-content .elementor-hidden-tablet { display: none; }
      .cs-content .elementor-hidden-desktop { display: block; }
    }
  </style>

  <div class="cs-page">
    <div class="cs-hero">
      <div class="cs-hero-inner">
        <div>
          <div class="breadcrumb">
            <a href="/">Home</a> &nbsp;›&nbsp; <a href="/our-clients/">Our Clients</a> &nbsp;›&nbsp; {client.title}
          </div>
          <h1>{client.tagline}</h1>
        </div>
        <div class="cs-hero-logo">
          <img src={client.logo} alt={`${client.title} logo`} loading="eager" decoding="async" />
        </div>
      </div>
    </div>

    <div class="cs-body-wrap">
      <aside class="cs-sidebar">
        <div class="cs-sb-group">
          <div class="cs-sb-label">Industries</div>
          <div class="cs-sb-tags">
            {client.industries.map((i: string) => <span class="cs-sb-tag">{i}</span>)}
          </div>
        </div>
        <div class="cs-sb-group">
          <div class="cs-sb-label">Tech Stack</div>
          <div class="cs-sb-tags">
            {client.techStack.map((t: string) => <span class="cs-sb-tag">{t}</span>)}
          </div>
        </div>
      </aside>

      <div class="cs-article">
        {hasLiveContent ? (
          <div class="cs-content" set:html={client.content} />
        ) : (
          <>
            <section class="cs-section">
              <h2>The Project</h2>
              <p>{client.project}</p>
            </section>

            <section class="cs-section">
              <h2>Our Solution</h2>
              <p>{client.solution}</p>
            </section>

            {client.features.length > 0 && (
              <section class="cs-section">
                <h2>Key Features</h2>
                {client.features.map((f: any) => (
                  <div class="cs-feature">
                    <h3>{f.title}</h3>
                    <p>{f.text}</p>
                  </div>
                ))}
              </section>
            )}

            <div class="cs-screenshot-wrap">
              <img src={client.screenshot} alt={`${client.title} screenshot`} loading="lazy" decoding="async" />
            </div>

            {client.quote && (
              <div class="cs-quote">
                <p>"{client.quote}"</p>
                {client.quoteAuthor && <div class="cs-quote-author">{client.quoteAuthor}</div>}
              </div>
            )}

            <section class="cs-section">
              <h2>The Results</h2>
              {client.resultsStats.length > 0 && (
                <div class="cs-stats-row">
                  {client.resultsStats.map((s: any) => (
                    <div class="cs-stat-box">
                      <div class="cs-stat-value">{s.value}</div>
                      <div class="cs-stat-label">{s.label}</div>
                    </div>
                  ))}
                </div>
              )}
              {client.results.map((r: any) => (
                <div class="cs-feature">
                  <h3>{r.title}</h3>
                  <p>{r.text}</p>
                </div>
              ))}
            </section>

            <section class="cs-section">
              <h2>Conclusion</h2>
              <p>{client.conclusion}</p>
            </section>
          </>
        )}

        <a class="back-link" href="/our-clients/">
          <svg width="14" height="12" viewBox="0 0 14 12" fill="none">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M0 6C0 5.77271 0.0902897 5.55473 0.251006 5.39402C0.411723 5.2333 0.629701 5.14301 0.856988 5.14301H10.7861L7.10615 1.46482C6.94523 1.3039 6.85482 1.08565 6.85482 0.858071C6.85482 0.630497 6.94523 0.412243 7.10615 0.251323C7.26707 0.0904038 7.48532 0 7.71289 0C7.94047 0 8.15872 0.0904038 8.31964 0.251323L13.4616 5.39325C13.5414 5.47286 13.6047 5.56743 13.6479 5.67154C13.6911 5.77566 13.7133 5.88728 13.7133 6C13.7133 6.11272 13.6911 6.22434 13.6479 6.32845C13.6047 6.43257 13.5414 6.52714 13.4616 6.60675L8.31964 11.7487C8.15872 11.9096 7.94047 12 7.71289 12C7.48532 12 7.26707 11.9096 7.10615 11.7487C6.94523 11.5878 6.85482 11.3695 6.85482 11.1419C6.85482 10.9144 6.94523 10.6961 7.10615 10.5352L10.7861 6.85699H0.856988C0.629701 6.85699 0.411723 6.7667 0.251006 6.60598C0.0902897 6.44527 0 6.22729 0 6Z" fill="#5B7486"/>
          </svg>
          Back to Our Clients
        </a>
      </div>
    </div>

    <!-- ══ FINAL CTA ══ -->
    <section class="cs-cta">
      <div class="cs-cta-inner">
        <div class="cs-cta-text">
          <h2>
            <span>Transform Your Vision into Reality:</span>
            <span style="color: white;">Partner with Our Expert Team Today!</span>
          </h2>
          <a href="/contact-us/" class="btn-cta-orange">Schedule a Consultation</a>
        </div>
        <div class="cs-cta-image">
          <img src="https://demskigroup.com/wp-content/uploads/2024/06/cropped-shot-of-a-group-of-creatives-having-a-meet-2023-11-27-04-53-10-utc-1.jpg" alt="Team meeting" loading="lazy" decoding="async" />
        </div>
      </div>
    </section>
  </div>

</Layout>
