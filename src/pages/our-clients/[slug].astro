    /* Simple single-column case studies (every page EXCEPT the per-slug
       zigzag/layout-fixed ones): give each content image a uniform 1520:820
       box that scales to the column width, object-fit: cover so they all share
       the same shape instead of varying heights. */
    .cs-page:not(.cs-willo):not(.cs-shop-orthopedics):not(.cs-farmers-daughter-fibers):not(.cs-biopac):not(.cs-mister-quik-case-study-new) .cs-content img {
      width: 100%; max-width: 1520px; aspect-ratio: 1520 / 820; height: auto;
      object-fit: cover; margin: 28px auto; border-radius: 12px;
    }
    .cs-content blockquote {
      border: none; padding: 0; margin: 36px 0; background: transparent;
      font-style: italic; color: #555; border-radius: 0;
    }
    .cs-content blockquote::before {
      content: '\201C'; display: block; font-family: Georgia, serif;
      font-size: 56px; font-weight: 700; color: #005cb9; line-height: 1; margin-bottom: 4px;
    }
    .cs-content blockquote p { font-size: 18px; line-height: 1.7; color: #555; margin: 0 0 4px; }
