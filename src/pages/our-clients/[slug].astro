       (handler in the inline script below). All widths. */
    .cs-farmers-daughter-fibers .cs-content .eael-circle-inner {
      position: relative; width: 100%; max-width: 440px; margin: 0 auto;
    }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-inner::after {
      content: ''; display: block; padding-bottom: 100%;
    }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-inner::before {
      content: ''; position: absolute; inset: 11%; border-radius: 50%;
      border: 1.5px solid #b0b0b0; z-index: 0;
    }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-item { position: static; }
    /* centre value panels (stacked, only active visible) */
    .cs-farmers-daughter-fibers .cs-content .eael-circle-btn-content {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      width: 56%; text-align: center; margin: 0;
      font-size: 24px; font-weight: 600; color: #1b1c1d; line-height: 1.35;
      opacity: 0; visibility: hidden; transition: opacity .25s; z-index: 1;
    }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-btn-content.active {
      opacity: 1; visibility: visible;
    }
    /* circle buttons on the ring */
    .cs-farmers-daughter-fibers .cs-content .eael-circle-btn {
      position: absolute; width: 92px; height: 92px; border-radius: 50%;
      background: #fff; box-shadow: 0 4px 16px rgba(0,0,0,0.10);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 3px; padding: 6px; cursor: pointer; transform: translate(-50%,-50%);
      text-align: center; line-height: 1.1; font-size: 12px; font-weight: 600;
      color: #1b1c1d; z-index: 2; transition: background .2s, color .2s, box-shadow .2s;
    }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-btn:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.16); }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-btn svg { width: 30px; height: 30px; }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-btn.active { background: #1456c7; color: #fff; }
    /* six positions around the ring (clockwise from top) */
    .cs-farmers-daughter-fibers .cs-content .eael-circle-item:nth-child(1) .eael-circle-btn { left: 50%;   top: 8%;  }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-item:nth-child(2) .eael-circle-btn { left: 86%;   top: 29%; }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-item:nth-child(3) .eael-circle-btn { left: 86%;   top: 71%; }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-item:nth-child(4) .eael-circle-btn { left: 50%;   top: 92%; }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-item:nth-child(5) .eael-circle-btn { left: 14%;   top: 71%; }
    .cs-farmers-daughter-fibers .cs-content .eael-circle-item:nth-child(6) .eael-circle-btn { left: 14%;   top: 29%; }
    /* Phones: shrink the ring circles + centre text so the widget isn't cramped. */
    @media (max-width: 600px) {
      .cs-farmers-daughter-fibers .cs-content .eael-circle-inner { max-width: 320px; }
      .cs-farmers-daughter-fibers .cs-content .eael-circle-btn { width: 72px; height: 72px; font-size: 10px; gap: 1px; padding: 4px; }
      .cs-farmers-daughter-fibers .cs-content .eael-circle-btn svg { width: 22px; height: 22px; }
      .cs-farmers-daughter-fibers .cs-content .eael-circle-btn-content { font-size: 17px; width: 52%; }
    }

