    /* ── Before/After comparison slider (wpr-before-after widget) ──
       Applies at ALL widths (desktop AND phone) — the WP-Royal plugin's JS/CSS
       isn't loaded here, so this rebuilds it as a CSS clip slider driven by
       --pos; a small inline script handles drag. image-1 = After (base),
       image-2 = Before (clipped overlay). Outside the desktop @media so the
       mobile copy of the widget is a working slider too. */
    .cs-willo .cs-content .wpr-ba-image-container {
      --pos: 50%;
      position: relative; display: block; width: max-content; max-width: 100%;
      margin: 0 auto; line-height: 0; cursor: ew-resize; touch-action: none;
      border-radius: 12px; overflow: hidden; user-select: none;
