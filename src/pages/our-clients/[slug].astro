    /* ══════════ BIOPAC — "Challenges & Requirements" flip cards ══════════
       The four cards beside the heading are EAEL flip-box markup with no plugin
       CSS/JS shipped, so the whole interaction is authored here: a 2×2 grid of
       cards that flip vertically (rotateX) on hover — dark front (icon + title)
       to a blue back (description). Fully self-contained, no Elementor runtime. */
    .cs-biopac .cs-content .elementor-element-1f5c71b,
    .cs-biopac .cs-content .elementor-element-f52b3f5 {
      display: grid; grid-template-columns: 1fr 1fr; gap: 18px;
    }
    .cs-biopac .cs-content .elementor-element-1f5c71b { margin-bottom: 18px; }
    .cs-biopac .cs-content .eael-elements-flip-box-container {
      position: relative; height: 290px; background: transparent;
      perspective: 1200px; margin: 0;
    }
    .cs-biopac .cs-content .eael-elements-flip-box-flip-card {
      position: relative; width: 100%; height: 100%;
      transform-style: preserve-3d; transition: transform 0.6s ease;
    }
    .cs-biopac .cs-content .eael-elements-flip-box-container:hover .eael-elements-flip-box-flip-card,
    .cs-biopac .cs-content .eael-elements-flip-box-container:focus-within .eael-elements-flip-box-flip-card {
      transform: rotateX(180deg);
    }
    .cs-biopac .cs-content .eael-elements-flip-box-front-container,
    .cs-biopac .cs-content .eael-elements-flip-box-rear-container {
      position: absolute; inset: 0; width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center; text-align: center;
      border-radius: 16px; overflow: hidden; color: #fff;
      -webkit-backface-visibility: hidden; backface-visibility: hidden;
    }
    /* dark front — a distinct background image per card, with a subtle dark
       overlay so the centred icon + title stay legible */
    .cs-biopac .cs-content .eael-elements-flip-box-front-container {
      background-color: #0a1f38;
      background-size: cover; background-position: center; background-repeat: no-repeat;
    }
    .cs-biopac .cs-content .elementor-element-928e07a .eael-elements-flip-box-front-container {
      background-image: linear-gradient(180deg, rgba(6,16,32,0.12), rgba(6,16,32,0.42)), url("/cards/scalability.svg");
    }
    .cs-biopac .cs-content .elementor-element-322ff8f .eael-elements-flip-box-front-container {
      background-image: linear-gradient(180deg, rgba(4,18,24,0.12), rgba(4,18,24,0.42)), url("/cards/data-management.svg");
    }
    .cs-biopac .cs-content .elementor-element-3b66714 .eael-elements-flip-box-front-container {
      background-image: linear-gradient(180deg, rgba(6,14,32,0.12), rgba(6,14,32,0.42)), url("/cards/performance.svg");
    }
    .cs-biopac .cs-content .elementor-element-122983b .eael-elements-flip-box-front-container {
      background-image: linear-gradient(180deg, rgba(10,7,32,0.12), rgba(10,7,32,0.45)), url("/cards/billing.svg");
    }
    .cs-biopac .cs-content .eael-elements-flip-box-rear-container {
      transform: rotateX(180deg);
      background: linear-gradient(160deg, #1c6fd6 0%, #0f54b1 100%);
    }
    /* neutralise the EAEL table-cell wrappers and set our own padding */
    .cs-biopac .cs-content .eael-elements-slider-display-table,
    .cs-biopac .cs-content .eael-elements-flip-box-vertical-align,
    .cs-biopac .cs-content .eael-elements-flip-box-padding {
      display: block; width: 100%; height: auto; margin: 0; box-sizing: border-box;
    }
    .cs-biopac .cs-content .eael-elements-flip-box-padding { padding: 26px 24px; }
    .cs-biopac .cs-content .eael-elements-flip-box-heading {
      font-size: 22px; font-weight: 700; color: #fff; margin: 12px 0 0; line-height: 1.25;
      word-break: normal; overflow-wrap: normal; hyphens: none;
    }
    .cs-biopac .cs-content .eael-elements-flip-box-content p {
      font-size: 14px; line-height: 1.6; color: #fff; margin: 0;
    }
    /* icons (white, masked) */
    .cs-biopac .cs-content .eael-elements-flip-box-icon-image {
      display: block; width: 48px; height: 48px; margin: 0 auto;
    }
    .cs-biopac .cs-content .eael-elements-flip-box-icon-image::before {
      content: ''; display: block; width: 100%; height: 100%; background: #fff;
      -webkit-mask: var(--cs-fb-icon) center / contain no-repeat;
      mask: var(--cs-fb-icon) center / contain no-repeat;
    }
    .cs-biopac .cs-content .elementor-element-928e07a .eael-elements-flip-box-icon-image {
      --cs-fb-icon: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='black' d='M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z'/></svg>");
