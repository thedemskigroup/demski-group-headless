    </div>

    {otherClients.length > 0 && (
      <section class="cs-other-stories">
        <div class="cs-other-inner">
          <h2>Some of Our Other Success Stories</h2>
          <p>From custom theme development to SEO to PPC, we specialize in all areas to help you grow your sales online. With over 12 years of experience, we have a lot to talk about.</p>
          <div class="cs-other-grid">
            {otherClients.map((c) => (
              c.graphic ? (
