    /* ══════════ BIOPAC — restore the two-sided "Implementation & Development
       Process" timeline (overrides the flatten rules above). Without Elementor's
       stylesheet the widget is unstyled, so the full timeline is authored here:
       a centre track with a green fill that grows on scroll (see the IIFE at the
       end of the file), node markers, and alternating cards. ══════════ */
    .cs-biopac .cs-content .wpr-timeline-centered {
      position: relative; display: block; width: 100%;
      max-width: 920px; margin: 40px auto; padding: 6px 0;
    }
    /* centre track + green scroll-fill */
    .cs-biopac .cs-content .wpr-middle-line {
      display: block; position: absolute; top: 0; bottom: 0;
      left: 50%; transform: translateX(-50%);
      width: 4px; background: #e3e6ea; border-radius: 4px; overflow: hidden;
    }
    .cs-biopac .cs-content .wpr-middle-line::after {
      content: ''; position: absolute; top: 0; left: 0; width: 100%;
      height: var(--cs-tl-progress, 0%);
      background: #34a853;
    }
    .cs-biopac .cs-content .wpr-timeline-fill { display: none; }
    /* entries occupy half the width, alternating sides */
    .cs-biopac .cs-content .wpr-timeline-entry {
      display: block; position: relative; width: 50%;
      box-sizing: border-box; margin: 0 0 34px; padding: 0;
    }
    .cs-biopac .cs-content .wpr-timeline-entry.wpr-left-aligned {
      left: 0; padding-right: 46px; text-align: right;
    }
    .cs-biopac .cs-content .wpr-timeline-entry.wpr-right-aligned {
      left: 50%; padding-left: 46px; text-align: left;
    }
    .cs-biopac .cs-content .wpr-timeline-entry-inner { display: block; width: 100%; }
    /* node marker sitting on the centre line */
    /* Node markers centred on the line: empty rings for the first two steps,
       glyphs (refresh / check / rocket) for the rest. A node turns green once
       the scroll-fill passes it (cs-tl-active toggled by the IIFE below). */
    .cs-biopac .cs-content .wpr-main-line-icon {
      display: flex; align-items: center; justify-content: center;
      position: absolute; top: 50%; transform: translateY(-50%); z-index: 2;
      width: 46px; height: 46px; border-radius: 50%;
      background: #fff; border: 3px solid #c6ccd4; box-sizing: border-box;
      color: #aeb4bd; transition: border-color 0.3s, color 0.3s;
    }
    .cs-biopac .cs-content .wpr-left-aligned .wpr-main-line-icon { right: -23px; }
    .cs-biopac .cs-content .wpr-right-aligned .wpr-main-line-icon { left: -23px; }
    .cs-biopac .cs-content .wpr-main-line-icon::after {
      content: ''; width: 21px; height: 21px; background: currentColor;
      -webkit-mask: var(--cs-tl-icon) center / contain no-repeat;
      mask: var(--cs-tl-icon) center / contain no-repeat;
    }
    .cs-biopac .cs-content .wpr-timeline-entry:nth-of-type(1) .wpr-main-line-icon::after,
    .cs-biopac .cs-content .wpr-timeline-entry:nth-of-type(2) .wpr-main-line-icon::after { display: none; }
    .cs-biopac .cs-content .wpr-timeline-entry:nth-of-type(3) .wpr-main-line-icon {
      --cs-tl-icon: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='black' d='M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z'/></svg>");
    }
    .cs-biopac .cs-content .wpr-timeline-entry:nth-of-type(4) .wpr-main-line-icon {
      --cs-tl-icon: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='black' d='M9 16.17 4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z'/></svg>");
    }
    .cs-biopac .cs-content .wpr-timeline-entry:nth-of-type(5) .wpr-main-line-icon {
      --cs-tl-icon: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path fill='black' d='M12 2.2c2.6 2.85 3.7 6.05 3.7 8.9 0 1.05-.18 2.1-.5 3.15l-1.3-1.05h-3.8l-1.3 1.05c-.32-1.05-.5-2.1-.5-3.15 0-2.85 1.1-6.05 3.7-8.9zM8.4 15.1l-2.1 2.1v2.2l2.7-1.1zM15.6 15.1l2.1 2.1v2.2l-2.7-1.1zM12 6.6a1.85 1.85 0 1 0 0 3.7 1.85 1.85 0 0 0 0-3.7z'/></svg>");
    }
    .cs-biopac .cs-content .wpr-timeline-entry.cs-tl-active .wpr-main-line-icon {
      border-color: #34a853; color: #34a853;
