      display: block; height: auto; max-height: 480px; width: auto; margin: 0;
    }
    .cs-willo .cs-content .wpr-ba-image-2 {
      position: absolute; inset: 0; overflow: hidden;
      clip-path: inset(0 calc(100% - var(--pos)) 0 0);
    }
    .cs-willo .cs-content .wpr-ba-image-2 img {
      position: absolute; inset: 0; width: 100%; height: 100%;
      max-height: none; object-fit: cover; margin: 0;
