  <!-- Drag handler for the willo Before/After comparison slider (scoped to
       .cs-willo; rebuilds the WP-Royal widget's drag since its JS isn't here). -->
  <script is:inline>
    (function () {
      document.querySelectorAll('.cs-willo .wpr-ba-image-container').forEach(function (c) {
        var dragging = false;
        function setPos(clientX) {
          var r = c.getBoundingClientRect();
          var p = Math.max(0, Math.min(1, (clientX - r.left) / r.width));
          c.style.setProperty('--pos', (p * 100) + '%');
        }
        c.addEventListener('pointerdown', function (e) {
          dragging = true; setPos(e.clientX);
          try { c.setPointerCapture(e.pointerId); } catch (_) {}
        });
        c.addEventListener('pointermove', function (e) { if (dragging) setPos(e.clientX); });
        c.addEventListener('pointerup', function () { dragging = false; });
        c.addEventListener('pointercancel', function () { dragging = false; });
      });

      // FDF interactive results circle: auto-rotate through the stats and let
      // the user click any circle. Dwell time depends on the value length —
      // short sentences 2s, longer ones 4s. Clicking resets the cycle.
      document.querySelectorAll('.cs-farmers-daughter-fibers .eael-interactive-circle').forEach(function (w) {
        var items = [].slice.call(w.querySelectorAll('.eael-circle-item'));
        if (!items.length) return;
        var timer;
        function show(idx) {
          items.forEach(function (it) {
            var b = it.querySelector('.eael-circle-btn');
            var c = it.querySelector('.eael-circle-btn-content');
            if (b) b.classList.remove('active');
            if (c) c.classList.remove('active');
          });
          var it = items[idx];
          var btn = it.querySelector('.eael-circle-btn');
          var content = it.querySelector('.eael-circle-btn-content');
          if (btn) btn.classList.add('active');
          if (content) content.classList.add('active');
          clearTimeout(timer);
          var len = content ? (content.innerText || '').trim().length : 0;
          var delay = len < 26 ? 2000 : 4000;
          timer = setTimeout(function () { show((idx + 1) % items.length); }, delay);
        }
        items.forEach(function (it, i) {
          var btn = it.querySelector('.eael-circle-btn');
          if (btn) btn.addEventListener('click', function () { show(i); });
        });
        var start = items.findIndex(function (it) {
          var b = it.querySelector('.eael-circle-btn');
          return b && b.classList.contains('active');
        });
        show(start < 0 ? 0 : start);
      });

      // BIOPAC implementation timeline: grow the green centre line as the
      // section scrolls through the viewport (the Royal widget's own JS isn't
      // present, so the fill is driven here).
      document.querySelectorAll('.cs-biopac .wpr-timeline-centered').forEach(function (tl) {
        var line = tl.querySelector('.wpr-middle-line');
        if (!line) return;
        var entries = [].slice.call(tl.querySelectorAll('.wpr-timeline-entry'));
        var ticking = false;
        function render() {
          ticking = false;
          var r = tl.getBoundingClientRect();
          var vh = window.innerHeight || document.documentElement.clientHeight;
          // The fill tip tracks the vertical centre of the screen: the green
          // line grows to exactly where the viewport middle crosses the
          // timeline, so its end stays mid-screen as the user scrolls past.
          var pct = ((vh * 0.5) - r.top) / r.height * 100;
          pct = Math.max(0, Math.min(100, pct));
          line.style.setProperty('--cs-tl-progress', pct + '%');
          // light up each node once the green fill reaches its centre.
          var fillPx = pct / 100 * line.offsetHeight;
          entries.forEach(function (en) {
            var center = en.offsetTop + en.offsetHeight / 2;
            en.classList.toggle('cs-tl-active', fillPx >= center);
          });
        }
        // rAF-throttle so the tip follows the scroll position with no lag.
        function update() {
          if (!ticking) { ticking = true; requestAnimationFrame(render); }
        }
        render();
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);
      });
    })();
  </script>

