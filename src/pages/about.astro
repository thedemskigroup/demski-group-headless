<script is:inline>
(function () {
  const slider = document.getElementById('about-blog-slider');
  const prev = document.getElementById('about-blog-prev');
  const next = document.getElementById('about-blog-next');
  if (!slider) return;
  function cw() {
    const c = slider.querySelector('.blog-post-card');
    return c ? c.offsetWidth + 20 : 420;
  }
  next && next.addEventListener('click', () => {
    const max = slider.scrollWidth - slider.clientWidth;
    slider.scrollLeft >= max - 10
      ? slider.scrollTo({ left: 0, behavior: 'smooth' })
      : slider.scrollBy({ left: cw(), behavior: 'smooth' });
  });
  prev && prev.addEventListener('click', () => {
    slider.scrollLeft <= 10
      ? slider.scrollTo({ left: slider.scrollWidth, behavior: 'smooth' })
      : slider.scrollBy({ left: -cw(), behavior: 'smooth' });
  });
})();
</script>

