---
import Layout from '../../layouts/Layout.astro';


const page = Number(Astro.url.searchParams.get('page') || 1);
const search = (Astro.url.searchParams.get('s') || '').trim();
const perPage = 10;

const searchParam = search ? `&search=${encodeURIComponent(search)}` : '';
const res = await fetch(`https://demskigroup.com/wp-json/wp/v2/posts?_embed&per_page=${perPage}&page=${page}${searchParam}`);
const posts = res.ok ? await res.json() : [];

const totalPages = Number(res.headers.get('X-WP-TotalPages') || 1);
const totalResults = Number(res.headers.get('X-WP-Total') || 0);

const catRes = await fetch('https://demskigroup.com/wp-json/wp/v2/categories?per_page=20');
const categories = await catRes.json();

const tagRes = await fetch('https://demskigroup.com/wp-json/wp/v2/tags?per_page=100&orderby=name&order=asc');
const tags = await tagRes.json();
---

<Layout title="Our Blog - Demski Group">

  <style slot="head">
    .hero { text-align: center; padding: 150px 20px; background: #faf9f5; }
    .hero h1 { font-size: 74px; font-weight: 800; color: #0A0000; line-height: 1.1; letter-spacing: 0.7px; margin: 0px 40px 20px; font-family: 'Outfit', sans-serif; }
    .breadcrumb { font-size: 18px; font-family: 'Outfit', sans-serif; color: #000; margin-top: 30px; }
    .breadcrumb a { color: #000; font-family: 'Outfit', sans-serif; font-size: 18px; text-decoration: none; }
    .top-search-wrap { width: 100%; margin: 40px 0 0; padding: 0 20px; display: flex; justify-content: center; box-sizing: border-box; }
    .top-search-form { width: 100%; max-width: 720px; margin: 0 auto; }
    .top-search-form input::placeholder { color: #888 !important; }
    .main-wrap { max-width: 1280px; margin: 40px auto 50px; padding: 0 60px; display: flex; flex-direction: row; gap: 40px; align-items: flex-start; }
    .posts-col { width: 65%; min-width: 0; flex: none; }
    .search-results-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; font-size: 18px; color: #0A0000; font-family: 'Outfit', sans-serif; }
    .search-results-header .clear-search { color: #003087; text-decoration: underline; font-weight: 600; }
    .search-results-header .clear-search:hover { color: #001f5c; }
    .no-results { padding: 40px 0; font-size: 18px; color: #555; font-family: 'Outfit', sans-serif; }
    .post-card { background: white; margin-bottom: 30px; overflow: hidden; border: 1px solid #ebebeb; border-radius: 12px; }
    .post-card img { width: 100%; height: 450px; object-fit: cover; display: block; max-width: 100%; }
    .post-info { padding: 20px 22px 22px; }
    .post-meta-row { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
    .post-date-txt { font-size: 16px; color: #000; font-family: 'Outfit', sans-serif; }
    .cat-tag { border: 1px solid #ccc; color: #000; padding: 2px 10px; border-radius: 20px; font-size: 16px; text-decoration: none; }
    .cat-tag:hover { background: #003087; color: white; border-color: #003087; }
    .post-card h2 { font-size: 30px; font-weight: 700; margin-bottom: 20px; line-height: 1.4; }
    .post-card h2 a { color: #0A0000; text-decoration: none; }
    .post-card h2 a:hover { color: #0A0000; }
    .post-excerpt { font-size: 18px; color: #555; line-height: 1.6; margin-bottom: 20px; }
    .read-more-link { display: inline-flex; align-items: center; gap: 7px; font-size: 18px; color: #003087; font-weight: 600; text-decoration: none; }
    .read-more-link:hover { color: #003087; }
    .pagination { display: flex; justify-content: center; align-items: center; gap: 18px; margin: 40px 0; }
    .pagination a, .pagination span { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 50%; font-size: 18px; font-weight: 600; text-decoration: none; color: #333; background: white; border: 1.5px solid #ccc; transition: all 0.2s; }
    .pagination .dots { border: none; background: none; color: #555; width: auto; font-size: 20px; }
    .pagination a:hover { background: #0A0000; color: white; border-color: #0A0000; }
    .pagination span.active { background: #0A0000; color: white; border-color: #0A0000; }
    .pagination-next { border: none !important; background: none !important; box-shadow: none !important; font-size: 22px !important; color: #333 !important; width: auto !important; height: auto !important; padding: 0 8px !important; }
    .sidebar-col { width: 32%; min-width: 0; flex: none; }
    .sb-box { background: #faf9f5; border: 1px solid #ebebeb; border-radius: 4px; padding: 20px; margin-bottom: 24px; height: auto; overflow: visible; }
    .sb-box h3 { font-size: 18px; font-weight: 700; color: #0A0000; display: inline-block; border-bottom: 2px solid #0A0000; padding-bottom: 8px; margin-bottom: 14px; }
    .search-form { display: flex; align-items: center; border: 1.5px solid #e0e0e0; border-radius: 50px; overflow: hidden; background: #fff; padding: 6px 18px; gap: 8px; }
    .search-form .search-icon { display: flex; align-items: center; flex-shrink: 0; }
    .search-form input { border: none; outline: none; padding: 8px 0; font-size: 16px; width: 100%; font-family: 'Outfit', sans-serif; background: transparent; color: #333; }
    .search-form input::placeholder { color: transparent; }
    .search-form button { display: none; }
    .recent-ul { list-style: none; padding: 0; margin: 0; }
    .recent-ul li { padding: 15px 0; border-bottom: 1px solid #f5f5f5; }
    .recent-ul li:last-child { border-bottom: none; }
    .recent-ul li a { font-size: 18px; color: #333; text-decoration: none; line-height: 1.5; }
    .recent-ul li a:hover { color: #003087; }
    .cat-ul { list-style: none; padding: 0; margin: 0; }
    .cat-ul li { display: flex; justify-content: space-between; padding: 15px 0; border-bottom: 1px solid #ccc; font-size: 18px; }
    .cat-ul li:last-child { border-bottom: none; }
    .cat-ul li a { color: #000; text-decoration: none; }
    .cat-ul li a:hover { color: #003087; }
    .cat-ul li span { color: #000; }
    .tech-cloud { display: flex; flex-wrap: wrap; gap: 10px; overflow: visible; }
    .tech-link { font-size: 17px; color: #333; background: #e2e2e2; padding: 9px 20px; border-radius: 20px; text-decoration: none; }
    .tech-link:hover { background: #000; color: white; }
    @media (max-width: 768px) {
      .hero { padding: 50px 20px; }
      .hero h1 { font-size: 36px; }
      .top-search-wrap { padding: 0 15px; margin-top: 25px; }
      .main-wrap { flex-direction: column !important; padding: 0 15px; margin: 25px auto 30px; gap: 20px; }
      .posts-col, .sidebar-col { width: 100% !important; }
      .post-card img { height: 200px; }
      .post-card h2 { font-size: 16px; }
    }
  </style>

  <div class="hero">
    <h1>Our blog</h1>
    <div class="breadcrumb">
      <a href="#">Home</a> &nbsp;&nbsp;&nbsp;›&nbsp;&nbsp;&nbsp; The Demski Group Blog
    </div>
  </div>

  <div class="top-search-wrap">
    <form class="search-form top-search-form" action="/blog" method="get">
      <span class="search-icon"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg></span>
      <input type="search" name="s" value={search} placeholder="Search the blog..." aria-label="Search" />
      <button type="submit" aria-label="Submit search"></button>
    </form>
  </div>

  <div class="main-wrap">
    <div class="posts-col">
      {search && (
        <div class="search-results-header">
          <span><strong>{totalResults}</strong> results for <strong>"{search}"</strong></span>
          <a href="/blog" class="clear-search">Clear search</a>
        </div>
      )}
      {search && posts.length === 0 && (
        <div class="no-results">No posts found matching "{search}".</div>
      )}
      {posts.map((post: any) => {
        const img = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
        const date = new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
        const cat = post._embedded?.['wp:term']?.[0]?.[0];
        const excerpt = post.excerpt?.rendered?.replace(/<[^>]+>/g, '').substring(0, 160) + '...';
        return (
          <div class="post-card">
            {img && <img src={img} alt={post.title.rendered} />}
            <div class="post-info">
              <div class="post-meta-row">
                <span class="post-date-txt"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:5px;margin-bottom:2px"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>{date}</span>
                {cat && <a href={`/category/${cat.slug}`} class="cat-tag">{cat.name}</a>}
              </div>
              <h2><a href={`/blog/${post.slug}`}>{post.title.rendered}</a></h2>
              <a class="read-more-link" href={`/blog/${post.slug}`}>
                Read More
                <svg width="14" height="12" viewBox="0 0 14 12" fill="none">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M0 6C0 5.77271 0.0902897 5.55473 0.251006 5.39402C0.411723 5.2333 0.629701 5.14301 0.856988 5.14301H10.7861L7.10615 1.46482C6.94523 1.3039 6.85482 1.08565 6.85482 0.858071C6.85482 0.630497 6.94523 0.412243 7.10615 0.251323C7.26707 0.0904038 7.48532 0 7.71289 0C7.94047 0 8.15872 0.0904038 8.31964 0.251323L13.4616 5.39325C13.5414 5.47286 13.6047 5.56743 13.6479 5.67154C13.6911 5.77566 13.7133 5.88728 13.7133 6C13.7133 6.11272 13.6911 6.22434 13.6479 6.32845C13.6047 6.43257 13.5414 6.52714 13.4616 6.60675L8.31964 11.7487C8.15872 11.9096 7.94047 12 7.71289 12C7.48532 12 7.26707 11.9096 7.10615 11.7487C6.94523 11.5878 6.85482 11.3695 6.85482 11.1419C6.85482 10.9144 6.94523 10.6961 7.10615 10.5352L10.7861 6.85699H0.856988C0.629701 6.85699 0.411723 6.7667 0.251006 6.60598C0.0902897 6.44527 0 6.22729 0 6Z" fill="#003087"/>
                </svg>
              </a>
            </div>
          </div>
        );
      })}

      {totalPages > 1 && (
        <div class="pagination">
          {page === 1 ? <span class="active">1</span> : <a href={`?page=1${searchParam}`}>1</a>}
          {totalPages >= 2 && (page === 2 ? <span class="active">2</span> : <a href={`?page=2${searchParam}`}>2</a>)}
          {totalPages >= 3 && (page === 3 ? <span class="active">3</span> : <a href={`?page=3${searchParam}`}>3</a>)}
          {totalPages > 4 && <span class="dots">...</span>}
          {totalPages > 3 && (page === totalPages ? <span class="active">{totalPages}</span> : <a href={`?page=${totalPages}${searchParam}`}>{totalPages}</a>)}
          {page < totalPages && <a href={`?page=${page + 1}${searchParam}`} class="pagination-next">›</a>}
        </div>
      )}
    </div>

    <div class="sidebar-col">
      <div class="sb-box">
        <h3>Recent Posts</h3>
        <ul class="recent-ul">
          {posts.slice(0, 5).map((post: any) => (
            <li><a href={`/blog/${post.slug}`}>{post.title.rendered}</a></li>
          ))}
        </ul>
      </div>
      <div class="sb-box">
        <h3>Blog Categories</h3>
        <ul class="cat-ul">
          {categories.filter((c: any) => c.count > 0).map((cat: any) => (
            <li>
              <a href={`/category/${cat.slug}`}>{cat.name}</a>
              <span>({cat.count})</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="sb-box">
        <h3>Technologies</h3>
        <div class="tech-cloud">
          {(() => {
            const excluded = ['.NET','Adobe','Airtable','Analytics','Apache','API','Apple','Azure','C++','Clutch','CSS','EJS','Elementor','Ext JS'];
            return tags.filter((t: any) => !excluded.includes(t.name)).map((tag: any) => (
              <a href={`/technology/${tag.slug}/`} class="tech-link">{tag.name}</a>
            ));
          })()}
        </div>
      </div>
    </div>
  </div>

</Layout>
