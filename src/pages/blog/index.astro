---
import Layout from '../../layouts/Layout.astro';


const page = Number(Astro.url.searchParams.get('page') || 1);
const perPage = 10;

const res = await fetch(`https://demskigroup.com/wp-json/wp/v2/posts?_embed&per_page=${perPage}&page=${page}`);
const posts = await res.json();

const totalRes = await fetch('https://demskigroup.com/wp-json/wp/v2/posts?per_page=1');
const totalPages = Number(totalRes.headers.get('X-WP-TotalPages') || 1);

const catRes = await fetch('https://demskigroup.com/wp-json/wp/v2/categories?per_page=20');
const categories = await catRes.json();

const tagRes = await fetch('https://demskigroup.com/wp-json/wp/v2/tags?per_page=50');
const tags = await tagRes.json();
---

<Layout title="Our Blog - Demski Group">

  <style slot="head">
    .hero { text-align: center; padding: 150px 20px; background: #faf9f5; }
    .hero h1 { font-size: 70px; font-weight: 800; color: #0A0000; line-height: 1.1; letter-spacing: 0.7px; }
    .breadcrumb { font-size: 18px; color: #888; margin-top: 30px; }
    .breadcrumb a { color: #888; text-decoration: none; }
    .main-wrap { max-width: 1400px; margin: 50px auto; padding: 0 30px; display: flex; flex-direction: row; gap: 40px; align-items: flex-start; }
    .posts-col { width: 65%; min-width: 0; flex: none; }
    .post-card { background: white; margin-bottom: 30px; overflow: hidden; border: 1px solid #ebebeb; border-radius: 4px; }
    .post-card img { width: 100%; height: 450px; object-fit: cover; display: block; max-width: 100%; }
    .post-info { padding: 20px 22px 22px; }
    .post-meta-row { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
    .post-date-txt { font-size: 16px; color: #888; }
    .cat-tag { border: 1px solid #ccc; color: #555; padding: 2px 10px; border-radius: 20px; font-size: 16px; text-decoration: none; }
    .cat-tag:hover { background: #003087; color: white; border-color: #003087; }
    .post-card h2 { font-size: 30px; font-weight: 700; margin-bottom: 20px; line-height: 1.4; }
    .post-card h2 a { color: #0A0000; text-decoration: none; }
    .post-card h2 a:hover { color: #003087; }
    .post-excerpt { font-size: 18px; color: #555; line-height: 1.6; margin-bottom: 20px; }
    .read-more-link { display: inline-flex; align-items: center; gap: 7px; font-size: 18px; color: #5B7486; font-weight: 600; text-decoration: none; }
    .read-more-link:hover { color: #003087; }
    .pagination { display: flex; justify-content: center; align-items: center; gap: 8px; margin: 40px 0; }
    .pagination a, .pagination span { display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 50%; font-size: 18px; font-weight: 600; text-decoration: none; color: #333; background: white; border: 1px solid #ddd; transition: all 0.2s; }
    .pagination a:hover { background: #003087; color: white; border-color: #003087; }
    .pagination span.active { background: #0A0000; color: white; border-color: #0A0000; }
    .sidebar-col { width: 32%; min-width: 0; flex: none; }
    .sb-box { background: white; border: 1px solid #ebebeb; border-radius: 4px; padding: 20px; margin-bottom: 24px; }
    .sb-box h3 { font-size: 18px; font-weight: 700; color: #0A0000; border-bottom: 2px solid #0A0000; padding-bottom: 8px; margin-bottom: 14px; }
    .search-form { display: flex; border: 1px solid #ddd; border-radius: 30px; overflow: hidden; }
    .search-form input { border: none; outline: none; padding: 9px 15px; font-size: 18px; width: 100%; font-family: 'Outfit', sans-serif; }
    .search-form button { border: none; background: white; padding: 9px 14px; cursor: pointer; color: #888; }
    .recent-ul { list-style: none; }
    .recent-ul li { padding: 15px 0; border-bottom: 1px solid #f5f5f5; }
    .recent-ul li:last-child { border-bottom: none; }
    .recent-ul li a { font-size: 18px; color: #333; text-decoration: none; line-height: 1.5; }
    .recent-ul li a:hover { color: #003087; }
    .cat-ul { list-style: none; }
    .cat-ul li { display: flex; justify-content: space-between; padding: 15px 0; border-bottom: 1px solid #f5f5f5; font-size: 18px; }
    .cat-ul li:last-child { border-bottom: none; }
    .cat-ul li a { color: #333; text-decoration: none; }
    .cat-ul li a:hover { color: #003087; }
    .cat-ul li span { color: #888; }
    .tech-cloud { display: flex; flex-wrap: wrap; gap: 16px; }
    .tech-link { font-size: 16px; color: #444; background: #f5f5f5; padding: 7px 10px; border-radius: 3px; text-decoration: none; }
    .tech-link:hover { background: #003087; color: white; }
    @media (max-width: 768px) {
      .hero { padding: 50px 20px; }
      .hero h1 { font-size: 36px; }
      .main-wrap { flex-direction: column !important; padding: 0 15px; margin: 30px auto; gap: 20px; }
      .posts-col, .sidebar-col { width: 100% !important; }
      .post-card img { height: 200px; }
      .post-card h2 { font-size: 16px; }
    }
  </style>

  <div class="hero">
    <h1>Our blog</h1>
    <div class="breadcrumb">
      <a href="#">Home</a> &nbsp;&nbsp;&nbsp;›&nbsp;&nbsp;&nbsp; The Demski Group Blog
    </div>
  </div>

  <div class="main-wrap">
    <div class="posts-col">
      {posts.map((post: any) => {
        const img = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
        const date = new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
        const cat = post._embedded?.['wp:term']?.[0]?.[0];
        const excerpt = post.excerpt?.rendered?.replace(/<[^>]+>/g, '').substring(0, 160) + '...';
        return (
          <div class="post-card">
            {img && <img src={img} alt={post.title.rendered} />}
            <div class="post-info">
              <div class="post-meta-row">
                <span class="post-date-txt">{date}</span>
                {cat && <a href={`/category/${cat.slug}`} class="cat-tag">{cat.name}</a>}
              </div>
              <h2><a href={`/blog/${post.slug}`}>{post.title.rendered}</a></h2>
              <p class="post-excerpt">{excerpt}</p>
              <a class="read-more-link" href={`/blog/${post.slug}`}>
                Read More
                <svg width="14" height="12" viewBox="0 0 14 12" fill="none">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M0 6C0 5.77271 0.0902897 5.55473 0.251006 5.39402C0.411723 5.2333 0.629701 5.14301 0.856988 5.14301H10.7861L7.10615 1.46482C6.94523 1.3039 6.85482 1.08565 6.85482 0.858071C6.85482 0.630497 6.94523 0.412243 7.10615 0.251323C7.26707 0.0904038 7.48532 0 7.71289 0C7.94047 0 8.15872 0.0904038 8.31964 0.251323L13.4616 5.39325C13.5414 5.47286 13.6047 5.56743 13.6479 5.67154C13.6911 5.77566 13.7133 5.88728 13.7133 6C13.7133 6.11272 13.6911 6.22434 13.6479 6.32845C13.6047 6.43257 13.5414 6.52714 13.4616 6.60675L8.31964 11.7487C8.15872 11.9096 7.94047 12 7.71289 12C7.48532 12 7.26707 11.9096 7.10615 11.7487C6.94523 11.5878 6.85482 11.3695 6.85482 11.1419C6.85482 10.9144 6.94523 10.6961 7.10615 10.5352L10.7861 6.85699H0.856988C0.629701 6.85699 0.411723 6.7667 0.251006 6.60598C0.0902897 6.44527 0 6.22729 0 6Z" fill="#5B7486"/>
                </svg>
              </a>
            </div>
          </div>
        );
      })}

      <div class="pagination">
        {page > 1 && <a href={`?page=${page - 1}`}>‹</a>}
        {page > 2 && <a href="?page=1">1</a>}
        {page > 3 && <span>...</span>}
        {page > 1 && <a href={`?page=${page - 1}`}>{page - 1}</a>}
        <span class="active">{page}</span>
        {page < totalPages && <a href={`?page=${page + 1}`}>{page + 1}</a>}
        {page < totalPages - 2 && <span>...</span>}
        {page < totalPages - 1 && <a href={`?page=${totalPages}`}>{totalPages}</a>}
        {page < totalPages && <a href={`?page=${page + 1}`}>›</a>}
      </div>
    </div>

    <div class="sidebar-col">
      <div class="sb-box">
        <form class="search-form" action="#" method="get">
          <input type="search" name="s" placeholder="Search..." />
          <button type="submit">🔍</button>
        </form>
      </div>
      <div class="sb-box">
        <h3>Recent Posts</h3>
        <ul class="recent-ul">
          {posts.slice(0, 5).map((post: any) => (
            <li><a href={`/blog/${post.slug}`}>{post.title.rendered}</a></li>
          ))}
        </ul>
      </div>
      <div class="sb-box">
        <h3>Blog Categories</h3>
        <ul class="cat-ul">
          {categories.filter((c: any) => c.count > 0).map((cat: any) => (
            <li>
              <a href={`/category/${cat.slug}`}>{cat.name}</a>
              <span>({cat.count})</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="sb-box">
        <h3>Technologies</h3>
        <div class="tech-cloud">
          {tags.map((tag: any) => (
            <a href={`/technology/${tag.slug}/`} class="tech-link">{tag.name}</a>
          ))}
        </div>
      </div>
    </div>
  </div>

</Layout>
