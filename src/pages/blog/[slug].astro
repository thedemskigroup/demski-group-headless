---
import Layout from '../../layouts/Layout.astro';

const { slug } = Astro.params;
const res = await fetch(`https://demskigroup.com/wp-json/wp/v2/posts?slug=${slug}&_embed`);
const posts = await res.json();
const post = posts[0];

const date = post ? new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : '';
const featuredImg = post?._embedded?.['wp:featuredmedia']?.[0]?.source_url;
const cat = post?._embedded?.['wp:term']?.[0]?.[0];
const author = post?._embedded?.['author']?.[0];
---

<Layout title={post ? `${post.title.rendered} - Demski Group` : 'Post Not Found'}>

  <style slot="head">
    .post-hero { text-align: center; padding: 80px 20px 60px; background: #faf9f5; }
    .post-hero .breadcrumb { font-size: 16px; color: #888; margin-bottom: 20px; }
    .post-hero .breadcrumb a { color: #888; text-decoration: none; }
    .post-hero .breadcrumb a:hover { color: #003087; }
    .post-hero h1 { font-size: 52px; font-weight: 800; color: #0A0000; line-height: 1.2; max-width: 900px; margin: 0 auto 24px; }
    .post-meta { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; font-size: 16px; color: #888; }
    .post-meta .cat-tag { border: 1px solid #ccc; color: #555; padding: 2px 12px; border-radius: 20px; text-decoration: none; font-size: 16px; }
    .post-meta .cat-tag:hover { background: #003087; color: white; border-color: #003087; }
    .featured-img-wrap { max-width: 1000px; margin: 0 auto 0; }
    .featured-img-wrap img { width: 100%; height: 500px; object-fit: cover; display: block; }
    .post-body-wrap { max-width: 800px; margin: 60px auto 80px; padding: 0 30px; }
    .post-content { font-size: 19px; line-height: 1.8; color: #333; }
    .post-content h2 { font-size: 32px; font-weight: 700; color: #0A0000; margin: 40px 0 16px; }
    .post-content h3 { font-size: 26px; font-weight: 700; color: #0A0000; margin: 32px 0 12px; }
    .post-content p { margin-bottom: 22px; }
    .post-content a { color: #003087; text-decoration: underline; }
    .post-content a:hover { color: #f09300; }
    .post-content ul, .post-content ol { padding-left: 24px; margin-bottom: 22px; }
    .post-content li { margin-bottom: 8px; }
    .post-content img { max-width: 100%; height: auto; border-radius: 4px; margin: 24px 0; }
    .post-content blockquote { border-left: 4px solid #003087; padding: 12px 20px; margin: 28px 0; background: #f5f8ff; font-style: italic; color: #444; }
    .back-link { display: inline-flex; align-items: center; gap: 8px; font-size: 17px; color: #5B7486; font-weight: 600; text-decoration: none; margin-bottom: 40px; }
    .back-link:hover { color: #003087; }
    .not-found { text-align: center; padding: 120px 20px; font-size: 22px; color: #888; }
    @media (max-width: 768px) {
      .post-hero h1 { font-size: 30px; }
      .post-hero { padding: 50px 20px 40px; }
      .post-body-wrap { padding: 0 20px; margin: 40px auto 60px; }
      .post-content { font-size: 17px; }
      .featured-img-wrap img { height: 250px; }
    }
  </style>

  {post ? (
    <>
      <div class="post-hero">
        <div class="breadcrumb">
          <a href="/">Home</a> &nbsp;›&nbsp; <a href="/">Blog</a> &nbsp;›&nbsp; {post.title.rendered}
        </div>
        <h1>{post.title.rendered}</h1>
        <div class="post-meta">
          <span>{date}</span>
          {cat && <a href={`/category/${cat.slug}`} class="cat-tag">{cat.name}</a>}
          {author && <span>By {author.name}</span>}
        </div>
      </div>

      {featuredImg && (
        <div class="featured-img-wrap">
          <img src={featuredImg} alt={post.title.rendered} />
        </div>
      )}

      <div class="post-body-wrap">
        <a class="back-link" href="/">
          <svg width="14" height="12" viewBox="0 0 14 12" fill="none" style="transform:rotate(180deg)">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M0 6C0 5.77271 0.0902897 5.55473 0.251006 5.39402C0.411723 5.2333 0.629701 5.14301 0.856988 5.14301H10.7861L7.10615 1.46482C6.94523 1.3039 6.85482 1.08565 6.85482 0.858071C6.85482 0.630497 6.94523 0.412243 7.10615 0.251323C7.26707 0.0904038 7.48532 0 7.71289 0C7.94047 0 8.15872 0.0904038 8.31964 0.251323L13.4616 5.39325C13.5414 5.47286 13.6047 5.56743 13.6479 5.67154C13.6911 5.77566 13.7133 5.88728 13.7133 6C13.7133 6.11272 13.6911 6.22434 13.6479 6.32845C13.6047 6.43257 13.5414 6.52714 13.4616 6.60675L8.31964 11.7487C8.15872 11.9096 7.94047 12 7.71289 12C7.48532 12 7.26707 11.9096 7.10615 11.7487C6.94523 11.5878 6.85482 11.3695 6.85482 11.1419C6.85482 10.9144 6.94523 10.6961 7.10615 10.5352L10.7861 6.85699H0.856988C0.629701 6.85699 0.411723 6.7667 0.251006 6.60598C0.0902897 6.44527 0 6.22729 0 6Z" fill="#5B7486"/>
          </svg>
          Back to Blog
        </a>
        <div class="post-content" set:html={post.content.rendered} />
      </div>
    </>
  ) : (
    <div class="not-found">Post not found. <a href="/" style="color:#003087">← Back to Blog</a></div>
  )}

</Layout>
