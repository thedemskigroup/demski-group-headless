}
.results-header p { font-size: 18px; color: #555; }
.results-header a { font-size: 18px; color: #0154b1; font-weight: 600; text-decoration: none; }
.results-header a:hover { text-decoration: underline; }
.results-list { display: flex; flex-direction: column; gap: 2px; }
.result-row {
