---
import Layout from '../../layouts/Layout.astro';

const platforms = [
  { id: 'mobile', label: 'Mobile App', icon: 'fa-mobile-screen-button' },
  { id: 'web', label: 'Web', icon: 'fa-globe' },
  { id: 'other', label: 'Other', icon: 'fa-shapes' },
  { id: 'not-sure', label: 'Not Sure', icon: 'fa-question' },
];

const projectTypes = [
  { id: 'game-dev', label: 'Game Development', icon: 'fa-gamepad' },
  { id: 'ai', label: 'Artificial Intelligence', icon: 'fa-brain' },
  { id: 'data-analytics', label: 'Data Analytics', icon: 'fa-chart-line' },
  { id: 'blockchain', label: 'Blockchain Development', icon: 'fa-cubes' },
  { id: 'ar-vr', label: 'Augmented or Virtual Reality', icon: 'fa-vr-cardboard' },
  { id: 'enterprise', label: 'Enterprise / Government', icon: 'fa-building' },
  { id: 'iot', label: 'Internet of Things', icon: 'fa-cloud' },
  { id: 'not-sure-2', label: 'Not Sure Yet', icon: 'fa-question' },
];

const techStack = [
  { id: 'aws', label: 'Amazon Web Service', icon: 'fa-aws', brand: true },
  { id: 'android', label: 'Android', icon: 'fa-android', brand: true },
  { id: 'angular', label: 'Angular', icon: 'fa-angular', brand: true },
  { id: 'apache', label: 'Apache', icon: 'fa-feather' },
  { id: 'aws-lambda', label: 'AWS Lambda', icon: 'fa-aws', brand: true },
  { id: 'azure', label: 'Azure', icon: 'fa-microsoft', brand: true },
  { id: 'cardano', label: 'Cardano', icon: 'fa-circle-nodes' },
  { id: 'cassandra', label: 'Cassandra', icon: 'fa-database' },
  { id: 'django', label: 'Django', icon: 'fa-leaf' },
  { id: 'ethereum', label: 'Ethereum', icon: 'fa-ethereum', brand: true },
  { id: 'expressjs', label: 'ExpressJs', icon: 'fa-node-js', brand: true },
  { id: 'firebase', label: 'Firebase', icon: 'fa-fire' },
  { id: 'go', label: 'Go / Golang', icon: 'fa-code' },
  { id: 'google-cloud', label: 'Google Cloud', icon: 'fa-cloud' },
  { id: 'graphql', label: 'GraphQL', icon: 'fa-diagram-project' },
  { id: 'ios', label: 'iOS', icon: 'fa-apple', brand: true },
  { id: 'linux', label: 'Linux', icon: 'fa-linux', brand: true },
  { id: 'mongodb', label: 'MongoDB', icon: 'fa-leaf' },
  { id: 'mysql', label: 'MySQL', icon: 'fa-database' },
  { id: 'node', label: 'Node', icon: 'fa-node-js', brand: true },
  { id: 'nosql', label: 'NoSQL', icon: 'fa-table-cells' },
  { id: 'not-sure-3', label: 'Not Sure Yet', icon: 'fa-question' },
  { id: 'php', label: 'Php', icon: 'fa-php', brand: true },
  { id: 'postgresql', label: 'PostgreSQL', icon: 'fa-database' },
  { id: 'python', label: 'Python', icon: 'fa-python', brand: true },
  { id: 'react', label: 'React', icon: 'fa-react', brand: true },
  { id: 'rails', label: 'Ruby On Rails', icon: 'fa-gem' },
  { id: 'solidity', label: 'Solidity', icon: 'fa-cube' },
  { id: 'sql', label: 'SQL', icon: 'fa-table-cells' },
