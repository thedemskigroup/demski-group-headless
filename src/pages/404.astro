---
import Layout from '../layouts/Layout.astro';
Astro.response.status = 404;
export const prerender = true;
---

<Layout title="Page Not Found - The Demski Group" description="The page you're looking for doesn't exist.">

  <section style="padding: 100px 20px; text-align: center;">
    <h1 style="font-size: 48px; margin-bottom: 16px;">404</h1>
    <p style="font-size: 20px; color: #555; margin-bottom: 32px;">Sorry, we couldn't find the page you're looking for.</p>
    <a href="/" class="btn-cta" style="display: inline-block; text-decoration: none;">Back to Home</a>
  </section>

</Layout>
