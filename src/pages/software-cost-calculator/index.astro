---
import Layout from '../../layouts/Layout.astro';

const wp = 'https://demskigrdev.wpenginepowered.com/wp-content/uploads';

const badges = [
  { src: `${wp}/2025/01/Clutch2.png`,       alt: 'Clutch Top Software Developers 2024' },
  { src: `${wp}/2025/01/ClutchAward3.png`,  alt: 'Clutch Top App Development Company 2023' },
  { src: `${wp}/2025/01/GoogleReviews.png`, alt: 'Google 5-Star Reviews' },
  { src: `${wp}/2025/01/Trophy-1.png`,      alt: 'Best Software Developer United States 2024' }
];

const steps = [
  { icon: 'fa-pen-to-square', title: 'Step 1', desc: 'Answer a few quick questions about your project\'s features, complexity, and timeline.' },
  { icon: 'fa-calculator',    title: 'Step 2', desc: 'Our experts generate a transparent cost estimate based on real industry data.' },
  { icon: 'fa-envelope',      title: 'Step 3', desc: 'We\'ll follow up to discuss your project in detail and refine the estimate if needed.' }
];

const whyBenefits = [
  'Fast & Easy – Get an estimate in 24 hours, not days.',
  'Transparent Pricing – No hidden fees or unexpected costs.',
  'Tailored to Your Needs – Estimates based on your specific project requirements.',
  'Expert Support – Our team is ready to answer questions and refine your estimate.'
];

const whoFor = [
  'Startups – Budget for your MVP with confidence.',
  'Businesses – Plan software investments with clarity.',
  'Agencies & Consultants – Get quick estimates for client projects.'
];

const faqs = [
  { q: 'How accurate is the estimate?',                 a: 'Our calculator provides a solid starting point based on real-world pricing and industry standards. While the estimate gives you a reliable cost range, final pricing may vary depending on your project\'s complexity, specific requirements, and any additional features you may need.' },
  { q: 'What happens after I get my estimate?',         a: 'Once you complete the form, we\'ll review your estimate and reach out to discuss your project in more detail. This allows us to refine the estimate, answer your questions, and explore the best approach to bring your idea to life.' },
  { q: 'Is the estimate really free?',                  a: 'Yes! Our cost calculator is completely free to use, and there\'s no obligation to move forward. We believe in transparency and helping you make informed decisions before committing to development.' },
  { q: 'Can I get a more detailed breakdown of costs?', a: 'Absolutely! After you receive your initial estimate, we\'ll work with you to refine the details and provide a more in-depth breakdown based on your specific needs and goals.' },
  { q: 'How long does it take to get my estimate?',     a: 'It only takes a minute to fill out the form! Simply answer a few questions about your project, and you\'ll receive an estimate within 24 hours.' },
  { q: 'What if I\'m not sure about my project details?', a: 'No problem! Just provide as much information as you can. If you\'re unsure about certain aspects, our team will be happy to guide you through the process and help define your requirements.' },
  { q: 'How do I get started?',                         a: 'Simply click the button below to use the calculator and get your free estimate. It\'s quick, easy, and the first step toward bringing your software project to life!' }
];
---

<Layout
  title="Get a Software Development Cost Estimate – Free & Instant"
  description="Quickly estimate your software development costs with our free cost calculator. Get an instant, transparent estimate in minutes—no guesswork, no obligations. Try it now!"
  pageClass="calc-page-class"
>
  <style slot="head">
    .calc-page-class {
      --blue: #005cb9;
      --orange: #f09300;
      --ink: #282828;
      font-family: 'Outfit', sans-serif;
      color: var(--ink);
    }

    /* nav overrides handled in global style block below */

    /* ══ HERO WRAP ══ */
    .calc-hero-wrap {
      background: linear-gradient(110deg, #1a3a6b 0%, #0d2247 40%, #050e1f 100%);
      position: relative;
    }

    .calc-hero {
      min-height: 70vh;
      display: flex;
      align-items: center;
      padding: 0 60px;
      position: relative;
      overflow: visible;
    }

    .calc-hero-inner {
      max-width: 1240px;
      margin: 0 auto;
      width: 100%;
      display: grid;
      grid-template-columns: 55% 45%;
      gap: 20px;
      align-items: flex-start;
      padding-top: 160px;
      padding-bottom: 40px;
    }

    .calc-hero-left {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding-top: 70px;
    }

    .calc-hero h1 {
      font-size: clamp(38px, 4.8vw, 64px);
      font-weight: 700;
      color: #fff;
      line-height: 1.12;
      margin: 0 0 20px;
      letter-spacing: -0.5px;
    }

    .calc-hero-sub {
      font-size: 26px;
      color: #ffffff;
      margin: 0 0 34px;
      line-height: 1.65;
      max-width: 460px;
    }
    .calc-hero-sub-line { white-space: nowrap; }

    .calc-hero-btn {
      display: inline-flex;
      align-items: center;
      gap: 16px;
      background: #fff;
      color: #0a0a0a;
      padding: 17px 28px 17px 32px;
      border-radius: 5px;
      font-size: 25px;
      font-weight: 500;
      text-decoration: none;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      transition: background 0.2s, color 0.2s, transform 0.2s;
      width: fit-content;
      justify-content: space-between;
      min-width: 340px;
    }
    .calc-hero-btn:hover { background: #f09300; color: #fff; transform: translateY(-2px); }
    .calc-hero-btn-arrow {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: inherit;
      position: relative;
      left: -3px;
    }
    .calc-hero-btn-arrow svg {
      width: 21px;
      height: 19px;
    }

    /* Calculator image — right side, overflows below dark section */
    .calc-hero-right {
      display: flex;
      align-items: flex-end;
      justify-content: center;
      position: relative;
      margin-top: -80px;
    }
    .calc-hero-img {
      width: 500px;
      height: auto;
      display: block;
      position: fixed;
      top: 120px;
      right: 80px;
      z-index: 2;
      filter: drop-shadow(0 30px 60px rgba(0,0,0,0.5));
      transition: opacity 0.2s;
    }
    .calc-hero-img.calc-hidden {
      opacity: 0;
      pointer-events: none;
    }

    /* ── BADGE ROW ── */
    .calc-badge-row {
      max-width: 1240px;
      margin: 0 auto;
      padding: 40px 320px 70px 135px;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 30px;
      position: relative;
      z-index: 100;
    }
    .calc-badge-section {
      position: relative;
      z-index: 100;
      background: #fff;
    }
    .calc-badge-card {
      background: transparent;
      border: none;
      outline: none;
      box-shadow: none;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 80px;
    }
    .calc-badge-card img {
      width: auto;
      max-width: 210px;
      max-height: 160px;
      height: auto;
      object-fit: contain;
      display: block;
      margin: 0 auto;
    }

    /* ── BRAND CARD ── */
    .brand-card-wrap {
      position: relative;
      z-index: 100;
      margin-top: -50px;
      padding: 0 40px 70px;
      background: transparent;
    }
    .brand-card-wrap::before {
      content: '';
      position: absolute;
      left: -10%;
      right: -10%;
      top: 25px;
      bottom: 0;
      background: #fff;
      border-radius: 50% 50% 0 0 / 100px 100px 0 0;
      z-index: -1;
    }
    .brand-card {
      max-width: 1364px;
      margin: -70px auto 0;
      background: #fff;
      border-radius: 14px;
      box-shadow: 0 6px 36px rgba(0,0,0,0.13);
      display: grid;
      grid-template-columns: 671px 1fr;
      overflow: hidden;
    }
    .brand-card-left {
      display: flex;
      align-items: center;
      padding: 32px 24px 32px 40px;
      border-right: 3px solid #222;
    }
    .brand-card-left p {
      font-size: 25px;
      font-weight: 600;
      color: #282828;
      margin: 0;
      line-height: 1.5;
    }
    .brand-card-right {
      display: flex;
      align-items: center;
      padding: 24px 32px;
    }
    .brand-card-right img {
      width: 100%;
      height: auto;
      max-height: 160px;
      object-fit: contain;
      object-position: left center;
      display: block;
    }

    /* ══ WHY CHALLENGING — 2-col with image ══ */
    .why-section-wrap, .calc-section {
      position: relative;
      z-index: 100;
      background: #fff;
    }
    .why-section-wrap {
      padding-bottom: 60px;
    }
    .why-section-wrap::after {
      content: '';
      position: absolute;
      left: 0;
      right: 0;
      bottom: -113px;
      height: 220px;
      background: #fff;
      clip-path: ellipse(100% 100% at 50% 0%);
      z-index: -1;
    }
    .calc-section-curve {
      padding-top: 60px;
      background: transparent;
    }
    .calc-section-curve::before {
      content: '';
      position: absolute;
      left: -10%;
      right: -10%;
      top: 30px;
      height: 220px;
      background: #fff;
      clip-path: ellipse(60% 100% at 50% 100%);
      z-index: -1;
    }
    .calc-section-curve::after {
      content: '';
      position: absolute;
      left: 0;
      right: 0;
      top: 140px;
      bottom: 0;
      background: #fff;
      z-index: -2;
    }
    .how-section {
      position: relative;
      z-index: 99;
    }
    .faq-section {
      position: relative;
      z-index: 100;
      background: #f7f7f7;
    }
    .final-cta {
      position: relative;
      z-index: 100;
    }
    .why-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 40px 100px;
      position: relative;
      z-index: 1;
    }
    .why-inner {
      display: flex;
      justify-content: center;
    }
    .why-text {
      max-width: 820px;
      text-align: center;
    }
    .why-text h2 {
      font-size: 48px;
      font-weight: 700;
      color: #282828;
      margin: 0 0 16px;
      line-height: 1.04;
      font-family: Outfit, sans-serif;
    }
    .why-text > p {
      font-size: 18px;
      line-height: 1.5;
      color: #000000;
      margin: 0 0 16px;
      font-family: Outfit, sans-serif;
    }
    .why-challenges {
      margin: 0 0 28px;
    }
    .why-challenges p {
      font-size: 18px;
      font-weight: 700;
      color: #000000;
      margin: 0 0 10px;
      font-family: Outfit, sans-serif;
    }
    .why-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: inline-block;
      text-align: left;
    }
    .why-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 18px;
      color: #000000;
      line-height: 1.6;
      margin-bottom: 8px;
      font-family: Outfit, sans-serif;
    }
    .why-list li::before {
      content: '';
      width: 14px; height: 14px; min-width: 14px;
      border: 2px solid #000000;
      border-radius: 50%;
      margin-top: 4px;
    }
    .why-solution h3 {
      font-size: 35px;
      font-weight: 700;
      color: #282828;
      margin: 0 0 10px;
      font-family: Outfit, sans-serif;
    }
    .why-solution p {
      font-size: 18px;
      line-height: 1.5;
      color: #000000;
      margin: 0 auto 16px;
      font-family: Outfit, sans-serif;
      max-width: 700px;
    }
    .why-cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #F09300;
      color: #FFFFFF;
      padding: 20px 25px;
      border-radius: 6px;
      font-size: 20px;
      font-weight: 600;
      font-family: Outfit, sans-serif;
      text-decoration: none;
      margin-top: 8px;
      border: 2px solid transparent;
      transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.2s;
    }
    .why-cta-btn:hover { background: #ffffff; color: #1b1c1d; border-color: #1b1c1d; transform: translateY(-2px); }

    /* ══ HOW IT WORKS ══ */
    .how-section {
      background: #eef0f2;
      margin-top: -260px;
      position: relative;
    }
    .how-section::after {
      content: '';
      position: absolute;
      left: 0;
      right: 0;
      bottom: -125px;
      height: 125px;
      background: #eef0f2;
      z-index: -2;
    }
    .how-section-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 420px 40px 80px;
    }
    .how-section h2 {
      color: #1b1c1d;
      font-size: clamp(50px, 2.1vw, 60px);
      font-weight: 700;
      text-align: center;
      margin: 0 0 35px;
    }
    .how-grid {
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      gap: 60px;
      align-items: stretch;
    }
    .steps-col { display: flex; flex-direction: column; gap: 12px; position: relative; top: 40px; }
    .step-card {
      background: #fff;
      border-radius: 20px;
      padding: 25px 20px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
      text-align: center;
    }
    .step-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      margin-bottom: 7px;
    }
    .step-icon-sm {
      font-size: 45px;
      color: #888888;
    }
    .step-card h3 {
      color: #1b1c1d;
      font-size: 26px;
      font-weight: 700;
      margin: 0;
    }
    .step-card p {
      color: #000000;
      font-size: 16px;
      line-height: 1.65;
      margin: 0;
    }
    .how-cta { margin-top: 8px; text-align: center; position: relative; top: 50px; }
    .how-cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: #f09300;
      color: #fff;
      padding: 17px 34px;
      border-radius: 7px;
      font-size: 18px;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.2s, transform 0.2s;
    }
    .how-cta-btn:hover { background: #d98200; transform: translateY(-2px); }

    .calc-screenshots {
      position: relative;
      background: #2b2f38;
      border-radius: 12px;
      padding: 20px;
      display: flex;
      flex-direction: column;
      height: 100%;
      overflow: hidden;
      max-width: 80%;
      margin-left: auto;
    }
    .calc-slide-stack {
      position: relative;
      flex: 1;
      min-height: 0;
    }
    .calc-screenshots .calc-slide {
      display: block;
      opacity: 0;
      transition: opacity 0.6s ease;
      pointer-events: none;
    }
    .calc-screenshots .calc-slide:first-child {
      position: relative;
    }
    .calc-screenshots .calc-slide:not(:first-child) {
      position: absolute;
      inset: 0;
    }
    .calc-screenshots .calc-slide.active-slide {
      opacity: 1;
      pointer-events: auto;
    }
    .calc-screenshots img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      border-radius: 8px;
      display: block;
    }
    .calc-screenshots-nav {
      display: flex;
      gap: 8px;
      margin-top: 18px;
      justify-content: center;
    }
    .calc-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: rgba(255,255,255,0.3);
      cursor: pointer; border: none;
      transition: background 0.2s; padding: 0;
    }
    .calc-dot.active { background: #fff; }

    /* ══ WHY USE / WHO IS THIS FOR — 2-col with image ══ */
    .calc-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 40px;
    }
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 70px;
      align-items: start;
    }
    .two-col-img img {
      width: 100%;
      height: 380px;
      object-fit: cover;
      border-radius: 14px;
      display: block;
    }
    .calc-section-curve .two-col-img {
      position: relative;
      left: -74%;
    }
    .calc-section-curve .two-col-img img {
      width: 168%;
      max-width: 168%;
      height: 547px;
      position: relative;
      top: 70px;
    }
    .two-col-img-right {
      position: relative;
      left: 4%;
    }
    .two-col-img-right img {
      width: 168%;
      max-width: 168%;
      height: 547px;
      position: relative;
      top: 70px;
    }
    .two-col-text {
      position: relative;
      top: 140px;
    }
    .two-col-text h2 {
      font-size: clamp(36px, 4.2vw, 56px);
      font-weight: 700;
      color: #1b1c1d;
      margin: 0 0 20px;
      line-height: 1.2;
    }
    .two-col-text p {
      font-size: 20px;
      line-height: 1.75;
      color: #000000;
      margin: 0 0 16px;
    }
    .two-col-list {
      list-style: none;
      margin: 0 0 20px;
      padding: 0;
    }
    .two-col-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 19px;
      line-height: 1.65;
      color: #000000;
      margin-bottom: 10px;
    }
    .two-col-list li::before {
      content: '';
      width: 8px; height: 8px; min-width: 8px;
      border: 1.5px solid #005cb9;
      border-radius: 50%;
      margin-top: 11px;
    }

    /* ══ FAQ ══ */
    .faq-section { background: #ffffff; }
    .faq-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 30px;
    }
    .faq-inner h2 {
      font-size: clamp(34px, 2.6vw, 46px);
      font-weight: 700;
      color: #1b1c1d;
      text-align: left;
      margin: 0 0 40px;
    }
    .faq-item { border-bottom: 1px solid #e2e2e2; }
    .faq-btn {
      width: 100%;
      display: flex;
      flex-direction: row-reverse;
      align-items: center;
      justify-content: flex-end;
      gap: 16px;
      padding: 18px 0;
      cursor: pointer;
      background: transparent;
      border: none;
      text-align: left;
      font-family: inherit;
    }
    .faq-q {
      font-size: 20px;
      font-weight: 600;
      color: #3a3a3a;
      line-height: 1.35;
    }
    .faq-icon {
      width: 26px; height: 26px; min-width: 26px;
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      font-weight: 600;
      color: #005cb9;
      transition: all 0.2s;
      line-height: 1;
    }
    .faq-icon::before { content: '+'; }
    .faq-item.active .faq-icon { color: #005cb9; }
    .faq-item.active .faq-icon::before { content: '−'; }
    .faq-panel { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
    .faq-item.active .faq-panel { max-height: 320px; }
    .faq-body {
      padding: 0 0 18px;
      font-size: 16px;
      line-height: 1.75;
      color: #000000;
    }

    /* ══ FINAL CTA ══ */
    .final-cta {
      background: linear-gradient(135deg, #001629 0%, #002b50 100%);
      padding: 80px 30px;
      text-align: center;
    }
    .final-cta p {
      font-size: clamp(20px, 2.4vw, 34px);
      font-weight: 700;
      color: #fff;
      margin: 0 0 28px;
      line-height: 1.3;
    }
    .final-cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: #f09300;
      color: #fff;
      padding: 19px 43px;
      border-radius: 7px;
      font-size: 19px;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.2s, color 0.2s, transform 0.2s;
    }
    .final-cta-btn:hover {
      background: #ffffff;
      color: #1b1c1d;
      transform: translateY(-2px);
    }
    .final-cta-arrow {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 30px;
      min-width: 30px;
      color: inherit;
    }

    /* ══ RESPONSIVE ══ */
    @media (max-width: 1366px) {
      .calc-section-curve .two-col-img,
      .two-col-img-right {
        left: 0;
        position: static;
      }
      .calc-section-curve .two-col-img img,
      .two-col-img-right img {
        width: 100%;
        max-width: 100%;
        height: 380px;
        position: static;
      }
    }
    @media (max-width: 1024px) {
      .calc-hero { padding: 0 30px; }
      .calc-hero-inner { grid-template-columns: 1fr; padding-top: 110px; padding-bottom: 30px; }
      .calc-hero-left, .calc-hero-right { min-width: 0; }
      .calc-hero h1 { width: auto; }
      .calc-hero-sub { max-width: 100%; }
      .calc-hero-sub-line { white-space: normal; }
      .calc-hero-btn { min-width: 0; width: 100%; box-sizing: border-box; }
      .calc-hero-right { margin-top: 30px; }
      .calc-hero-img {
        position: relative;
        top: auto;
        right: auto;
        width: 100%;
        max-width: 300px;
        margin: 0 auto;
      }
      .calc-hero-img.calc-hidden { opacity: 1; pointer-events: auto; }
      .calc-badge-row { display: grid; grid-template-columns: repeat(2, 1fr); padding: 20px 30px 50px; }
      .calc-badge-card img { max-width: 100%; }
      .how-grid { grid-template-columns: 1fr; gap: 40px; }
      .calc-screenshots { display: none; }
      .brand-card { grid-template-columns: 1fr; }
      .brand-card-left { border-right: none; border-bottom: 1px solid #eee; }
      .brand-card-wrap { margin-top: 20px; padding: 0 20px 50px; }
      .two-col { grid-template-columns: 1fr; gap: 30px; }
      .calc-section-curve .two-col-img,
      .two-col-img-right {
        left: 0;
        position: static;
      }
      .calc-section-curve .two-col-img img,
      .two-col-img-right img {
        width: 100%;
        max-width: 100%;
        height: 320px;
        position: static;
      }
    }
    @media (max-width: 768px) {
      .calc-hero { padding: 0 20px; }
      .calc-hero h1 { font-size: 30px; }
      .calc-hero-btn { min-width: unset; width: 100%; }
      .calc-badge-row { display: grid; grid-template-columns: repeat(2, 1fr); padding: 16px 16px 40px; }
      .why-section { padding: 50px 20px; }
      .calc-section { padding: 50px 20px; }
