  <script is:inline>
    (function () {
      /* Nav: transparent on hero, white when scrolled a little,
         then hidden entirely in favor of the compact #scrollStickyBar. */
      var wrap = document.querySelector('.site-header-wrap');
      var stickyBar = document.getElementById('scrollStickyBar');
      if (wrap) {
        var headerEl = wrap.querySelector('header');
        var topBar = wrap.querySelector('.top-bar');

        function setNavState(scrolled) {
          if (scrolled) {
            /* Scrolled past hero: full white header with blue top bar */
            wrap.style.background = '#ffffff';
            wrap.style.boxShadow = '0 2px 12px rgba(0,0,0,0.12)';
            if (headerEl) headerEl.style.cssText = 'background:#ffffff!important;box-shadow:none!important;';
            if (topBar) topBar.style.cssText = 'display:block!important;';
            wrap.querySelectorAll('header nav a, header button.nav-trigger').forEach(function(el) { if (!el.closest('.nav-dropdown-menu')) el.style.color = '#222222'; });
            var logo = wrap.querySelector('.logo img');
            if (logo) logo.src = '/Logo3-768x137.webp';
          } else {
            /* Hero: fully transparent — hide top bar, transparent header */
            wrap.style.background = 'transparent';
            wrap.style.boxShadow = 'none';
            if (headerEl) headerEl.style.cssText = 'background:transparent!important;box-shadow:none!important;';
            if (topBar) topBar.style.cssText = 'display:none!important;';
            wrap.querySelectorAll('header nav a, header button.nav-trigger').forEach(function(el) { if (!el.closest('.nav-dropdown-menu')) el.style.color = '#ffffff'; });
            var logo = wrap.querySelector('.logo img');
            if (logo) logo.src = '/Logo3-white-outline.png';
          }
        }

        /* Single threshold (matches Layout.astro's compact-bar threshold):
           below it, show the full transparent/white header. At/above it,
           hide the full header completely and let the global script's
           compact #scrollStickyBar (topbar + logo + Schedule button) be
           the only sticky bar — no overlap between the two. */
        var HEADER_SWAP_THRESHOLD = Math.max(80, (document.body.scrollHeight - window.innerHeight) * 0.04);
        var hidden = false;
        function update() {
          var sy = window.scrollY;
          if (!hidden && sy >= HEADER_SWAP_THRESHOLD) {
            hidden = true;
            wrap.style.opacity = '0';
            wrap.style.visibility = 'hidden';
            wrap.style.pointerEvents = 'none';
          } else if (hidden && sy < HEADER_SWAP_THRESHOLD - 24) {
            hidden = false;
          }
          if (!hidden) {
            wrap.style.opacity = '1';
            wrap.style.visibility = 'visible';
            wrap.style.pointerEvents = '';
            setNavState(sy > 0);
          }
        }
        window.addEventListener('scroll', update, { passive: true });
        update();
      }

      /* Hide fixed calculator when hero scrolls out of view */
      var calcImg = document.querySelector('.calc-hero-img');
      var heroWrap = document.querySelector('.calc-hero-wrap');
      if (calcImg && heroWrap) {
        function updateCalc() {
          var heroBottom = heroWrap.getBoundingClientRect().bottom;
          calcImg.classList.toggle('calc-hidden', heroBottom < 0);
        }
        window.addEventListener('scroll', updateCalc, { passive: true });
        updateCalc();
      }

      /* FAQ accordion */
      var faq = document.querySelector('[data-faq]');
      if (faq) {
        faq.querySelectorAll('.faq-item').forEach(function (item) {
          item.querySelector('.faq-btn').addEventListener('click', function () {
            var open = item.classList.contains('active');
            faq.querySelectorAll('.faq-item').forEach(function (i) {
              i.classList.remove('active');
              i.querySelector('.faq-btn').setAttribute('aria-expanded', 'false');
              i.querySelector('.faq-panel').style.maxHeight = '';
            });
            if (!open) {
              item.classList.add('active');
              item.querySelector('.faq-btn').setAttribute('aria-expanded', 'true');
              item.querySelector('.faq-panel').style.maxHeight = '320px';
            }
          });
        });
      }

      /* Screenshots slider */
      var slides = Array.from(document.querySelectorAll('[data-calc-slide]'));
      var dots   = Array.from(document.querySelectorAll('[data-calc-dot]'));
      if (!slides.length) return;
      var cur = 0;
      function showCalc(n) {
        slides[cur].classList.remove('active-slide'); dots[cur].classList.remove('active');
        cur = (n + slides.length) % slides.length;
        slides[cur].classList.add('active-slide'); dots[cur].classList.add('active');
      }
      dots.forEach(function (d) {
        d.addEventListener('click', function () { showCalc(parseInt(d.dataset.calcDot)); });
      });
      setInterval(function () { showCalc(cur + 1); }, 3000);
    })();
  </script>
