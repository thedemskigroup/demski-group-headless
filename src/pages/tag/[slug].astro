---
const { slug } = Astro.params;
const tagRes = await fetch(`https://demskigroup.com/wp-json/wp/v2/tags?slug=${slug}`);
const tags = await tagRes.json();
const tag = tags[0];

const postsRes = await fetch(`https://demskigroup.com/wp-json/wp/v2/posts?_embed&tags=${tag.id}&per_page=10`);
const posts = await postsRes.json();
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{tag.name} - Demski Group Blog</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Outfit', sans-serif; background: #f5f5f5; color: rgb(10,0,0); }
      .top-bar { background: #1a1a2e; color: white; font-size: 12px; padding: 6px 30px; text-align: center; }
      header { background: white; padding: 14px 40px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
      header .logo { font-size: 22px; font-weight: 800; color: #003087; }
      header nav { display: flex; align-items: center; gap: 20px; }
      header nav a { text-decoration: none; font-size: 14px; color: #333; font-weight: 500; }
      .btn-cta { background: #f97316; color: white !important; padding: 8px 18px; border-radius: 4px; font-size: 13px; font-weight: 700 !important; }
      .hero { text-align: center; padding: 50px 20px 30px; background: white; border-bottom: 1px solid #eee; }
      .hero h1 { font-size: 50px; font-weight: 800; color: rgb(10,0,0); }
      .breadcrumb { font-size: 14px; color: #888; margin-top: 10px; }
      .breadcrumb a { color: #888; text-decoration: none; }
      .container { max-width: 900px; margin: 36px auto; padding: 0 20px; }
      .post-card { background: white; margin-bottom: 24px; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 5px rgba(0,0,0,0.07); }
      .post-card img { width: 100%; height: 230px; object-fit: cover; display: block; }
      .post-card .info { padding: 18px 20px; }
      .post-card .meta { font-size: 12px; color: #aaa; margin-bottom: 8px; }
      .post-card h2 { font-size: 17px; font-weight: 700; margin-bottom: 10px; color: rgb(10,0,0); line-height: 1.4; }
      .post-card a.read-more { font-size: 13px; color: #003087; font-weight: 700; text-decoration: none; }
      .back { display: inline-block; margin-bottom: 20px; color: #003087; font-weight: 600; text-decoration: none; font-size: 14px; }
    </style>
  </head>
  <body>

    <div class="top-bar">Questions? We're Online — Give Us a Call: 406-412-5291</div>
    <header>
      <div class="logo">⬡ Demski Group</div>
      <nav>
        <a href="/">Blog</a>
        <a href="#" class="btn-cta">Request a Free Consultation</a>
      </nav>
    </header>

    <div class="hero">
      <h1>Tag: {tag.name}</h1>
      <div class="breadcrumb">
        <a href="/">Home</a> › <a href="/">Blog</a> › {tag.name}
      </div>
    </div>

    <div class="container">
      <a href="/" class="back">← Back to Blog</a>
      {posts.map((post: any) => {
        const img = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
        const date = new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
        return (
          <div class="post-card">
            {img && <img src={img} alt={post.title.rendered} />}
            <div class="info">
              <div class="meta">{date}</div>
              <h2>{post.title.rendered}</h2>
              <a class="read-more" href={`/blog/${post.slug}`}>Read More →</a>
            </div>
          </div>
        );
      })}
    </div>

  </body>
</html>