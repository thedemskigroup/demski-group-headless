---
import Layout from '../../layouts/Layout.astro';

const { slug } = Astro.params;

let tag = null;
try {
  const tagRes = await fetch(`https://demskigroup.com/wp-json/wp/v2/tags?slug=${slug}`, { signal: AbortSignal.timeout(6000) });
  if (tagRes.ok) {
    const tags = await tagRes.json();
    if (Array.isArray(tags)) tag = tags[0] ?? null;
  }
} catch (e) { tag = null; }

let posts = [];
try {
  if (tag?.id) {
    const postsRes = await fetch(`https://demskigroup.com/wp-json/wp/v2/posts?_embed&tags=${tag.id}&per_page=10`, { signal: AbortSignal.timeout(6000) });
    if (postsRes.ok) {
      const data = await postsRes.json();
      if (Array.isArray(data)) posts = data;
    }
  }
} catch (e) { posts = []; }

Astro.response.headers.set('Cache-Control', 'public, s-maxage=120, stale-while-revalidate=3600');
---

<Layout
  title={`${tag?.name ?? slug} | The Demski Group Blog`}
  description={`Browse all articles tagged "${tag?.name ?? slug}" on The Demski Group blog. Insights on custom software, mobile development, and technology trends.`}
>
  <style slot="head">
    .tag-hero { text-align: center; padding: 50px 20px 30px; background: white; border-bottom: 1px solid #eee; }
    .tag-hero h1 { font-size: 50px; font-weight: 800; color: rgb(10,0,0); }
    .breadcrumb { font-size: 14px; color: #888; margin-top: 10px; }
    .breadcrumb a { color: #888; text-decoration: none; }
    .tag-container { max-width: 900px; margin: 36px auto; padding: 0 20px; }
    .post-card { background: white; margin-bottom: 24px; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 5px rgba(0,0,0,0.07); }
    .post-card img { width: 100%; height: 230px; object-fit: cover; display: block; }
    .post-card .info { padding: 18px 20px; }
    .post-card .meta { font-size: 12px; color: #aaa; margin-bottom: 8px; }
    .no-posts { text-align: center; padding: 50px 20px; color: #888; font-size: 16px; }
    .post-card h2 { font-size: 17px; font-weight: 700; margin-bottom: 10px; color: rgb(10,0,0); line-height: 1.4; }
    .post-card a.read-more { font-size: 13px; color: #003087; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
    .back { display: inline-block; margin-bottom: 20px; color: #003087; font-weight: 600; text-decoration: none; font-size: 14px; }
  </style>

  <div class="tag-hero">
    <h1>Tag: {tag?.name ?? slug}</h1>
    <div class="breadcrumb">
      <a href="/">Home</a> › <a href="/blog">Blog</a> › {tag?.name ?? slug}
    </div>
  </div>

  <div class="tag-container">
    <a href="/blog" class="back">← Back to Blog</a>
    {posts.length === 0 && (
      <div class="no-posts">No posts found for this tag yet. Check back soon.</div>
    )}
    {posts.map((post: any) => {
      const img = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
      const date = new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
      return (
        <div class="post-card">
          {img && <img src={img} alt={post.title.rendered} />}
          <div class="info">
            <div class="meta">{date}</div>
            <h2>{post.title.rendered}</h2>
            <a class="read-more" href={`/blog/${post.slug}`}>Read More <span class="btn-arrow-icon"></span></a>
          </div>
        </div>
      );
    })}
  </div>
</Layout>
