<script is:inline>
(function () {
  const stepsContainer = document.getElementById('web-process-steps');
  const lineFill = document.getElementById('web-process-line-fill');
  const steps = Array.from(document.querySelectorAll('#web-process-steps .hp-process-step'));
  if (!stepsContainer || !lineFill || !steps.length) return;

  function update() {
    const containerRect = stepsContainer.getBoundingClientRect();
    const containerTop = containerRect.top;
    const containerHeight = containerRect.height;
    const windowH = window.innerHeight;

    const scrolled = Math.max(0, Math.min(1,
      (windowH * 0.6 - containerTop) / containerHeight
    ));

    lineFill.style.height = (scrolled * 100) + '%';

    steps.forEach((step) => {
      const rect = step.getBoundingClientRect();
      const mid = rect.top + rect.height / 2;
      if (mid < windowH * 0.65) {
        step.classList.add('active');
      } else {
        step.classList.remove('active');
      }
    });
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
})();
</script>

