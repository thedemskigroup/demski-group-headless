/* Testimonial carousel */
(function () {
  var slides = Array.from(document.querySelectorAll('#mlTcCarousel [data-tc-slide]'));
  var fracEl = document.getElementById('mlTcFraction');
  if (!slides.length) return;
  var cur = 0;
  function showSlide(n) {
    slides[cur].classList.remove('active');
    cur = (n + slides.length) % slides.length;
    slides[cur].classList.add('active');
    if (fracEl) fracEl.textContent = (cur + 1) + ' / ' + slides.length;
  }
  setInterval(function () { showSlide(cur + 1); }, 4000);
})();
</script>

