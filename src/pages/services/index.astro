---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Software Services - The Demski Group">
<style is:global>
/* ══ GLOBAL FONT — Outfit for ALL headings (consistent with other pages) ══ */
h1, h2, h3, h4, h5, h6 {
  font-family: 'Outfit', sans-serif !important;
}

/* ══ HERO ══ */
.svc-hero {
  background: #fff;
  padding: 80px 60px;
  min-height: 560px;
  display: flex;
  align-items: center;
}
.svc-hero-inner {
  max-width: 1280px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  width: 100%;
}
.svc-eyebrow {
  font-family: 'Outfit', sans-serif;
  font-size: 11px; font-weight: 700;
  letter-spacing: 3px; text-transform: uppercase;
  color: #888; margin-bottom: 16px;
}
.svc-hero h1 {
  font-family: 'Outfit', sans-serif !important;
  font-size: 52px; font-weight: 700;
  color: #0A0000; line-height: 1.1;
  margin-bottom: 18px;
}
.svc-hero-desc {
  font-size: 16px; color: #555;
  line-height: 1.75; margin-bottom: 30px;
  max-width: 440px;
}
.svc-hero-actions { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
.btn-orange {
  display: inline-flex; align-items: center; justify-content: center;
  background: #F09300; color: #fff;
  font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 600;
  padding: 13px 28px; border-radius: 8px;
  text-decoration: none; transition: background 0.3s; white-space: nowrap;
}
.btn-orange:hover { background: #d98200; }
.svc-hero-right {
  border-radius: 20px; overflow: hidden;
  height: 420px; position: relative;
  background: #0a1628;
}
.svc-hero-right img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
.svc-hero-right::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(10,22,40,0.4) 0%, transparent 60%);
}

/* ══ BRANDS BAR ══ */
.svc-brands { background: #f7f7f7; padding: 0 60px 60px; }
.svc-brands-wrap {
  max-width: 1200px; margin: 0 auto;
  background: #2a2a2a; border-radius: 16px;
  display: flex; overflow: hidden;
}
.svc-brands-label {
  font-family: 'Outfit', sans-serif; font-size: 16px;
  color: #fff; min-width: 230px; padding: 32px 30px;
  border-right: 1px solid #444; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  text-align: center; line-height: 1.65;
}
.svc-brands-logos { flex: 1; padding: 20px 44px; display: flex; align-items: center; }
.svc-brands-logos img { width: 100%; max-height: 100px; object-fit: contain; }

/* ══ SERVICES GRID ══ */
.svc-services { background: #fff; padding: 90px 60px; }
.svc-services-inner { max-width: 1200px; margin: 0 auto; }
.svc-section-title {
  font-family: 'Outfit', sans-serif !important;
  font-size: 40px; font-weight: 700;
  color: #0A0000; margin-bottom: 50px; line-height: 1.2;
}
.svc-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.svc-card {
  border: 1px solid #e8e8e8; border-radius: 16px;
  padding: 28px 24px 22px; background: #fff;
  transition: box-shadow 0.25s, transform 0.25s;
  display: flex; flex-direction: column;
}
.svc-card:hover { box-shadow: 0 6px 28px rgba(0,0,0,0.09); transform: translateY(-2px); }
.svc-card-icon {
  width: 44px; height: 44px;
  background: #f0f4ff; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; color: #0154b1; margin-bottom: 16px; flex-shrink: 0;
}
.svc-card-name {
  font-family: 'Outfit', sans-serif !important;
  font-size: 17px; font-weight: 700;
  color: #0A0000; margin-bottom: 10px;
}
.svc-card-desc {
  font-size: 14px; color: #666;
  line-height: 1.7; flex: 1; margin-bottom: 18px;
}
.svc-card-link {
  font-family: 'Outfit', sans-serif;
  font-size: 13px; font-weight: 700;
  color: #0154b1; text-decoration: none;
  display: flex; align-items: center; gap: 6px;
}
.svc-card-link:hover { text-decoration: underline; }

/* Wide card (E-commerce) */
.svc-card.wide { grid-column: span 3; flex-direction: row; align-items: flex-start; gap: 24px; }
.svc-card.wide .svc-card-body { flex: 1; }

/* ══ TECH STACK ══ */
.svc-tech { background: #f0f0f0; padding: 80px 60px; overflow: hidden; }
.svc-tech-inner { max-width: 1200px; margin: 0 auto; }
.svc-tech-header {
  display: flex; justify-content: space-between;
  align-items: flex-end; margin-bottom: 50px;
}
.svc-tech-header h2 {
  font-family: 'Outfit', sans-serif !important;
  font-size: 40px; font-weight: 700;
  color: #0A0000; line-height: 1.2;
  max-width: 440px;
}
.btn-outline {
  display: inline-flex; align-items: center; gap: 8px;
  border: 1.5px solid #1a1a1a; color: #0A0000;
  font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 600;
  padding: 10px 20px; border-radius: 50px;
  text-decoration: none; transition: all 0.25s; white-space: nowrap;
}
.btn-outline:hover { background: #0A0000; color: #fff; }
/* Marquee */
.tech-marquee-wrap { overflow: hidden; }
.tech-marquee {
  display: flex; gap: 20px;
  animation: marquee-left 20s linear infinite;
  width: max-content;
}
.tech-marquee:hover { animation-play-state: paused; }
@keyframes marquee-left {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.tech-item {
  background: #fff; border-radius: 14px;
  padding: 20px 32px;
  display: flex; align-items: center; justify-content: center;
  min-width: 120px; height: 80px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  flex-shrink: 0;
}
.tech-item img {
  max-height: 44px; max-width: 80px;
  object-fit: contain; display: block;
}

/* ══ PROJECTS SECTION ══ */
.svc-projects { background: #fff; padding: 80px 60px; }
.svc-projects-inner { max-width: 1200px; margin: 0 auto; }
.svc-projects-header {
  display: flex; justify-content: space-between;
  align-items: flex-start; margin-bottom: 40px;
}
.svc-projects-header h2 {
  font-family: 'Outfit', sans-serif !important;
  font-size: 40px; font-weight: 700;
  color: #0A0000; line-height: 1.2;
}
.btn-outline-sm {
  display: inline-flex; align-items: center; gap: 8px;
  border: 1.5px solid #1a1a1a; color: #0A0000;
  font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 600;
  padding: 9px 18px; border-radius: 50px;
  text-decoration: none; transition: all 0.25s; white-space: nowrap; margin-top: 8px;
}
.btn-outline-sm .ac {
  width: 20px; height: 20px;
  background: #0A0000; color: #fff;
  border-radius: 50%; display: inline-flex;
  align-items: center; justify-content: center;
  font-size: 11px; transition: all 0.25s;
}
.btn-outline-sm:hover { background: #0A0000; color: #fff; }
.btn-outline-sm:hover .ac { background: #fff; color: #0A0000; }

/* Top wrap: BIOPAC + 4 */
.proj-top-wrap {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 16px; margin-bottom: 16px;
}
.biopac-card {
  background: #0a1628; border-radius: 16px; padding: 32px;
  display: flex; flex-direction: column; justify-content: space-between;
  min-height: 300px; text-decoration: none;
  transition: transform 0.25s, box-shadow 0.25s;
  grid-row: span 2;
}
.biopac-card:hover { transform: translateY(-3px); box-shadow: 0 12px 36px rgba(0,0,0,0.3); }
.biopac-logo img {
  height: 60px; width: auto; object-fit: contain;
  filter: brightness(0) invert(1); display: block; margin-bottom: 16px;
}
.biopac-name { font-family:'Outfit',sans-serif; font-size:22px; font-weight:700; color:#fff; }
.biopac-desc { font-size:14px; color:rgba(255,255,255,0.8); line-height:1.7; margin:12px 0; }
.biopac-link { font-family:'Outfit',sans-serif; font-size:13px; font-weight:700; color:#fff; }
.proj-four { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.client-card {
  background: #fff; border: 1px solid #ebebeb; border-radius: 14px;
  padding: 24px 18px 18px; display: flex; flex-direction: column;
  justify-content: space-between; align-items: center;
  text-decoration: none; transition: box-shadow 0.25s, transform 0.25s;
  min-height: 140px;
}
.client-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); transform: translateY(-2px); }
.client-card-img {
  flex: 1; display: flex; align-items: center;
  justify-content: center; width: 100%; margin-bottom: 14px;
}
.client-card img { max-height: 56px; max-width: 150px; object-fit: contain; }
.client-card-name { font-family:'Outfit',sans-serif; font-size:12px; font-weight:600; color:#333; text-align:center; }
.client-card-link { font-family:'Outfit',sans-serif; font-size:12px; font-weight:700; color:#0154b1; white-space:nowrap; }
.proj-main-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }

/* Skeletons */
.skeleton {
  border-radius: 16px;
  background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* ══ EXCELLENCE ══ */
.svc-excellence {
  background: #0A0000; padding: 80px 60px;
}
.svc-excellence-inner {
  max-width: 1200px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: center;
}
.svc-excellence-left h2 {
  font-family: 'Outfit', sans-serif !important;
  font-size: 40px; font-weight: 700;
  color: #fff; line-height: 1.2; margin-bottom: 16px;
}
.svc-excellence-left p { font-size: 15px; color: rgba(255,255,255,0.7); line-height: 1.75; margin-bottom: 28px; }
.btn-white {
  display: inline-flex; align-items: center; justify-content: center;
  background: #fff; color: #0A0000;
  font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 700;
  padding: 12px 26px; border-radius: 8px;
  text-decoration: none; transition: all 0.25s;
}
.btn-white:hover { background: #f0f0f0; }
.excellence-ratings {
  display: flex; gap: 40px; margin-top: 36px;
}
.rating-item { text-align: center; }
.rating-label { font-family:'Outfit',sans-serif; font-size:13px; color:rgba(255,255,255,0.6); margin-bottom:6px; }
.rating-score { font-family:'Outfit',sans-serif; font-size:22px; font-weight:700; color:#fff; }
.stars { color: #F09300; font-size: 18px; letter-spacing: 2px; }
.svc-excellence-right {
  display: flex; flex-wrap: wrap;
  gap: 20px; align-items: center; justify-content: center;
}
.svc-excellence-right img { height: 80px; width: auto; object-fit: contain; }

/* ══ POS INTEGRATION CTA ══ */
.svc-pos {
  background: #f0f0f0; padding: 60px;
}
.svc-pos-inner {
  max-width: 1200px; margin: 0 auto;
  border-radius: 20px; overflow: hidden;
  display: grid; grid-template-columns: 1fr 1fr;
}
.svc-pos-img {
  position: relative; min-height: 260px;
}
.svc-pos-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.svc-pos-content {
  background: #fff; padding: 48px 44px;
  display: flex; flex-direction: column; justify-content: center;
}
.svc-pos-content p {
  font-size: 18px; color: #333; line-height: 1.7; margin-bottom: 8px;
}
.svc-pos-content small { font-size: 14px; color: #888; display: block; margin-bottom: 24px; }

/* ══ METHODOLOGIES ══ */
.svc-methods { background: #fff; padding: 80px 60px; }
.svc-methods-inner { max-width: 1200px; margin: 0 auto; }
.svc-methods-header {
  display: flex; justify-content: space-between;
  align-items: flex-end; margin-bottom: 40px;
}
.svc-methods-header h2 {
  font-family: 'Outfit', sans-serif !important;
  font-size: 40px; font-weight: 700; color: #0A0000;
}
.svc-methods-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
.method-card {
  border-radius: 18px; overflow: hidden;
  position: relative; min-height: 300px;
  text-decoration: none; display: block;
}
.method-card-bg {
  position: absolute; inset: 0;
  background-size: cover; background-position: center;
  transition: transform 0.4s;
}
.method-card:hover .method-card-bg { transform: scale(1.04); }
.method-card::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.7) 100%);
  z-index: 1;
}
.method-card-content {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 28px 26px; z-index: 2;
  display: flex; justify-content: space-between; align-items: flex-end;
}
.method-card-name {
  font-family: 'Outfit', sans-serif !important;
  font-size: 26px; font-weight: 700; color: #fff;
}
.method-card-desc { font-size: 13px; color: rgba(255,255,255,0.8); line-height: 1.6; margin-top: 8px; }
.method-card-left { flex: 1; }
.method-arrow {
  width: 40px; height: 40px; border-radius: 50%;
  background: rgba(255,255,255,0.2); border: 1.5px solid rgba(255,255,255,0.4);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 18px; flex-shrink: 0; margin-left: 16px;
  transition: background 0.25s;
}
.method-card:hover .method-arrow { background: rgba(255,255,255,0.35); }

/* ══ CONTACT + TESTIMONIAL ══ */
.svc-contact { background: #0A0000; padding: 80px 60px; }
.svc-contact-inner {
  max-width: 1200px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 60px;
}
.svc-contact-left h2 {
  font-family: 'Outfit', sans-serif !important;
  font-size: 40px; font-weight: 700;
  color: #fff; margin-bottom: 32px;
}
.contact-form { display: flex; flex-direction: column; gap: 16px; }
.contact-form input,
.contact-form textarea {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 10px;
  padding: 14px 18px;
  font-family: 'Outfit', sans-serif;
  font-size: 15px; color: #fff;
  outline: none; transition: border 0.25s;
  width: 100%;
}
.contact-form input::placeholder,
.contact-form textarea::placeholder { color: rgba(255,255,255,0.4); }
.contact-form input:focus,
.contact-form textarea:focus { border-color: rgba(255,255,255,0.4); }
.contact-form textarea { min-height: 120px; resize: vertical; }
.contact-form .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.btn-submit {
  display: inline-flex; align-items: center; justify-content: center;
  background: #F09300; color: #fff;
  font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 600;
  padding: 14px 32px; border-radius: 8px; border: none;
  cursor: pointer; transition: background 0.3s; align-self: flex-start;
}
.btn-submit:hover { background: #d98200; }
.svc-testimonial-col {
  display: flex; flex-direction: column; gap: 20px;
}
.testimonial-label {
  font-family: 'Outfit', sans-serif;
  font-size: 11px; font-weight: 700; letter-spacing: 3px;
  text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 4px;
}
.testimonial-card {
  background: #fff; border-radius: 18px; padding: 32px 28px;
}
.testimonial-quote {
  font-size: 14.5px; color: #333; line-height: 1.8; margin-bottom: 24px;
}
.testimonial-author { display: flex; align-items: center; gap: 14px; }
.testimonial-author-info {}
.testimonial-author-name {
  font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 700; color: #0A0000;
}
.testimonial-author-role { font-size: 13px; color: #888; }
.testimonial-read {
  font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 700;
  color: #0154b1; text-decoration: none; display: block; margin-top: 16px;
}
.testimonial-read:hover { text-decoration: underline; }

/* ══ RESPONSIVE ══ */
@media (max-width: 1024px) {
  .svc-grid { grid-template-columns: repeat(2,1fr); }
  .svc-card.wide { grid-column: span 2; }
  .proj-main-grid { grid-template-columns: repeat(3,1fr); }
}
@media (max-width: 900px) {
  .svc-hero-inner { grid-template-columns: 1fr; }
  .svc-hero-right { height: 260px; }
  .svc-brands-wrap { flex-direction: column; }
  .svc-brands-label { border-right: none; border-bottom: 1px solid #444; }
  .svc-excellence-inner { grid-template-columns: 1fr; gap: 40px; }
  .svc-pos-inner { grid-template-columns: 1fr; }
  .svc-contact-inner { grid-template-columns: 1fr; }
  .svc-tech-header { flex-direction: column; align-items: flex-start; gap: 20px; }
  .svc-projects-header { flex-direction: column; gap: 16px; }
  .proj-top-wrap { grid-template-columns: 1fr; }
  .biopac-card { grid-row: span 1; }
  .svc-methods-header { flex-direction: column; gap: 16px; align-items: flex-start; }
  .svc-methods-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  .svc-hero, .svc-brands, .svc-services, .svc-tech, .svc-projects,
  .svc-excellence, .svc-pos, .svc-methods, .svc-contact { padding-left: 24px; padding-right: 24px; }
  .svc-hero h1 { font-size: 36px; }
  .svc-grid { grid-template-columns: 1fr; }
  .svc-card.wide { grid-column: span 1; flex-direction: column; }
  .proj-main-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
  .proj-four { grid-template-columns: 1fr 1fr; }
  .contact-form .form-row { grid-template-columns: 1fr; }
  .excellence-ratings { flex-direction: column; gap: 20px; }
}
</style>

<!-- ══ HERO ══ -->
<section class="svc-hero">
  <div class="svc-hero-inner">
    <div class="svc-hero-left">
      <div class="svc-eyebrow">Software Services</div>
      <h1>Empowering Businesses with Custom Software</h1>
      <p class="svc-hero-desc">Talk to our experts today about your project. We love a challenge.</p>
      <div class="svc-hero-actions">
        <a href="/contact-us/" class="btn-orange">Schedule a Consultation</a>
      </div>
    </div>
    <div class="svc-hero-right">
      <img
        src="https://demskigroup.com/wp-content/uploads/2024/06/programmers-developing-software-in-team-2023-11-27-05-25-31-utc-1024x683.jpg"
        alt="Software development team"
      />
    </div>
  </div>
</section>

<!-- ══ BRANDS BAR ══ -->
<div class="svc-brands">
  <div class="svc-brands-wrap">
    <div class="svc-brands-label">Companies that trust<br/>our experienced team.</div>
    <div class="svc-brands-logos">
      <img src="https://demskigroup.com/wp-content/uploads/2024/07/brandlogos.png" alt="companies we work with" />
    </div>
  </div>
</div>

<!-- ══ SERVICES GRID ══ -->
<section class="svc-services">
  <div class="svc-services-inner">
    <h2 class="svc-section-title">Our Software Development Services</h2>
    <div class="svc-grid">

      <a class="svc-card" href="/services/custom-development/">
        <div class="svc-card-icon"><i class="fa-solid fa-code"></i></div>
        <div class="svc-card-name">Custom Software Development</div>
        <p class="svc-card-desc">We craft tailored software solutions that align with your unique business needs, driving efficiency and innovation.</p>
        <span class="svc-card-link">Read more →</span>
      </a>

      <a class="svc-card" href="/services/machine-learning/">
        <div class="svc-card-icon"><i class="fa-solid fa-brain"></i></div>
        <div class="svc-card-name">Machine Learning</div>
        <p class="svc-card-desc">Harness the power of machine learning to unlock insights, automate processes, and elevate decision-making.</p>
        <span class="svc-card-link">Read more →</span>
      </a>

      <a class="svc-card" href="/services/web/">
        <div class="svc-card-icon"><i class="fa-solid fa-globe"></i></div>
        <div class="svc-card-name">Web Development</div>
        <p class="svc-card-desc">Our web development services deliver responsive, high-performance websites that captivate and engage users.</p>
        <span class="svc-card-link">Read more →</span>
      </a>

      <a class="svc-card" href="/services/app-development/">
        <div class="svc-card-icon"><i class="fa-solid fa-mobile-screen"></i></div>
        <div class="svc-card-name">Mobile App Development</div>
        <p class="svc-card-desc">We design and develop intuitive mobile apps that provide seamless user experiences on both iOS and Android platforms.</p>
        <span class="svc-card-link">Read more →</span>
      </a>

      <a class="svc-card" href="/services/cross-platform/">
        <div class="svc-card-icon"><i class="fa-solid fa-layer-group"></i></div>
        <div class="svc-card-name">Cross Platform Development</div>
        <p class="svc-card-desc">Reach wider audiences with our cross-platform development services, ensuring consistent performance across all devices.</p>
        <span class="svc-card-link">Read more →</span>
      </a>

      <a class="svc-card" href="/services/maintenance/">
        <div class="svc-card-icon"><i class="fa-solid fa-screwdriver-wrench"></i></div>
        <div class="svc-card-name">Software Maintenance</div>
