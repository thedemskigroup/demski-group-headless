---
import Layout from '../../layouts/Layout.astro';
Astro.response.headers.set('Cache-Control', 'public, s-maxage=120, stale-while-revalidate=3600');

const KNOWN_IMAGES: Record<string,string> = {
  'biopac':'https://demskigroup.com/wp-content/uploads/2024/07/Biopac.png',
  'shop-orthopedics':'https://demskigroup.com/wp-content/uploads/2024/06/ShopOrthopedics-1.png',
  'property-gauge':'https://demskigroup.com/wp-content/uploads/2024/07/PropertyGauge.png',
  'mister-quik':'https://demskigroup.com/wp-content/uploads/2024/07/mrquick.png',
  'pnc-bank':'https://demskigroup.com/wp-content/uploads/2024/06/company-logo-4.png',
  'jackson-hewitt':'https://demskigroup.com/wp-content/uploads/2024/06/jacksonhewitt-1.png',
  'zoomifi':'https://demskigroup.com/wp-content/uploads/2024/06/Zoomifi-1.png',
  'corning-glass':'https://demskigroup.com/wp-content/uploads/2024/07/corning-300x201-1.png',
  'flower-moxie-case-study':'https://demskigroup.com/wp-content/uploads/2024/07/Flowermoxie.png',
  'golf-daddy':'https://demskigroup.com/wp-content/uploads/2024/07/Branded-300x159.png',
  'audiojack':'https://demskigroup.com/wp-content/uploads/2024/06/audiojackhighres-300x159.png',
  'willo':'https://demskigroup.com/wp-content/uploads/2024/07/Willo-1.png',
  'impact-team-tennis':'https://demskigroup.com/wp-content/uploads/2025/02/ITTLogo-300x159.png',
  'bite':'https://demskigroup.com/wp-content/uploads/2024/08/newbitelogo.png',
  'hewlett-packard-enterprise':'https://demskigroup.com/wp-content/uploads/2024/07/HP-1.png',
  'farmers-daughter-fibers':'https://demskigroup.com/wp-content/uploads/2024/07/FarmersDaughter.png',
  'tausi-brands':'https://demskigroup.com/wp-content/uploads/2024/06/Tausi-1.png',
  'nu-borders':'https://demskigroup.com/wp-content/uploads/2024/07/Nuborders.png',
};

function clean(s: string) {
  return (s||'').replace(/&amp;/g,'&').replace(/&#8217;/g,"'").replace(/&#8216;/g,"'").replace(/<[^>]*>/g,'').trim();
}
function normalizeLink(link: string, slug: string) {
  return (link||'').replace('https://demskigrdev.wpenginepowered.com','').replace('https://demskigroup.com','') || `/our-clients/${slug}/`;
}
function extractPhoto(item: any) {
  return item._embedded?.['wp:featuredmedia']?.[0]?.source_url || item.acf?.featured_image?.url || item.acf?.image?.url || '';
}

let svcClients: any[] = [];
try {
  let all: any[] = [], page = 1, totalPages = 1;
  do {
    const res = await fetch(`https://demskigroup.com/wp-json/wp/v2/our-clients?_embed&per_page=100&page=${page}`, { signal: AbortSignal.timeout(8000) });
    if (!res.ok) break;
    const tp = res.headers.get('X-WP-TotalPages');
    if (tp) totalPages = parseInt(tp);
    const data = await res.json();
    if (!Array.isArray(data) || !data.length) break;
    all = [...all, ...data]; page++;
  } while (page <= totalPages);
  svcClients = all.map((item: any) => ({
    id: item.id, name: clean(item.title?.rendered), slug: item.slug||'',
    link: normalizeLink(item.link, item.slug),
    photo: extractPhoto(item) || KNOWN_IMAGES[item.slug] || '',
    desc: clean(item.excerpt?.rendered||'').replace(/\[&hellip;\]/g,''),
  }));
} catch(e) { console.warn('services SSR clients fetch failed:', e); }

const svcBiopac = svcClients.find(c => c.slug?.includes('biopac')) || svcClients[0];
const svcOthers = svcClients.filter(c => c.id !== svcBiopac?.id);
const svcTopFour = svcOthers.slice(0, 4);
const svcRest = svcOthers.slice(4, 12);
const svcBiopacDesc = svcBiopac?.desc?.length > 20 ? svcBiopac.desc : 'The Demski Group successfully delivered a scalable and efficient web application for Biopac, enabling users to perform and track scientific studies online.';
---

<Layout title="Software Services - The Demski Group">
<style is:global>
/* ══ GLOBAL FONT — Outfit for ALL headings (consistent with other pages) ══ */
h1, h2, h3, h4, h5, h6 {
  font-family: 'Outfit', sans-serif !important;
}

/* ══ HERO ══ */
.svc-hero {
  position: relative;
  min-height: 600px;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: #fff;
  padding: 80px;
  padding-bottom: 180px;

}
.svc-hero::before {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 100%;
  height: 100%;
  background-image: url('https://demskigrdev.wpenginepowered.com/wp-content/uploads/2024/07/busy-colleagues-analyzing-computer-code-2023-11-27-05-16-26-utc-1-scaled.jpg');
  background-size: cover;
  background-position: center;
  z-index: 0;
}
.svc-hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: linear-gradient(96deg, #FFFFFC 43%, #0023686B 85%);
  opacity: 0.99;
  z-index: 1;
}
.svc-hero-inner {
  position: relative;
  z-index: 2;
  max-width: 1280px;
  margin: 0 auto;
  padding: 50px 60px 100px 30px;
  width: 100%;
}
.svc-eyebrow {
  font-family: 'Outfit', sans-serif;
  font-size: 20px;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #666;
  margin-bottom: 20px;
}
.svc-hero h1 {
  font-family: 'Outfit', sans-serif;
  font-size: 65px;
  font-weight: 700;
  color: #0A0000;
  line-height: 1.05;
  margin-top: 0;
  margin-bottom: 24px;
  max-width: 750px;
}
.svc-hero-desc {
  font-size: 20px;
  color: #444;
  line-height: 1.75;
  margin-bottom: 36px;
  max-width: 700px;
}
.btn-orange {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #F09300;
  color: #fff !important;
  font-family: 'Outfit', sans-serif;
  font-size: 20px;
  font-weight: 600;
  padding: 16px 36px;
  border-radius: 10px;
  text-decoration: none !important;
  transition: background 0.3s;
}
.btn-orange:hover { background: #d98200; }

/* Responsive */
@media (max-width: 900px) {
  .svc-hero::before { width: 100%; }
  .svc-hero::after {
    background: linear-gradient(
      to right,
      rgba(255,255,255,1) 0%,
      rgba(255,255,255,0.97) 50%,
      rgba(255,255,255,0.85) 100%
    );
  }
  .svc-hero h1 { font-size: 38px; }
}
@media (max-width: 600px) {
  .svc-hero-inner { padding: 70px 24px; }
  .svc-hero h1 { font-size: 32px; }
}

/* ─── SECTION 2: BRANDS ─── */
.brands-wrap {
  max-width: 1200px;
  margin: -160px auto 0;
  position: relative;
  z-index: 10;
  background: white;
  border-radius: 28px;
  box-shadow: 0 8px 40px rgba(0,0,0,.38);
  padding: 30px 50px;
  display: flex;
  gap: 0;
}
.brands-label {
  font-size: 26px;
  color: #282828;
  min-width: 430px;
  line-height: 1.7;
  padding-right: 40px;
  margin-left: 111px;
  border-right: 3px solid #111;
  flex-shrink: 0;
  text-align: center;
  align-content: center;
}
.brands-label a { color: #0154b1; text-decoration: none; font-weight: 600; }
.brands-label a:hover { text-decoration: underline; }
.brands-text { display: block; }
.brands-logo-img { flex: 1; padding-left: 51px; }
.brands-logo-img img {
  width: 100%; height: auto;
  max-height: 170px; object-fit: contain; display: block;
}
/* ══ SERVICES GRID ══ */
.svc-services {
  background: #fff;
  padding: 90px 65px 120px;
  position: relative;
  overflow-x: clip;
}
.svc-services::after {
  content: '';
  position: absolute;
  bottom: -360px;
  left: -50%;
  width: 200%;
  height: 580px;
  background: #fff;
  clip-path: ellipse(50% 50% at 50% 0%);
  z-index: 2;
}
.svc-services-inner {
  max-width: 1300px;
  margin: 0 auto;
  position: relative;
  z-index: 3;
}
.svc-section-title {
  font-family: 'Outfit', sans-serif;
  font-size: 50px;
  font-weight: 700;
  color: #0A0000;
  margin-bottom: 50px;
  line-height: 1.2;
}
.svc-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 25px;
}
.svc-card {
  border-radius: 25px;
  padding: 25px;
  background: #fff;
  box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.3);
  transition: box-shadow 0.3s;
  display: flex;
  flex-direction: column;
  border: none;
}
.svc-card:hover {
  box-shadow: 0px 0px 24px 0px rgba(0, 0, 0, 0.18);
  transform: translateY(-2px);
}
.svc-card-icon {
  display: none; /* hidden — original has no icon */
}
.svc-card-name {
  font-family: 'Outfit', sans-serif;
  font-size: 35px;
  font-weight: 600;
  color: #282828;
  margin-bottom: 16px;
  line-height: 1.2;
}
.svc-card-desc {
  font-size: 18px;
  color: #000;
  line-height: 1.7;
  flex: 1;
  margin-bottom: 24px;
}
/* Remove all underlines from card links */
.svc-card,
.svc-card *,
.svc-card:hover,
.svc-card:visited {
  text-decoration: none !important;
}
.svc-card-link {
  font-family: 'Outfit', sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: #282828;
  text-decoration: none !important;
  display: flex;
  align-items: center;
  gap: 0;
  align-self: flex-end;
  border-top: 1px solid #f0f0f0;
  width: 100%;
  padding-top: 16px;
  justify-content: flex-end;
  transition: color 0.3s ease, transform 0.3s ease;
}
.svc-card-link:hover {
  color: #0154b1;
  transform: translateY(-8px);
}
.svc-link-inner {
  display: inline-flex;
  align-items: center;
  gap: 0;
  border-bottom: 1px solid #282828;
  padding-bottom: 3px;
  transition: border-color 0.3s ease;
}
.svc-card-link:hover .svc-link-inner {
  border-color: #282828;
}
.svc-arrow {
  margin-left: 6px;
}
.svc-card-link:hover .svc-arrow {
  transform: translateX(5px);
}

/* Wide card (E-commerce) */
.svc-card.wide {
  grid-column: span 3;
  flex-direction: row;
  align-items: flex-start;
  gap: 24px;
}
.svc-card.wide .svc-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.svc-card.wide .svc-card-link {
  border-top: 1px solid #f0f0f0;  /* line back */
  width: 100%;
  padding-top: 16px;
  margin-top: auto;               /* pushes to bottom even if desc is short */
}

/* ══ TECH STACK ══ */
.svc-tech { background: #f0f0f0; padding: 100px 60px; overflow: hidden; position: relative; z-index: 1; }
.svc-tech-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.svc-tech-left {
  margin-left: -10px;
}
.svc-tech-left h2 {
  font-family: 'Outfit', sans-serif !important;
  font-size: 50px; font-weight: 600;
  color: #282828; line-height: 1.2;
  margin-bottom: 32px;
}
/* The .btn-outline rule — add font-size override for tech section */
.svc-tech-left .btn-outline {
  display: inline-flex !important;
  align-items: center !important;
  gap: 16px !important;
  border: 1.5px solid #1a1a1a !important;
  color: #1a1a1a !important;
  background: transparent !important;
  font-family: 'Outfit', sans-serif !important;
  font-size: 18px !important;
  font-weight: 600 !important;
  padding: 12px 24px !important;
  border-radius: 50px !important;
  text-decoration: none !important;
  white-space: nowrap !important;
  transition: color 0.3s ease, border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease !important;
}
.svc-tech-left .btn-outline:hover {
  background: transparent !important;
  color: #0154b1 !important;
  border-color: #0154b1 !important;
  transform: translateY(-3px) !important;
  box-shadow: 0 6px 18px rgba(1, 84, 177, 0.12) !important;
}
.tech-logo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr)); /* minmax prevents blowout */
  gap: 48px 32px;
  margin-top: 20px;
  align-items: center;
  justify-items: center;
}
.tech-logo-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}
.tech-logo-item img {
  max-height: 64px;
  width: 100%;          /* fill cell */
  max-width: 130px;
  object-fit: contain;
  display: block;
  filter: grayscale(100%) brightness(0.15);
  opacity: 1;
  transition: opacity 0.25s, filter 0.25s;
}
.tech-logo-item img:hover { filter: grayscale(0%); opacity: 1; }

@media (max-width: 900px) {
  .svc-tech-inner { grid-template-columns: 1fr; gap: 40px; }
  .tech-logo-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 32px 20px;
  }
}
@media (max-width: 600px) {
  .tech-logo-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px 12px;
  }
  .tech-logo-item img { max-height: 32px; }
}
/* ══ PROJECTS SECTION ══ */
.svc-projects { background: #f0f0f0; padding: 80px 60px; }

.svc-projects-inner {
    max-width: 1200px;
    margin: 0 auto;
    background: #ffffff;
    padding: 80px;
    border-radius: 20px;
}
.svc-projects-header {
  display: flex; justify-content: space-between;
  align-items: center; margin-bottom: 40px;
}
.svc-projects-header h2 {
  font-family: 'Outfit', sans-serif !important;
  font-size: 50px; font-weight: 600;
  color: #0A0000; line-height: 1.2;
}
.btn-outline-sm {
  display: inline-flex !important;
  align-items: center !important;
  gap: 10px !important;
  border: 1.5px solid #1a1a1a !important;
  color: #1a1a1a !important;
  background: transparent !important;
  font-family: 'Outfit', sans-serif !important;
  font-size: 16px !important;
  font-weight: 600 !important;
  padding: 10px 24px !important;
  border-radius: 50px !important;
  text-decoration: none !important;
  white-space: nowrap !important;
  margin-top: 8px;
  transition: color 0.3s ease, border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease !important;
}
.btn-outline-sm .ac { display: none; }
.btn-outline-sm:hover {
  background: transparent !important;
  color: #0154b1 !important;
  border-color: #0154b1 !important;
  transform: translateY(-3px) !important;
  box-shadow: 0 6px 18px rgba(1, 84, 177, 0.12) !important;
}

/* Top wrap: BIOPAC + 4 */
.proj-top-wrap {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 16px; margin-bottom: 16px;
}
.biopac-card {
  background: #0a1628; border-radius: 16px; padding: 32px;
  display: flex; flex-direction: column; justify-content: space-between;
  min-height: 300px; text-decoration: none;
  transition: transform 0.25s, box-shadow 0.25s;
  grid-row: span 2;
}
.biopac-card:hover { transform: translateY(-3px); box-shadow: 0 12px 36px rgba(0,0,0,0.3); }
.biopac-logo img {
  height: 60px; width: auto; object-fit: contain;
  filter: brightness(0) invert(1); display: block; margin-bottom: 16px;
}
.biopac-name { font-family:'Outfit',sans-serif; font-size:22px; font-weight:700; color:#fff; }
.biopac-desc { font-size:14px; color:rgba(255,255,255,0.8); line-height:1.7; margin:12px 0; }
.biopac-link { font-family:'Outfit',sans-serif; font-size:16px; font-weight:700; color:#fff; display:inline-flex; align-items:center; gap:6px; }
.proj-four { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
.client-card {
  box-sizing: border-box;
  background: #fff; border: 1px solid #ebebeb; border-radius: 14px;
  padding: 24px 18px 18px; display: flex; flex-direction: column;
  justify-content: space-between; align-items: center;
  text-decoration: none; transition: box-shadow 0.25s, transform 0.25s;
  min-height: 140px;
}
.client-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); transform: translateY(-2px); }
.client-card-img {
  flex: 1; display: flex; align-items: center;
  justify-content: center; width: 100%; margin-bottom: 14px;
}
.client-card img {
  width: 100%;
  max-width: 100%;
  height: 125px;
  object-fit: contain;
  object-position: center;
  display: block;
}
.client-card-name { font-family:'Outfit',sans-serif; font-size:12px; font-weight:600; color:#333; text-align:center; }
.client-card-link {
  font-family: 'Outfit', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: #0A0000;
  text-decoration: none;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.proj-main-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; }

/* Skeletons */
.skeleton {
  border-radius: 16px;
  background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* ─── SECTION 8: EXCELLENCE ─── */
.excellence-section {
  background: #000000;
  padding: 80px 94px 150px;
  overflow: visible;
  margin-top: 0px;
}
.excellence-card {
  max-width: 1300px;
  margin: 0 auto 0;
  background: #000000;
  border-radius: 25px;
  overflow: visible;
  padding: 80px 70px 60px;
  display: grid;
  grid-template-columns: 51% 49%;
  gap: 0;
  position: relative;
  z-index: 20;
}
.excellence-top { display: contents; }
.excellence-left {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  gap: 22px;
  padding-right: 60px;
  padding-left: 2%;
  padding-top: 2%;
  border-right: 2px solid #ffffff;
}
.excellence-left h2 {
  font-family: 'Outfit', sans-serif;
  font-size: 52px;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.18;
  margin: 0;
  letter-spacing: -0.5px;
}
.excellence-left p {
  font-size: 18px;
  color: #ffffff;
  line-height: 1.65;
  margin: 0;
  max-width: 380px;
}
.btn-outline-excellence {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  border: 1.5px solid #4798ed;
  color: #4798ed;
  background: transparent;
  font-family: 'Outfit', sans-serif;
  font-size: 16px;
  font-weight: 600;
  padding: 10px 20px;
  border-radius: 50px;
  text-decoration: none;
  width: fit-content;
  transition: all 0.6s cubic-bezier(0.4,0,0.2,1), transform 0.5s cubic-bezier(0.4,0,0.2,1);
  margin-top: 10%;
}
.btn-outline-excellence:hover { background: transparent; color: #4798ed; border-color: #4798ed; transform: translateY(-4px); }
.excellence-divider { display: none; }
.excellence-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding-left: 60px;
  transform: translateY(-80px);
}
.badge-rotator {
  position: relative;
  width: 507px;
  height: 507px;
  overflow: hidden;
}
.badge-slide {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: translateX(100%);
  transition: transform 0.65s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.65s ease;
  pointer-events: none;
}
.badge-slide.active {
  opacity: 1;
  transform: translateX(0);
  pointer-events: auto;
}
.badge-slide.leaving {
  opacity: 0;
  transform: translateX(-100%);
}
.badge-slide img {
  max-width: 429px;
  max-height: 429px;
  width: auto;
  height: auto;
  object-fit: contain;
  filter: brightness(0) invert(1);
}
.cissp-badge {
  background: white;
  border-radius: 22px;
  width: 200px;
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}
.cissp-badge img {
  width: 100%;
  height: auto;
  object-fit: contain;
  filter: none;
}

/* Bottom ratings */
.excellence-bottom {
  grid-column: 1 / -1;
  display: flex;
  justify-content: center;
  gap: 0;
  border-top: none;
  padding-top: 30px;
  margin-top: 30px;
}
.rating-col {
  flex: 1;
  text-align: center;
  padding: 0 40px;
}
.rating-col:first-child { border-right: none; }
.rating-col-label {
  font-family: 'Outfit', sans-serif;
  font-size: 36px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 18px;
}
.rating-col-stars { color: #F09300; font-size: 38px; letter-spacing: 6px; }

@media (max-width: 900px) {
  .excellence-card { grid-template-columns: 1fr; padding: 50px 24px; gap: 40px; }
