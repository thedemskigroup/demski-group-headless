---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Software Services - The Demski Group">
<style is:global>
/* ══ GLOBAL FONT — Outfit for ALL headings (consistent with other pages) ══ */
h1, h2, h3, h4, h5, h6 {
  font-family: 'Outfit', sans-serif !important;
}

/* ══ HERO ══ */
.svc-hero {
  position: relative;
  min-height: 600px;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: #fff;
  padding: 80;
  padding-bottom: 180px;

}
.svc-hero::before {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 100%;
  height: 100%;
  background-image: url('https://demskigrdev.wpenginepowered.com/wp-content/uploads/2024/07/busy-colleagues-analyzing-computer-code-2023-11-27-05-16-26-utc-1-scaled.jpg');
  background-size: cover;
  background-position: center;
  z-index: 0;
}
.svc-hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image: linear-gradient(96deg, #FFFFFC 43%, #0023686B 85%);
  opacity: 0.99;
  z-index: 1;
}
.svc-hero-inner {
  position: relative;
  z-index: 2;
  max-width: 1280px;
  margin: 0 auto;
  padding: 100px 60px;
  width: 100%;
}
.svc-eyebrow {
  font-family: 'Outfit', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #666;
  margin-bottom: 20px;
}
.svc-hero h1 {
  font-family: 'Outfit', sans-serif;
  font-size: 65px;
  font-weight: 700;
  color: #0A0000;
  line-height: 1.05;
  margin-bottom: 24px;
  max-width: 750px;
}
.svc-hero-desc {
  font-size: 20px;
  color: #444;
  line-height: 1.75;
  margin-bottom: 36px;
  max-width: 420px;
}
.btn-orange {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #F09300;
  color: #fff !important;
  font-family: 'Outfit', sans-serif;
  font-size: 18px;
  font-weight: 600;
  padding: 16px 36px;
  border-radius: 10px;
  text-decoration: none !important;
  transition: background 0.3s;
}
.btn-orange:hover { background: #d98200; }

/* Responsive */
@media (max-width: 900px) {
  .svc-hero::before { width: 100%; }
  .svc-hero::after {
    background: linear-gradient(
      to right,
      rgba(255,255,255,1) 0%,
      rgba(255,255,255,0.97) 50%,
      rgba(255,255,255,0.85) 100%
    );
  }
  .svc-hero h1 { font-size: 38px; }
}
@media (max-width: 600px) {
  .svc-hero-inner { padding: 70px 24px; }
  .svc-hero h1 { font-size: 32px; }
}

/* ─── SECTION 2: BRANDS ─── */
.brands-wrap {
  max-width: 1300px;
  margin: -160px auto 0;
  position: relative;
  z-index: 10;
  background: white;
  border-radius: 16px;
  box-shadow: 0 8px 40px rgba(0,0,0,.18);
  padding: 40px 50px;
  display: flex;
  gap: 0;
}
.brands-label {
  font-size: 26px;
  color: #282828;
  min-width: 380px;
  line-height: 1.7;
  padding-right: 40px;
  margin-left: 211px;
  border-right: 1px solid #ccc;
  flex-shrink: 0;
  text-align: left;
  align-content: center;
}
.brands-label a { color: #0154b1; text-decoration: none; font-weight: 600; }
.brands-label a:hover { text-decoration: underline; }
.brands-text { display: block; transform: translateX(-40px); }
.brands-logo-img { flex: 1; padding-left: 36px; }
.brands-logo-img img {
  width: 100%; height: auto;
  max-height: 170px; object-fit: contain; display: block;
}
/* ══ SERVICES GRID ══ */
.svc-services {
  background: #fff;
  padding: 90px 60px;
}
.svc-services-inner {
  max-width: 1200px;
  margin: 0 auto;
}
.svc-section-title {
  font-family: 'Outfit', sans-serif;
  font-size: 50px;
  font-weight: 700;
  color: #0A0000;
  margin-bottom: 50px;
  line-height: 1.2;
}
.svc-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 25px;
}
.svc-card {
  border-radius: 25px;
  padding: 25px;
  background: #fff;
  box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.3);
  transition: box-shadow 0.3s;
  display: flex;
  flex-direction: column;
  border: none;
}
.svc-card:hover {
  box-shadow: 0px 0px 24px 0px rgba(0, 0, 0, 0.18);
  transform: translateY(-2px);
}
.svc-card-icon {
  display: none; /* hidden — original has no icon */
}
.svc-card-name {
  font-family: 'Outfit', sans-serif;
  font-size: 35px;
  font-weight: 600;
  color: #282828;
  margin-bottom: 16px;
  line-height: 1.2;
}
.svc-card-desc {
  font-size: 18px;
  color: #444;
  line-height: 1.7;
  flex: 1;
  margin-bottom: 24px;
}
/* Remove all underlines from card links */
.svc-card,
.svc-card *,
.svc-card:hover,
.svc-card:visited {
  text-decoration: none !important;
}
.svc-card-link {
  font-family: 'Outfit', sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: #282828;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 8px;
  align-self: flex-end;
  border-top: 1px solid #f0f0f0;
  width: 100%;
  padding-top: 16px;
  justify-content: flex-end;
}
.svc-card-link:hover { color: #0154b1; }

/* Wide card (E-commerce) */
.svc-card.wide {
  grid-column: span 3;
  flex-direction: row;
  align-items: flex-start;
  gap: 24px;
}
.svc-card.wide .svc-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.svc-card.wide .svc-card-link {
  border-top: 1px solid #f0f0f0;  /* line back */
  width: 100%;
  padding-top: 16px;
  margin-top: auto;               /* pushes to bottom even if desc is short */
}

/* ══ TECH STACK ══ */
.svc-tech { background: #f0f0f0; padding: 100px 60px; overflow: hidden; }
.svc-tech-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.svc-tech-left h2 {
  font-family: 'Outfit', sans-serif !important;
  font-size: 50px; font-weight: 600;
  color: #0A0000; line-height: 1.2;
  margin-bottom: 32px;
}
/* The .btn-outline rule — add font-size override for tech section */
.svc-tech-left .btn-outline {
  display: inline-flex !important;
  align-items: center;
  gap: 8px;
  border: 1.5px solid #1a1a1a !important;
  color: #0A0000 !important;
  background: transparent !important;
  font-family: 'Outfit', sans-serif;
  font-size: 16px;
  font-weight: 600;
  padding: 12px 28px;
  border-radius: 50px;
  text-decoration: none !important;
  white-space: nowrap;
  transition: all 0.25s;
}
.svc-tech-left .btn-outline:hover {
  background: #0A0000 !important;
  color: #fff !important;
}
.tech-logo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr)); /* minmax prevents blowout */
  gap: 48px 32px;
  align-items: center;
  justify-items: center;
}
.tech-logo-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}
.tech-logo-item img {
  max-height: 44px;
  width: 100%;          /* fill cell */
  max-width: 110px;
  object-fit: contain;
  display: block;
  filter: grayscale(100%);
  opacity: 0.75;
  transition: opacity 0.25s, filter 0.25s;
}
.tech-logo-item img:hover { filter: grayscale(0%); opacity: 1; }

@media (max-width: 900px) {
  .svc-tech-inner { grid-template-columns: 1fr; gap: 40px; }
  .tech-logo-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 32px 20px;
  }
}
@media (max-width: 600px) {
  .tech-logo-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px 12px;
  }
  .tech-logo-item img { max-height: 32px; }
}
/* ══ PROJECTS SECTION ══ */
.svc-projects { background: #f0f0f0; padding: 80px 60px; }

.svc-projects-inner {
    max-width: 1200px;
    margin: 0 auto;
    background: #ffffff;
    padding: 80px;
    border-radius: 20px;
}
.svc-projects-header {
  display: flex; justify-content: space-between;
  align-items: center; margin-bottom: 40px;
}
.svc-projects-header h2 {
  font-family: 'Outfit', sans-serif !important;
  font-size: 50px; font-weight: 600;
  color: #0A0000; line-height: 1.2;
}
.btn-outline-sm {
  display: inline-flex; align-items: center; gap: 8px;
  border: 1.5px solid #1a1a1a; color: #0A0000;
  font-family: 'Outfit', sans-serif; font-size: 18px; font-weight: 600;
  padding: 9px 18px; border-radius: 50px;
  text-decoration: none; transition: all 0.25s; white-space: nowrap; margin-top: 8px;
}
.btn-outline-sm .ac {
  width: 20px; height: 20px;
  background: #0A0000; color: #fff;
  border-radius: 50%; display: inline-flex;
  align-items: center; justify-content: center;
  font-size: 11px; transition: all 0.25s;
}
.btn-outline-sm:hover { background: #0A0000; color: #fff; }
.btn-outline-sm:hover .ac { background: #fff; color: #0A0000; }

/* Top wrap: BIOPAC + 4 */
.proj-top-wrap {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 16px; margin-bottom: 16px;
}
.biopac-card {
  background: #0a1628; border-radius: 16px; padding: 32px;
  display: flex; flex-direction: column; justify-content: space-between;
  min-height: 300px; text-decoration: none;
  transition: transform 0.25s, box-shadow 0.25s;
  grid-row: span 2;
}
.biopac-card:hover { transform: translateY(-3px); box-shadow: 0 12px 36px rgba(0,0,0,0.3); }
.biopac-logo img {
  height: 60px; width: auto; object-fit: contain;
  filter: brightness(0) invert(1); display: block; margin-bottom: 16px;
}
.biopac-name { font-family:'Outfit',sans-serif; font-size:22px; font-weight:700; color:#fff; }
.biopac-desc { font-size:14px; color:rgba(255,255,255,0.8); line-height:1.7; margin:12px 0; }
.biopac-link { font-family:'Outfit',sans-serif; font-size:16px; font-weight:700; color:#fff; }
.proj-four { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.client-card {
  background: #fff; border: 1px solid #ebebeb; border-radius: 14px;
  padding: 24px 18px 18px; display: flex; flex-direction: column;
  justify-content: space-between; align-items: center;
  text-decoration: none; transition: box-shadow 0.25s, transform 0.25s;
  min-height: 140px;
}
.client-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); transform: translateY(-2px); }
.client-card-img {
  flex: 1; display: flex; align-items: center;
  justify-content: center; width: 100%; margin-bottom: 14px;
}
.client-card img {
  width: 100%;
  max-width: 100%;
  height: 125px;
  object-fit: contain;
  object-position: center;
  display: block;
}
.client-card-name { font-family:'Outfit',sans-serif; font-size:12px; font-weight:600; color:#333; text-align:center; }
.client-card-link {
  font-family: 'Outfit', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: #0A0000;
  text-decoration: none;
  white-space: nowrap;
}
.proj-main-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }

/* Skeletons */
.skeleton {
  border-radius: 16px;
  background: linear-gradient(90deg, #e8e8e8 25%, #f5f5f5 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* ─── SECTION 8: EXCELLENCE ─── */
.excellence-section {
  background: #0c0c0c;
  padding: 80px 174px 150px;
  overflow: visible;
  margin-top: 0px;
}
.excellence-card {
  max-width: 1300px;
  margin: 0 auto 0;
  background: #0c0c0c;
  border-radius: 25px;
  overflow: visible;
  padding: 80px 70px 60px;
  display: grid;
  grid-template-columns: 51% 49%;
  gap: 0;
  position: relative;
  z-index: 20;
}
.excellence-top { display: contents; }
.excellence-left {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  gap: 22px;
  padding-right: 60px;
  padding-left: 2%;
  padding-top: 2%;
  border-right: 2px solid #ffffff;
}
.excellence-left h2 {
  font-family: 'Outfit', sans-serif;
  font-size: 52px;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.18;
  margin: 0;
  letter-spacing: -0.5px;
}
.excellence-left p {
  font-size: 18px;
  color: #ffffff;
  line-height: 1.65;
  margin: 0;
  max-width: 380px;
}
.btn-outline-excellence {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  border: 1.5px solid #4798ed;
  color: #4798ed;
  background: transparent;
  font-family: 'Outfit', sans-serif;
  font-size: 16px;
  font-weight: 600;
  padding: 10px 20px;
  border-radius: 50px;
  text-decoration: none;
  width: fit-content;
  transition: all 0.6s cubic-bezier(0.4,0,0.2,1), transform 0.5s cubic-bezier(0.4,0,0.2,1);
  margin-top: 10%;
}
.btn-outline-excellence:hover { background: transparent; color: #4798ed; border-color: #4798ed; transform: translateY(-4px); }
.excellence-divider { display: none; }
.excellence-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding-left: 60px;
}
.badge-rotator {
  position: relative;
  width: 507px;
  height: 507px;
}
.badge-slide {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.8s ease;
  pointer-events: none;
}
.badge-slide.active {
  opacity: 1;
  pointer-events: auto;
}
.badge-slide img {
  max-width: 429px;
  max-height: 429px;
  width: auto;
  height: auto;
  object-fit: contain;
  filter: brightness(0) invert(1);
}
.cissp-badge {
  background: white;
  border-radius: 22px;
  width: 200px;
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}
.cissp-badge img {
  width: 100%;
  height: auto;
  object-fit: contain;
  filter: none;
}

/* Bottom ratings */
.excellence-bottom {
  grid-column: 1 / -1;
  display: flex;
  justify-content: center;
  gap: 0;
  border-top: none;
  padding-top: 30px;
  margin-top: 30px;
}
.rating-col {
  flex: 1;
  text-align: center;
  padding: 0 40px;
}
.rating-col:first-child { border-right: none; }
.rating-col-label {
  font-family: 'Outfit', sans-serif;
  font-size: 36px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 18px;
}
.rating-col-stars { color: #F09300; font-size: 38px; letter-spacing: 6px; }

@media (max-width: 900px) {
  .excellence-card { grid-template-columns: 1fr; padding: 50px 24px; gap: 40px; }
  .excellence-left { border-right: none; border-bottom: 1px solid #333; padding-right: 0; padding-bottom: 40px; }
  .excellence-right { padding-left: 0; }
  .excellence-left h2 { font-size: 32px; }
  .rating-col-label { font-size: 22px; }
}
/* ══ POS INTEGRATION CTA ══ */
.svc-pos {
  background: transparent;   /* let excellence black show behind */
  padding: 0 60px 60px;
  position: relative;
  z-index: 99;
}
.svc-pos-inner {
  max-width: 1200px;
  margin: -150px auto 0;     /* negative overlap into excellence */
  background: #fff;
  border-radius: 20px;
  display: flex;
  align-items: center;
  overflow: hidden;
  min-height: 220px;
  box-shadow: 0px 0px 35px 7px rgba(0, 0, 0, 0.27);
  position: relative;
  z-index: 10;
}
.svc-pos-img {
  width: 420px;
  min-width: 420px;       /* prevent shrinking */
  height: 290px;
  flex-shrink: 0;
  overflow: hidden;
}
.svc-pos-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.svc-pos-content {
  flex: 1;
  padding: 40px 48px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.svc-pos-content p {
  font-size: 25px;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.5;
  margin: 0;
}
.pos-sub {
  font-size: 20px;
  color: #0154b1;
  font-weight: 500;
  text-decoration: none;
}
.svc-pos-btn {
  padding: 0 56px;
  flex-shrink: 0;
}
.svc-pos-btn .btn-orange {
  font-size: 20px;            /* override global btn-orange size */
  padding: 18px 32px;
  white-space: nowrap;
}

@media (max-width: 900px) {
  .svc-pos-inner { flex-direction: column; align-items: stretch; }
  .svc-pos-img { width: 100%; min-width: unset; height: 220px; }
  .svc-pos-btn { padding: 0 40px 40px; }
}

/* ══ METHODOLOGIES ══ */
.svc-methods {
  background: #fff;
  padding: 80px 60px;
}
.svc-methods-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 60px;
  align-items: center;
}
.svc-methods-left {
  display: flex;
  flex-direction: column;
  gap: 28px;
}
.svc-methods-left h2 {
  font-family: 'Outfit', sans-serif !important;
  font-size: 50px;
  font-weight: 600;
  color: #0A0000;
  line-height: 1.2;
}
.btn-outline-methods {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1.5px solid #1a1a1a;
  color: #0A0000;
  font-family: 'Outfit', sans-serif;
  font-size: 18px;
  font-weight: 600;
  padding: 10px 20px;
  border-radius: 50px;
  text-decoration: none !important;
  transition: all 0.25s;
  white-space: nowrap;
  width: fit-content;
}
.btn-outline-methods:hover {
  background: #0A0000;
  color: #fff;
}
.svc-methods-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

/* ── Flip card wrapper ── */
.method-card {
  min-height: 420px;
  perspective: 1000px;   /* 3D depth */
  text-decoration: none !important;
  display: block;
  cursor: pointer;
  border-radius: 24px;
}

/* Inner container that flips */
.method-card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 420px;
  transform-style: preserve-3d;
  transition: transform 0.7s cubic-bezier(0.4, 0.2, 0.2, 1);
  border-radius: 24px;
}
.method-card:hover .method-card-inner {
  transform: rotateY(180deg);
}

/* Front face */
.method-card-front {
  position: absolute;
  inset: 0;
  border-radius: 24px;
  overflow: hidden;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}
.method-card-front .method-card-bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  z-index: 0;
}
.method-card-front::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.55) 100%);
  z-index: 1;
  border-radius: 24px;
}
.method-card-front-content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
}
.method-default-arrow {
  color: #fff;
  font-size: 22px;
  line-height: 1;
}
.method-default-name {
  font-family: 'Outfit', sans-serif;
  font-size: 26px;
  font-weight: 700;
  color: #fff;
  text-align: center;
}

/* Back face */
.method-card-back {
  position: absolute;
  inset: 0;
  border-radius: 24px;
  overflow: hidden;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  transform: rotateY(180deg);   /* pre-flipped, hidden until hover */
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 28px;
  text-align: center;
  box-shadow: 0 8px 32px rgba(0,0,0,0.12);
}
.method-hover-name {
  font-family: 'Outfit', sans-serif;
  font-size: 26px;
  font-weight: 700;
  color: #0A0000;
  margin-bottom: 16px;
}
.method-hover-desc {
  font-size: 15px;
  color: #555;
  line-height: 1.75;
  margin: 0;
}

/* ── Responsive ── */
@media (max-width: 1024px) {
