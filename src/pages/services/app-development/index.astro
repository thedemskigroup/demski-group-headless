    font-weight: 700;
    color: var(--ink);
    margin: 0 0 20px;
    line-height: 1.15;
  }
  .cd-hero__text p {
    font-size: 19px;
    color: var(--ink);
    line-height: 1.75;
    margin: 0 0 30px;
  }
  .cd-hero__text .btn-orange {
    font-size: 19px;
    border-radius: 6px;
    transition: background 0.2s, color 0.2s;
  }
  .cd-hero__text .btn-orange:hover {
    background: #fff;
    color: #000;
  }
  .cd-hero__image { flex: 1.3; max-width: 624px; position: relative; left: 85px; }
  @media (max-width: 1366px) { .cd-hero__image { left: 0; } }
  .cd-hero__image img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 24px;
