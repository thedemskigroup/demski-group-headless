  .container { max-width: 1200px; margin: 0 auto; padding: 0 40px; }

  .btn-orange {
    display: inline-block;
    background: var(--orange);
    color: #fff;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 15px;
    padding: 14px 30px;
    border-radius: 4px;
    text-decoration: none;
    border: none;
    cursor: pointer;
