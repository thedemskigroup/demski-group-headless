  /* ─── 1. HERO ─── */
  .cd-hero {
    background: #ffffff;
    padding: 80px 40px 80px;
  }
  .cd-hero__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 60px;
  }
  .cd-hero__text { flex: 1.1; }
  .cd-hero__text h1 {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(44px, 4vw, 62px);
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 20px;
    line-height: 1.15;
  }
  .cd-hero__text p {
    font-size: 19px;
    color: #000000;
    line-height: 1.75;
    margin: 0 0 30px;
  }
  .cd-hero__text .btn-orange {
    font-size: 19px;
    border-radius: 6px;
    transition: background 0.2s, color 0.2s;
  }
  .cd-hero__text .btn-orange:hover {
    background: #fff;
    color: #000;
  }
  .cd-hero__image { flex: 1.3; max-width: 624px; position: relative; left: 85px; }
  @media (max-width: 1366px) { .cd-hero__image { left: 0; } }
  .cd-hero__image img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 24px;
    display: block;
    margin-bottom: -150px;
    position: relative;
    top: 40px;
    z-index: 2;
    box-shadow: 0 10px 40px rgba(0,0,0,0.12);
  }

  /* ─── 2. LOGOS ─── */
  .cd-logos {
    background: #2a2a2a;
    padding: 0;
  }
  .cd-logos__inner {
    max-width: 100%;
    margin: 0;
    background: #2a2a2a;
    border-radius: 0;
    display: flex;
    overflow: hidden;
  }
  .cd-logos .brands-label {
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    color: #fff;
    min-width: 250px;
    padding: 36px 36px 36px 86px;
    border-right: 3px solid #ffffff;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    line-height: 1.65;
  }
  .cd-logos .brands-logos {
    flex: 1;
    padding: 24px 44px 24px 0;
    margin-left: -700px;
    display: flex;
    align-items: center;
  }
  .cd-logos .brands-logos img {
    width: 100%;
    max-height: 120px;
    object-fit: contain;
  }

  /* ─── 3. OUR SERVICES ─── */
  .cd-services {
    background: #fff;
    padding: 100px 40px;
  }
  .cd-services h2 {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(36px, 4.5vw, 56px);
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 16px;
  }
  .cd-services__subtitle {
    font-size: 18px;
    color: #6b7280;
    margin: 0 0 60px;
  }
  .cd-services__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 80px;
  }
  .service-hr {
    border: none;
    border-top: 2px solid #b0b0b0;
    margin: 0 0 32px;
  }
  .service-icon-row {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding-bottom: 48px;
  }
  .service-icon-row i {
    color: var(--blue);
    font-size: 26px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .service-title {
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 21px;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .service-desc {
    font-size: 16px;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  /* ─── 4. CASE STUDY ─── */
  .cd-casestudy {
    background: #fff;
    padding: 80px 40px;
  }
  .cd-casestudy__card {
    background: #fff;
    border-radius: 24px;
    display: flex;
    gap: 40px;
    padding: 74px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.14), 0 4px 12px rgba(0,0,0,0.08);
    border: 1px solid #f0f0f0;
  }
  .cd-casestudy__left {
    flex: 1;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    justify-content: center;
  }
  .case-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--blue);
    text-transform: uppercase;
  }
  .cd-casestudy__left img {
    max-width: 220px;
    height: auto;
  }
  .cd-casestudy__left p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--ink);
    margin: 0;
  }
  .cd-casestudy__left a { color: var(--blue); }
  .case-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
  }
  .tag-btn {
    background: transparent;
    color: var(--ink);
    padding: 8px 20px;
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .tag-btn:hover { background: var(--ink); color: #fff; }
  .tag-btn-arrow {
    color: var(--ink);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    transition: background 0.2s, color 0.2s;
  }
  .tag-btn-arrow:hover { background: var(--ink); color: #fff; }
  .cd-casestudy__right { flex: 0 0 340px; }
  .cd-casestudy__right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 16px;
  }

  /* ─── 5. TABS ─── */
  .cd-tabs {
    background: #fff;
    padding: 100px 40px;
  }
  .cd-tabs h2 {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(36px, 4.5vw, 56px);
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 60px;
  }
  .cd-tabs__wrap {
    display: flex;
    gap: 60px;
  }
  .cd-tabs__nav {
    flex: 0 0 280px;
    display: flex;
    flex-direction: column;
  }
  .tab-btn {
    background: transparent;
    border: none;
    border-bottom: 1px solid #000;
    padding: 24px 24px 24px 0;
    text-align: left;
    font-family: 'Outfit', sans-serif;
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    cursor: pointer;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .tab-btn:last-child { border-bottom: none; }
  .tab-btn:hover { color: var(--blue); }
  .tab-btn.active {
    color: var(--blue);
    font-weight: 700;
  }
  .tab-btn .tab-arrow {
    display: none;
    font-size: 14px;
    flex-shrink: 0;
  }
  .tab-btn.active .tab-arrow { display: inline-block; }
  .cd-tabs__content {
    flex: 1;
    padding: 0;
  }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }
  .tab-panel p {
    font-size: 16px;
    line-height: 1.85;
    color: var(--ink);
    margin: 0 0 16px;
  }

  /* ─── 6. POS CTA BANNER ─── */
  .cd-cta-banner {
    background: var(--navy);
    display: flex;
    align-items: center;
    gap: 0;
    overflow: hidden;
    border-radius: 24px;
    margin: 0 100px;
  }
  .cd-cta-banner__img { flex: 0 0 35%; max-height: 220px; overflow: hidden; }
  .cd-cta-banner__img img { width: 100%; height: 220px; object-fit: cover; object-position: center; display: block; opacity: 0.7; }
  .cd-cta-banner__text {
    flex: 1;
    padding: 40px;
    color: #fff;
    font-size: 18px;
    font-weight: 500;
    line-height: 1.6;
  }
  .cd-cta-banner__btn { padding: 40px; flex-shrink: 0; }
  .cd-cta-banner__btn .btn-orange {
    border-radius: 8px;
    transition: background 0.2s, color 0.2s;
  }
  .cd-cta-banner__btn .btn-orange:hover {
    background: #fff;
    color: #000;
  }

  /* ─── 7. WHY CHOOSE US ─── */
  .cd-why {
    background: #fff;
    padding: 100px 40px;
  }
  .cd-why__inner {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    gap: 60px;
    align-items: flex-start;
  }
  .cd-why__left { flex: 1; }
  .cd-why__left h2 {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(36px, 4.5vw, 56px);
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 24px;
  }
  .cd-why__left img {
    width: 50vw;
    max-width: none;
    margin-left: calc(50% - 50vw + 290px);
    height: 360px;
    object-fit: cover;
    border-radius: 24px;
    display: block;
  }
  .cd-why__right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 20px;
  }
  .why-item { display: flex; gap: 16px; align-items: flex-start; }
  .why-icon {
    width: 32px;
    height: 32px;
    background: transparent;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--blue);
    font-size: 24px;
  }
  .why-title {
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 19px;
    color: var(--ink);
    margin: 0 0 8px;
  }
  .why-desc { font-size: 16px; color: #555; line-height: 1.7; margin: 0; }
  .btn-outline-arrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: 1.5px solid var(--ink);
    color: var(--ink);
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 14px;
    padding: 10px 24px;
    border-radius: 999px;
    text-decoration: none;
    margin-top: 10px;
    align-self: flex-end;
    transition: background 0.2s, color 0.2s;
  }
  .btn-outline-arrow:hover { background: var(--ink); color: #fff; }

  /* ─── 8. PROCESS ─── */
  .hp-process-section {
    background: #fff;
    padding: 100px 90px;
    position: relative;
    overflow: hidden;
  }
  .hp-process-inner {
    max-width: 1140px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .hp-process-heading {
    text-align: center;
    margin-bottom: 70px;
  }
  .hp-process-heading h2 {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.15;
    margin: 0 0 16px;
  }
  .hp-process-heading p {
    font-size: 16px;
    color: #000;
    line-height: 1.7;
    max-width: 780px;
    margin: 0 auto;
  }
  .hp-process-body {
    display: flex;
    gap: 60px;
    align-items: flex-start;
  }

  /* Timeline steps */
  .hp-process-steps { flex: 1; position: relative; }
  .hp-process-line-track {
    position: absolute;
    left: 21px;
    top: 30px;
    bottom: 30px;
    width: 2px;
    background: #e0e0e0;
    z-index: 0;
  }
  .hp-process-line-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: var(--blue);
    border-radius: 2px;
  }
  .hp-process-step {
    display: flex;
    gap: 24px;
    padding: 0 0 44px 0;
    position: relative;
    z-index: 1;
  }
  .hp-process-step:last-child { padding-bottom: 0; }
  .hp-step-dot-wrap { flex-shrink: 0; padding-top: 22px; }
  .hp-step-dot {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid #e0e0e0;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    color: #ccc;
    transition: border-color 0.4s, color 0.4s, background 0.4s;
  }
  .hp-process-step.active .hp-step-dot {
    border-color: var(--blue);
    color: var(--blue);
    background: #fff;
  }
  .hp-step-content { flex: 1; display: flex; flex-direction: column; }
  .hp-step-label {
    font-size: 15px;
    font-weight: 700;
    color: var(--blue);
    letter-spacing: 0.5px;
    margin-bottom: 8px;
    padding-left: 2px;
  }
  .hp-step-card {
    background: #fff;
    border-radius: 14px;
    padding: 22px 26px 24px;
    box-shadow: 0 4px 18px rgba(0,0,0,0.06);
    transition: box-shadow 0.4s;
  }
  .hp-process-step.active .hp-step-card { box-shadow: 0 6px 28px rgba(1,84,177,0.12); }
  .hp-step-card h4 {
    font-family: 'Outfit', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
    margin-top: 0;
    margin-bottom: 10px;
  }
  .hp-step-card p {
    font-size: 16px;
    color: #000;
    line-height: 1.7;
    margin: 0;
  }

  /* Right CTA */
  .hp-process-right {
    flex: 0 0 260px;
    position: sticky;
    top: 120px;
  }
  .hp-process-right-actions {
    display: flex;
    align-items: center;
    gap: 20px;
    transform: translateY(40px);
  }
  .hp-process-right-actions .btn-orange {
    white-space: nowrap;
    border-radius: 10px;
    transition: background 0.2s, color 0.2s;
  }
  .hp-process-right-actions .btn-orange:hover {
    background: #fff;
    color: #000;
  }
  .hp-btn-back-arrow {
    font-size: 60px;
    font-weight: 900;
    color: var(--ink);
    display: inline-block;
    line-height: 1;
    animation: hp-arrow-slide 1.15s ease-in-out infinite;
  }
  @keyframes hp-arrow-slide {
    0%   { transform: translateX(0); }
    50%  { transform: translateX(-25px); }
    100% { transform: translateX(0); }
  }

  /* ─── 9. FAQ ─── */
  .cd-faq {
    background: #fff;
    padding: 100px 40px;
  }
  .cd-faq h2 {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(36px, 4.5vw, 56px);
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 60px;
  }
  .faq-list { max-width: 1620px; margin: 0 auto; }
  .faq-item {
    border-bottom: 1px solid #e5e5e5;
  }
  .faq-q {
    display: flex;
    align-items: center;
    gap: 18px;
    width: 100%;
    background: transparent;
    border: none;
    padding: 28px 0;
    text-align: left;
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
  }
  .faq-q i { color: var(--blue); font-size: 16px; }
  .faq-q[aria-expanded="true"] i.icon-closed { display: none !important; }
  .faq-q[aria-expanded="true"] i.icon-open  { display: inline-block !important; }
  .faq-q[aria-expanded="false"] i.icon-open  { display: none !important; }
  .faq-q[aria-expanded="false"] i.icon-closed { display: inline-block !important; }
  .faq-a {
    display: none;
    padding: 0 0 28px 40px;
    font-size: 17px;
    line-height: 1.75;
    color: #000;
  }

  /* ─── 10. CONTACT + TESTIMONIAL ─── */
  .svc-contact { background-color: #001629; }
  .svc-contact-inner {
    display: grid;
    grid-template-columns: 62% 38%;
    max-width: 1850px;
    margin: 0 auto;
    min-height: 600px;
    align-items: stretch;
  }
  .svc-contact-left { padding: 72px 140px 72px 140px; }
  .svc-contact-left h2 {
    font-family: 'Outfit', sans-serif !important;
    color: #ffffff;
    font-size: clamp(28px, 3.2vw, 46px);
    margin-bottom: 46px;
    line-height: 1.2;
    white-space: nowrap;
    font-weight: 600;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }
  .contact-form .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 42px;
  }
  .contact-form input,
  .contact-form textarea {
    width: 100%;
    padding: 12px 0;
    border: none;
    border-bottom: 1.5px solid rgba(255,255,255,0.9);
    border-radius: 0;
    font-size: 15px;
    font-family: inherit;
    outline: none;
    background: transparent;
    color: #ffffff;
    transition: border-bottom-color 0.2s;
  }
  .contact-form input:focus,
  .contact-form textarea:focus { border-bottom-color: rgba(255,255,255,0.9); }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder { color: rgba(255,255,255,0.65); }
  .contact-form textarea { resize: none; min-height: 40px; }
  .btn-contact {
    align-self: flex-start;
    padding: 15px 44px;
    background: #ffffff;
    color: #001629;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    margin-top: 12px;
    transition: background 0.2s;
  }
  .btn-contact:hover { background: #f0f0f0; }
  .svc-contact-right {
    background-color: #f0f0f0;
    border-radius: 25px;
    margin: 28px 28px 28px 0;
    padding: 40px 40px 0;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 32px rgba(0,0,0,0.14);
  }
  .svc-contact-right-label {
    font-size: 16px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 22px;
  }
  .tc-carousel { position: relative; flex: 1; }
  .tc-slide { display: none; flex-direction: column; padding: 0; background: transparent; border-radius: 0; box-shadow: none; }
  .tc-slide.active { display: flex; }
  .tc-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 14px; }
  .tc-logo { display: flex; align-items: center; height: 35px; }
  .tc-logo img { height: 35px; width: auto; object-fit: contain; max-width: 120px; }
  .tc-text { color: #333; font-size: 16px; line-height: 1.72; margin: 0 0 20px; flex: 1; }
  .tc-footer { display: flex; justify-content: space-between; align-items: flex-end; gap: 12px; padding-top: 14px; border-top: 1px solid #e8e8e8; }
  .tc-author { font-size: 14px; font-weight: 700; color: #1a1a1a; line-height: 1.4; }
  .tc-role { display: block; font-weight: 400; font-size: 13px; color: #888; }
  .tc-link { color: #1a1a1a; text-decoration: none; font-size: 13px; font-weight: 500; white-space: nowrap; display: inline-flex; align-items: center; gap: 4px; }
  .tc-fraction-bar { text-align: center; font-size: 20px; color: #000; padding: 14px 0 8px; position: relative; z-index: 2; transform: translateY(-100px); }
  .contact-right-img { width: 100%; height: 220px; object-fit: cover; object-position: center top; display: block; margin-top: 0; margin-bottom: 0; border-radius: 16px 16px 22px 22px; transform: translateY(-50px); }
  .svc-arrow { margin-left: 6px; display: inline-block; transition: transform 0.2s; }
  .tc-link:hover .svc-arrow { transform: translateX(5px); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .cd-hero__inner,
    .cd-why__inner,
    .hp-process-body { flex-direction: column; gap: 40px; }
    .cd-why__left img { width: 100%; max-width: 100%; margin-left: 0; height: auto; aspect-ratio: 16/10; }
    .hp-process-heading { flex: none; max-width: none; }
    .hp-process-heading h2, .hp-process-heading p { max-width: none; }
    .hp-process-right { position: static; }
    .cd-hero__image { display: none; }
    .cd-services__grid { grid-template-columns: 1fr; }
    .cd-casestudy__right { display: none; }
    .cd-tabs__wrap { flex-direction: column; }
    .cd-tabs__nav { flex: none; }
    .cd-cta-banner { flex-direction: column; }
    .cd-cta-banner__img { flex: none; width: 100%; }
    .svc-contact-inner { grid-template-columns: 1fr; }
    .svc-contact-left h2 { font-size: 32px; white-space: normal; }
    .svc-contact-left { padding: 48px 32px; }
  }

  @media (max-width: 600px) {
    .cd-hero, .cd-services, .cd-casestudy,
    .cd-tabs, .cd-why, .hp-process-section, .cd-faq {
      padding-left: 20px;
      padding-right: 20px;
    }
    .cd-logos__inner { flex-direction: column; padding: 40px 20px 48px; }
    .cd-logos .brands-label {
      min-width: 0; width: 100%; padding: 0 0 28px; border-right: none; border-bottom: none;
      font-size: 22px; font-weight: 600; line-height: 1.3;
    }
    .cd-logos .brands-label br { display: none; }
    .cd-logos .brands-logos { margin: 0; padding: 0; width: 100%; justify-content: center; }
    .cd-logos .brands-logos img { width: 100%; max-width: 480px; max-height: none; height: auto; margin: 0 auto; }
    .container { padding: 0 20px; }
    .form-row { flex-direction: column; }
    .svc-contact { padding-left: 8px !important; padding-right: 8px !important; }
    .svc-contact-right {
      margin: 0 0 24px;
      padding: 28px 22px 24px;
      border-radius: 20px;
    }
    .svc-contact-right-label { font-size: 15px; margin: 0 0 14px; }
    .tc-text { font-size: 15px; line-height: 1.65; margin: 0 0 16px; }
    .tc-top { margin-bottom: 10px; }
  }
</style>

<script>
  // ─── TABS ───
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.querySelector(`.tab-panel[data-panel="${tab}"]`)?.classList.add('active');
    });
  });

  // ─── FAQ ───
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      answer.style.display = isOpen ? 'none' : 'block';
    });
  });

</script>
