---
import Layout from '../../layouts/Layout.astro';

const page = Number(Astro.url.searchParams.get('page') || 1);
const search = (Astro.url.searchParams.get('s') || '').trim();
const perPage = 10;

// All results posts (hardcoded from WP)
const allPosts = [
  { id: 40550, slug: 'making-property-listings-and-home-buying-simpler-with-a-well-organized-online-platform', title: 'Making Property Listings and Home Buying Simpler with a Well-Organized Online Platform', excerpt: 'When you are buying or selling a home, it\'s a huge step. The online tools you use should make it simpler, not more complicated. But if property listings are all...', date: 'May 27, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/05/young-woman-calculates-finances-at-home-office-2026-03-17-09-03-36-utc-1024x683.jpg', alt: 'Making Property Listings and Home Buying Simpler' },
  { id: 40547, slug: 'automating-aircraft-appraisal-with-a-smart-web-platform', title: 'Automating Aircraft Appraisal with a Smart Web Platform', excerpt: 'The aircraft appraisal process is multifaceted and requires a structured, accurate, and properly documented system. A comprehensive appraisal report should be generated for each aircraft assessed...', date: 'May 23, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/05/aircraft-mechanic-inspecting-engine-with-tablet-de-2026-03-26-08-38-07-utc-1024x683.jpg', alt: 'Automating Aircraft Appraisal with a Smart Web Platform' },
  { id: 40535, slug: 'combining-campaigns-products-and-communities-in-one-platform', title: 'Combining Campaigns, Products, and Communities in One Platform', excerpt: 'Crowdfunding operates best when people unite around one common purpose. However, vendors need a dedicated platform for showcasing their products...', date: 'May 17, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/05/crowdsourcing-concept-on-a-laptop-on-a-desk-2026-03-18-11-48-41-utc-1024x681.jpg', alt: 'Combining Campaigns, Products, and Communities in One Platform' },
  { id: 40521, slug: 'managing-the-complexities-of-vehicle-repossession-with-a-mobile-first-application', title: 'Managing the Complexities of Vehicle Repossession with a Mobile-First Application', excerpt: 'Working in the field of vehicle repossession management involves constant movement, coordination, and communication between different employees and management...', date: 'May 10, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/05/man-on-phone-with-car-on-tow-truck-2026-03-25-09-09-37-utc-1024x683.jpg', alt: 'Managing the Complexities of Vehicle Repossession' },
  { id: 40514, slug: 'making-insect-identification-faster-and-easier-with-ai', title: 'Making Insect Identification Faster and Easier with AI', excerpt: 'The identification of insect species has been a low paced and elaborate process. It takes expertise, visual comparisons, and time to search for references...', date: 'May 2, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/05/kenya-small-insects-macro-animals-fauna-plants-flo-2026-03-10-03-12-55-utc-1024x683.jpg', alt: 'Making Insect Identification Faster and Easier with AI' },
  { id: 40479, slug: 'transforming-collectible-grading-into-a-more-automated-and-efficient-process', title: 'Transforming Collectible Grading Into a More Automated and Efficient Process', excerpt: 'The grading of collectible items has traditionally been a highly manual process involving detailed evaluation, consistent judgment, and a great deal of time...', date: 'April 25, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/04/bijouterie-speciaist-taking-a-picture-of-working-t-2026-01-05-06-14-06-utc-1024x683.jpg', alt: 'Transforming Collectible Grading Into a More Automated and Efficient Process' },
  { id: 40471, slug: 'how-to-tame-complex-operations-with-a-custom-erp-solution', title: 'How to Tame Complex Operations with a Custom ERP Solution?', excerpt: 'It is often the case that running enterprise operations can get very chaotic as time goes by. As a result, companies may face the issue of having multiple different systems...', date: 'April 19, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/04/asian-business-adviser-meeting-to-analyze-and-disc-2026-01-07-00-50-52-utc-1024x656.jpg', alt: 'Tame Complex Operations with a Custom ERP Solution' },
  { id: 40460, slug: 'building-safer-workplaces-with-smarter-safety-training-and-compliance-tools', title: 'Building Safer Workplaces with Smarter Safety Training and Compliance Tools', excerpt: 'Safety of employees is not something you write down in a policy book. For companies it is something they have to think about every day...', date: 'April 8, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/04/middle-aged-caucasian-foreman-supervising-diverse-2026-03-05-11-50-35-utc-1024x683.jpg', alt: 'Building Safer Workplaces with Smarter Safety Training' },
  { id: 40452, slug: 'bringing-league-operations-under-one-roof', title: 'Bringing League Operations Under One Roof', excerpt: 'A sports league has to be managed beyond just games, fixtures and results. Behind every match, there are registrations, payments, schedules, messages...', date: 'March 27, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/03/soccer-coach-explaining-strategy-to-an-internation-2026-03-26-23-08-30-utc-1024x683.jpg', alt: 'Bringing League Operations Under One Roof' },
  { id: 40422, slug: 'modernizing-home-appraisals-with-a-mobile-workflow-system', title: 'Modernizing Home Appraisals with a Mobile Workflow System', excerpt: 'In real estate, home appraisals are a linchpin for buying, selling, and lending — yet for years, the process has been stuck in the past...', date: 'March 15, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/03/serious-professional-architect-design-engineer-wor-2026-01-09-09-37-59-utc-1024x740.jpg', alt: 'Modernizing Home Appraisals with a Mobile Workflow System' },
  { id: 40400, slug: 'helping-a-startup-launch-a-scalable-saas-platform', title: 'Helping a Startup Launch a Scalable SaaS Platform', excerpt: 'When a startup is preparing to launch its first SaaS product, the technical decisions made early on can define the entire trajectory of the business...', date: 'March 5, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/02/startup-team-working-on-laptop-2026-01-10-05-20-30-utc-1024x683.jpg', alt: 'Helping a Startup Launch a Scalable SaaS Platform' },
  { id: 40380, slug: 'streamlining-field-operations-with-a-custom-mobile-app', title: 'Streamlining Field Operations with a Custom Mobile App', excerpt: 'Field teams face unique challenges when it comes to coordination, reporting, and real-time communication. Off-the-shelf tools rarely fit these workflows perfectly...', date: 'February 22, 2026', img: 'https://demskigrdev.wpenginepowered.com/wp-content/uploads/2026/02/field-worker-with-tablet-2026-01-08-06-15-20-utc-1024x683.jpg', alt: 'Streamlining Field Operations with a Custom Mobile App' },
];

// Filter by search
const filtered = search
  ? allPosts.filter(p => p.title.toLowerCase().includes(search.toLowerCase()) || p.excerpt.toLowerCase().includes(search.toLowerCase()))
  : allPosts;

const totalResults = filtered.length;
const totalPages = Math.ceil(totalResults / perPage);
const posts = filtered.slice((page - 1) * perPage, page * perPage);
const searchParam = search ? `&s=${encodeURIComponent(search)}` : '';

// Sidebar data
let recentPosts = [];
try {
  const recentRes = await fetch('https://demskigroup.com/wp-json/wp/v2/posts?_embed&per_page=5', { signal: AbortSignal.timeout(8000) });
  if (recentRes.ok) {
    const data = await recentRes.json();
    if (Array.isArray(data)) recentPosts = data;
  }
} catch (e) { recentPosts = []; }

let categories = [];
try {
  const catRes = await fetch('https://demskigroup.com/wp-json/wp/v2/categories?per_page=20', { signal: AbortSignal.timeout(8000) });
  if (catRes.ok) {
    const data = await catRes.json();
    if (Array.isArray(data)) categories = data;
  }
} catch (e) { categories = []; }

let tags = [];
try {
  const tagRes = await fetch('https://demskigroup.com/wp-json/wp/v2/tags?per_page=100&orderby=name&order=asc', { signal: AbortSignal.timeout(8000) });
  if (tagRes.ok) {
    const data = await tagRes.json();
    if (Array.isArray(data)) tags = data;
  }
} catch (e) { tags = []; }
---

<Layout
  title="Results | The Demski Group"
  description="See the real-world results The Demski Group has delivered — from SaaS platforms and mobile apps to ERP systems and AI-powered tools. 600+ successful custom software projects."
>

  <style slot="head">
    .hero { text-align: center; padding: 150px 20px; background: #faf9f5; }
    .hero h1 { font-size: 74px; font-weight: 800; color: #0A0000; line-height: 1.1; letter-spacing: 0.7px; margin: 0px 40px 20px; font-family: 'Outfit', sans-serif; }
    .breadcrumb { font-size: 18px; font-family: 'Outfit', sans-serif; color: #000; margin-top: 30px; }
    .breadcrumb a { color: #000; font-family: 'Outfit', sans-serif; font-size: 18px; text-decoration: none; }
    .top-search-wrap { width: 100%; margin: 40px 0 0; padding: 0 20px; display: flex; justify-content: center; box-sizing: border-box; }
    .top-search-form { width: 100%; max-width: 720px; margin: 0 auto; }
    .main-wrap { max-width: 1280px; margin: 40px auto 50px; padding: 0 60px; display: flex; flex-direction: row; gap: 40px; align-items: flex-start; }
    .posts-col { width: 65%; min-width: 0; flex: none; }
    .search-results-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; font-size: 18px; color: #0A0000; font-family: 'Outfit', sans-serif; }
    .search-results-header .clear-search { color: #003087; text-decoration: underline; font-weight: 600; }
    .search-results-header .clear-search:hover { color: #001f5c; }
    .no-results { padding: 40px 0; font-size: 18px; color: #555; font-family: 'Outfit', sans-serif; }
    .post-card { background: white; margin-bottom: 30px; overflow: hidden; border: 1px solid #ebebeb; border-radius: 12px; }
    .post-card img { width: 100%; height: 450px; object-fit: cover; display: block; max-width: 100%; }
    .post-info { padding: 20px 22px 22px; }
    .post-meta-row { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
    .post-date-txt { font-size: 16px; color: #000; font-family: 'Outfit', sans-serif; }
    .post-card h2 { font-size: 30px; font-weight: 700; margin-bottom: 20px; line-height: 1.4; }
    .post-card h2 a { color: #0A0000; text-decoration: none; }
    .post-card h2 a:hover { color: #005cb9; }
    .post-excerpt { font-size: 18px; color: #555; line-height: 1.6; margin-bottom: 20px; }
    .read-more-link { display: inline-flex; align-items: center; gap: 7px; font-size: 18px; color: #003087; font-weight: 600; text-decoration: none; }
    .read-more-link:hover { color: #003087; }
    .pagination { display: flex; justify-content: center; align-items: center; gap: 18px; margin: 40px 0; }
    .pagination a, .pagination span { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 50%; font-size: 18px; font-weight: 600; text-decoration: none; color: #333; background: white; border: 1.5px solid #ccc; transition: all 0.2s; }
    .pagination .dots { border: none; background: none; color: #555; width: auto; font-size: 20px; }
    .pagination a:hover { background: #0A0000; color: white; border-color: #0A0000; }
    .pagination span.active { background: #0A0000; color: white; border-color: #0A0000; }
    .pagination-next { border: none !important; background: none !important; box-shadow: none !important; font-size: 22px !important; color: #333 !important; width: auto !important; height: auto !important; padding: 0 8px !important; }
    .sidebar-col { width: 32%; min-width: 0; flex: none; }
    .sb-box { background: #faf9f5; border: 1px solid #ebebeb; border-radius: 4px; padding: 20px; margin-bottom: 24px; }
    .sb-box h3 { font-size: 18px; font-weight: 700; color: #0A0000; display: inline-block; border-bottom: 2px solid #0A0000; padding-bottom: 8px; margin-bottom: 14px; }
    .search-form { display: flex; align-items: center; border: 1.5px solid #e0e0e0; border-radius: 50px; overflow: hidden; background: #fff; padding: 6px 18px; gap: 8px; }
    .search-form .search-icon { display: flex; align-items: center; flex-shrink: 0; }
    .search-form input { border: none; outline: none; padding: 8px 0; font-size: 16px; width: 100%; font-family: 'Outfit', sans-serif; background: transparent; color: #333; }
    .search-form button { display: none; }
    .recent-ul { list-style: none; padding: 0; margin: 0; }
    .recent-ul li { padding: 15px 0; border-bottom: 1px solid #f5f5f5; }
    .recent-ul li:last-child { border-bottom: none; }
    .recent-ul li a { font-size: 18px; color: #333; text-decoration: none; line-height: 1.5; }
    .recent-ul li a:hover { color: #003087; }
    .cat-ul { list-style: none; padding: 0; margin: 0; }
    .cat-ul li { display: flex; justify-content: space-between; padding: 15px 0; border-bottom: 1px solid #ccc; font-size: 18px; }
    .cat-ul li:last-child { border-bottom: none; }
    .cat-ul li a { color: #000; text-decoration: none; }
    .cat-ul li a:hover { color: #003087; }
    .cat-ul li span { color: #000; }
    .tech-cloud { display: flex; flex-wrap: wrap; gap: 10px; }
    .tech-link { font-size: 17px; color: #333; background: #e2e2e2; padding: 9px 20px; border-radius: 20px; text-decoration: none; }
    .tech-link:hover { background: #000; color: white; }
    @media (max-width: 768px) {
      .hero { padding: 50px 20px; }
      .hero h1 { font-size: 36px; }
      .top-search-wrap { padding: 0 15px; margin-top: 25px; }
      .main-wrap { flex-direction: column !important; padding: 0 15px; margin: 25px auto 30px; gap: 20px; }
      .posts-col, .sidebar-col { width: 100% !important; }
      .post-card img { height: 200px; }
      .post-card h2 { font-size: 16px; }
    }
  </style>

  <!-- Hero -->
  <div class="hero">
    <h1>Our Results</h1>
    <div class="breadcrumb">
      <a href="/">Home</a> &nbsp;&nbsp;&nbsp;›&nbsp;&nbsp;&nbsp; Results
    </div>
  </div>

  <!-- Top Search -->
  <div class="top-search-wrap">
    <form class="search-form top-search-form" action="/results/" method="get">
      <span class="search-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
      </span>
      <input type="search" name="s" value={search} placeholder="Search results..." aria-label="Search" />
      <button type="submit" aria-label="Submit search"></button>
    </form>
  </div>

  <!-- Main content -->
  <div class="main-wrap">
    <div class="posts-col">

      {search && (
        <div class="search-results-header">
          <span><strong>{totalResults}</strong> results for <strong>"{search}"</strong></span>
          <a href="/results/" class="clear-search">Clear search</a>
        </div>
      )}

      {search && posts.length === 0 && (
        <div class="no-results">No results found matching "{search}".</div>
      )}

      {posts.map((post, i) => (
        <div class="post-card">
          <img src={post.img} alt={post.alt} loading={i === 0 ? 'eager' : 'lazy'} />
          <div class="post-info">
            <div class="post-meta-row">
              <span class="post-date-txt">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:5px;margin-bottom:2px"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {post.date}
              </span>
            </div>
            <h2><a href={`/results/${post.slug}/`}>{post.title}</a></h2>
            <p class="post-excerpt">{post.excerpt}</p>
            <a class="read-more-link" href={`/results/${post.slug}/`}>
              Read More
              <svg width="14" height="12" viewBox="0 0 14 12" fill="none">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M0 6C0 5.77271 0.0902897 5.55473 0.251006 5.39402C0.411723 5.2333 0.629701 5.14301 0.856988 5.14301H10.7861L7.10615 1.46482C6.94523 1.3039 6.85482 1.08565 6.85482 0.858071C6.85482 0.630497 6.94523 0.412243 7.10615 0.251323C7.26707 0.0904038 7.48532 0 7.71289 0C7.94047 0 8.15872 0.0904038 8.31964 0.251323L13.4616 5.39325C13.5414 5.47286 13.6047 5.56743 13.6479 5.67154C13.6911 5.77566 13.7133 5.88728 13.7133 6C13.7133 6.11272 13.6911 6.22434 13.6479 6.32845C13.6047 6.43257 13.5414 6.52714 13.4616 6.60675L8.31964 11.7487C8.15872 11.9096 7.94047 12 7.71289 12C7.48532 12 7.26707 11.9096 7.10615 11.7487C6.94523 11.5878 6.85482 11.3695 6.85482 11.1419C6.85482 10.9144 6.94523 10.6961 7.10615 10.5352L10.7861 6.85699H0.856988C0.629701 6.85699 0.411723 6.7667 0.251006 6.60598C0.0902897 6.44527 0 6.22729 0 6Z" fill="#003087"/>
              </svg>
            </a>
          </div>
        </div>
      ))}

      {totalPages > 1 && (
        <div class="pagination">
          {page === 1 ? <span class="active">1</span> : <a href={`?page=1${searchParam}`}>1</a>}
          {totalPages >= 2 && (page === 2 ? <span class="active">2</span> : <a href={`?page=2${searchParam}`}>2</a>)}
          {totalPages >= 3 && (page === 3 ? <span class="active">3</span> : <a href={`?page=3${searchParam}`}>3</a>)}
          {totalPages > 4 && <span class="dots">...</span>}
          {totalPages > 3 && (page === totalPages ? <span class="active">{totalPages}</span> : <a href={`?page=${totalPages}${searchParam}`}>{totalPages}</a>)}
          {page < totalPages && <a href={`?page=${page + 1}${searchParam}`} class="pagination-next">›</a>}
        </div>
      )}

    </div>

    <!-- Sidebar -->
    <div class="sidebar-col">
      <div class="sb-box">
        <h3>Recent Posts</h3>
        <ul class="recent-ul">
          {recentPosts.map((p: any) => (
            <li><a href={`/blog/${p.slug}`}>{p.title.rendered}</a></li>
          ))}
        </ul>
      </div>
      <div class="sb-box">
        <h3>Blog Categories</h3>
        <ul class="cat-ul">
          {categories.filter((c: any) => c.count > 0).map((cat: any) => (
            <li>
              <a href={`/category/${cat.slug}`}>{cat.name}</a>
              <span>({cat.count})</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="sb-box">
        <h3>Technologies</h3>
        <div class="tech-cloud">
          {tags.map((t: any) => (
            <a href={`/tag/${t.slug}/`} class="tech-link">{t.name}</a>
          ))}
        </div>
      </div>
    </div>
  </div>

</Layout>