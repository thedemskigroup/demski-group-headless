---

<Layout title="Results Archive - The Demski Group" description="Explore case studies and project results from The Demski Group — custom software development success stories across industries." pageClass="results-archive-page">

  <style slot="head">
    .results-archive-page { font-family:'Outfit',sans-serif; color:#282828; }

    /* breadcrumb banner */
    .blog-breadcrumb {
      position: relative;
      background-color: #001629;
      padding: 70px 0 60px;
      text-align: center;
    }
    .blog-breadcrumb .overlay {
      position: absolute; inset: 0;
      background: rgba(0,0,0,0.35);
    }
    .blog-breadcrumb .container { position: relative; z-index: 1; }
    .blog-breadcrumb h1.post__title {
      color: #fff;
      font-size: clamp(28px, 3.5vw, 42px);
      font-weight: 700;
      margin: 0 0 12px;
      font-family: 'Outfit', sans-serif;
    }
    .breadcrumbs { font-size: 14px; color: rgba(255,255,255,0.7); }
    .breadcrumbs a { color: rgba(255,255,255,0.7); text-decoration: none; }
    .breadcrumbs a:hover { color: #fff; }

    /* layout */
    .content-block { padding: 60px 0 80px; background: #fff; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    .blog-content-row { display: flex; gap: 40px; align-items: flex-start; }
    .post_col { flex: 0 0 66.666%; max-width: 66.666%; }
    .blog-sidebar-col { flex: 0 0 33.333%; max-width: 33.333%; }
    .posts-row { display: flex; flex-direction: column; gap: 0; }

    /* single post item */
    .single-post-item.one-column { margin-bottom: 50px; }
    .post-thumbnail { overflow: hidden; border-radius: 8px; margin-bottom: 20px; }
    .post-thumbnail img {
      width: 100%; height: 280px;
      object-fit: cover; object-position: center;
      display: block;
      transition: transform 0.4s ease;
    }
    .single-post-item:hover .post-thumbnail img { transform: scale(1.04); }
    .entry-title {
      font-size: 22px; font-weight: 600; line-height: 1.35;
      margin: 0 0 12px;
      font-family: 'Outfit', sans-serif;
      color: #282828;
    }
    .entry-title a { color: inherit; text-decoration: none; }
    .entry-title a:hover { color: #005cb9; }
    .post-content p { color: #555; font-size: 15px; line-height: 1.65; margin: 0 0 14px; }
    .post-read-more a {
      display: inline-flex; align-items: center; gap: 8px;
      color: #005cb9; font-size: 15px; font-weight: 600;
      text-decoration: none; transition: gap 0.2s;
    }
    .post-read-more a:hover { gap: 12px; }
    .post-read-more svg { flex-shrink: 0; }
    hr.post-divider { border: none; border-top: 1px solid #e8e8e8; margin: 0 0 50px; }

    /* pagination */
    .masco-navigation { margin-top: 20px; }
    .nav-links { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
    .page-numbers {
      display: inline-flex; align-items: center; justify-content: center;
      width: 38px; height: 38px; border-radius: 6px;
      font-size: 15px; font-weight: 500; text-decoration: none;
      color: #282828; background: #f5f5f5; transition: all 0.2s;
    }
    .page-numbers.current { background: #005cb9; color: #fff; }
    .page-numbers:not(.current):hover { background: #e0e0e0; }
    .page-numbers.next { width: auto; padding: 0 14px; }

    /* sidebar */
    .widget-area { position: sticky; top: 100px; }
    .widget { margin-bottom: 36px; }
    .wp-block-heading {
      font-size: 18px; font-weight: 700; color: #1b1c1d;
      margin: 0 0 16px; padding-bottom: 10px;
      border-bottom: 2px solid #005cb9;
      font-family: 'Outfit', sans-serif;
    }

    /* search widget */
    .wp-block-search { display: flex; gap: 0; }
    .wp-block-search__label { display: none; }
    .wp-block-search__inside-wrapper { display: flex; width: 100%; }
    .wp-block-search__input {
      flex: 1; padding: 10px 14px;
      border: 1px solid #ddd; border-right: none;
      border-radius: 6px 0 0 6px;
      font-size: 14px; font-family: 'Outfit', sans-serif;
      outline: none; color: #282828;
    }
    .wp-block-search__input:focus { border-color: #005cb9; }
    .wp-block-search__button {
      padding: 10px 16px; background: #005cb9; color: #fff;
      border: none; border-radius: 0 6px 6px 0;
      font-size: 14px; cursor: pointer; font-family: 'Outfit', sans-serif;
      font-weight: 500; white-space: nowrap;
    }
    .wp-block-search__button:hover { background: #0047a3; }

    /* recent posts */
    .wp-block-latest-posts__list { list-style: none; margin: 0; padding: 0; }
    .wp-block-latest-posts__list li { margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid #f0f0f0; }
    .wp-block-latest-posts__list li:last-child { border-bottom: none; margin-bottom: 0; }
    .wp-block-latest-posts__post-title {
      color: #282828; text-decoration: none; font-size: 14px; line-height: 1.5;
    }
    .wp-block-latest-posts__post-title:hover { color: #005cb9; }

    /* categories */
    .wp-block-categories-list { list-style: none; margin: 0; padding: 0; }
    .wp-block-categories-list li { margin-bottom: 8px; }
    .wp-block-categories-list a { color: #282828; text-decoration: none; font-size: 14px; }
    .wp-block-categories-list a:hover { color: #005cb9; }

    /* tag cloud */
    .wp-block-tag-cloud { display: flex; flex-wrap: wrap; gap: 8px; }
    .tag-cloud-link {
      display: inline-block;
      padding: 4px 10px; border-radius: 4px;
      background: #f5f5f5; color: #444;
      text-decoration: none; font-size: 12px !important;
      transition: background 0.2s, color 0.2s;
    }
    .tag-cloud-link:hover { background: #005cb9; color: #fff; }

    /* responsive */
    @media (max-width: 992px) {
      .blog-content-row { flex-direction: column; }
      .post_col, .blog-sidebar-col { flex: 0 0 100%; max-width: 100%; }
      .widget-area { position: static; }
    }
    @media (max-width: 600px) {
      .post-thumbnail img { height: 200px; }
      .entry-title { font-size: 18px; }
    }
  </style>

  <!-- Breadcrumb Banner -->
  <div class="blog-breadcrumb" style="background-image: url()">
    <div class="overlay"></div>
    <div class="container">
      <div class="row text-center justify-content-center">
        <div class="col-lg-8">
          <h1 class="post__title">Results</h1>
          <div class="breadcrumbs">
            <span><a href="/" class="home"><span>Home</span></a></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="content-block">
    <div class="container">
      <div class="row blog-content-row">

        <!-- Main Posts Column -->
        <div class="col-lg-8 col-md-12 one-column post_col">
          <div class="row posts-row">
            {posts.map((post, i) => (
              <div class="col-12">
                <div id={`post-${post.id}`} class="single-post-item one-column">
                  <div class="post-thumbnail-wrapper">
                    <div class="post-thumbnail">
                      <img
                        src={post.img}
                        alt={post.alt}
                        width="1024" height="683"
                        loading={i === 0 ? 'eager' : 'lazy'}
                      />
                    </div>
                  </div>
                  <div class="post-content">
                    <h2 class="entry-title">
                      <a href={`/results/${post.slug}/`}>{post.title}</a>
                    </h2>
                    <p>{post.excerpt}</p>
                    <div class="post-read-more">
                      <a href={`/results/${post.slug}/`}>
                        Read More
                        <svg width="14" height="12" viewBox="0 0 14 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M0 6C0 5.77271 0.0902897 5.55473 0.251006 5.39402C0.411723 5.2333 0.629701 5.14301 0.856988 5.14301H10.7861L7.10615 1.46482C6.94523 1.3039 6.85482 1.08565 6.85482 0.858071C6.85482 0.630497 6.94523 0.412243 7.10615 0.251323C7.26707 0.0904038 7.48532 0 7.71289 0C7.94047 0 8.15872 0.0904038 8.31964 0.251323L13.4616 5.39325C13.5414 5.47286 13.6047 5.56743 13.6479 5.67154C13.6911 5.77566 13.7133 5.88728 13.7133 6C13.7133 6.11272 13.6911 6.22434 13.6479 6.32845C13.6047 6.43257 13.5414 6.52714 13.4616 6.60675L8.31964 11.7487C8.15872 11.9096 7.94047 12 7.71289 12C7.48532 12 7.26707 11.9096 7.10615 11.7487C6.94523 11.5878 6.85482 11.3695 6.85482 11.1419C6.85482 10.9144 6.94523 10.6961 7.10615 10.5352L10.7861 6.85699H0.856988C0.629701 6.85699 0.411723 6.7667 0.251006 6.60598C0.0902897 6.44527 0 6.22729 0 6Z" fill="#5B7486" />
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
                {i < posts.length - 1 && <hr class="post-divider" />}
              </div>
            ))}
          </div>

          <!-- Pagination -->
          <div class="row">
            <div class="col-12">
              <div class="masco-navigation">
                <nav class="navigation pagination" aria-label="Posts pagination">
                  <h2 class="screen-reader-text">Posts pagination</h2>
                  <div class="nav-links">
                    <span aria-current="page" class="page-numbers current">1</span>
                    <a class="page-numbers" href="/results/page/2/">2</a>
                    <a class="page-numbers" href="/results/page/3/">3</a>
                    <a class="page-numbers" href="/results/page/4/">4</a>
                    <a class="page-numbers next" href="/results/page/2/">
                      <i class="fa fa-angle-right"></i>
                    </a>
                  </div>
                </nav>
              </div>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4 col-md-12 right-sidebar blog-sidebar-col">
          <aside id="secondary" class="widget-area">

            <!-- Search -->
            <section class="widget widget_block widget_search">
              <form role="search" method="get" action="/" class="wp-block-search">
                <label class="wp-block-search__label" for="search-1">Search</label>
                <div class="wp-block-search__inside-wrapper">
                  <input class="wp-block-search__input" id="search-1" placeholder="" type="search" name="s" required />
                  <button aria-label="Search" class="wp-block-search__button" type="submit">Search</button>
                </div>
              </form>
            </section>

            <!-- Recent Posts -->
            <section class="widget widget_block">
              <div class="wp-block-group">
                <div class="wp-block-group__inner-container">
                  <h2 class="wp-block-heading">Recent Posts</h2>
                  <ul class="wp-block-latest-posts__list">
                    {recentPosts.map(p => (
                      <li>
                        <a class="wp-block-latest-posts__post-title" href={`/${p.slug}/`}>{p.title}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </section>

            <!-- Search 2 -->
            <section class="widget widget_block widget_search">
              <form role="search" method="get" action="/" class="wp-block-search">
                <label class="wp-block-search__label" for="search-2">Search</label>
                <div class="wp-block-search__inside-wrapper">
                  <input class="wp-block-search__input" id="search-2" placeholder="Type to search..." type="search" name="s" required />
                  <button aria-label="Search" class="wp-block-search__button" type="submit">Search</button>
                </div>
              </form>
            </section>

            <!-- Categories -->
            <section class="widget widget_block">
              <div class="wp-block-group">
                <div class="wp-block-group__inner-container">
                  <h2 class="wp-block-heading">Blog Categories</h2>
                  <ul class="wp-block-categories-list">
                    {categories.map(cat => (
                      <li class="cat-item">
                        <a href={`/category/${cat.slug}/`}>{cat.name}</a> ({cat.count})
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </section>

            <!-- Tag Cloud -->
            <section class="widget widget_block">
              <div class="wp-block-group">
                <div class="wp-block-group__inner-container">
                  <h2 class="wp-block-heading">Technologies</h2>
                  <p class="wp-block-tag-cloud">
                    {technologies.map(tag => (
                      <a href={`/technology/${tag.toLowerCase().replace(/\s+/g,'-').replace(/\./g,'')}/`} class="tag-cloud-link">{tag}</a>
                    ))}
                  </p>
                </div>
              </div>
            </section>

          </aside>
        </div>

      </div>
    </div>
  </div>

</Layout>