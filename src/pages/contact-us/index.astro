---
import Layout from '../../layouts/Layout.astro';

function cleanT(str: string) {
  return (str || '').replace(/&amp;/g,'&').replace(/&#8217;/g,"'").replace(/&#8216;/g,"'")
    .replace(/&#8220;/g,'"').replace(/&#8221;/g,'"').replace(/&#8230;/g,'…')
    .replace(/<[^>]*>/g,'').trim();
}
function normalizeLink(link: string, slug: string) {
  return (link || '').replace('https://demskigrdev.wpenginepowered.com','').replace('https://demskigroup.com','')
    || `/our-clients/${slug}/`;
}

let testimonials: Array<{logo:string;logoAlt:string;quote:string;author:string;role:string;link:string}> = [];

const WP_REVIEW_URLS = [
  'https://demskigroup.com/wp-json/wp/v2/reviews?_embed&per_page=100',
  'https://demskigrdev.wpenginepowered.com/wp-json/wp/v2/reviews?_embed&per_page=100',
];
for (const url of WP_REVIEW_URLS) {
  try {
    const res = await fetch(url, { signal: AbortSignal.timeout(8000) });
    if (!res.ok) continue;
    const data = await res.json();
    if (!Array.isArray(data) || !data.length) continue;
    testimonials = data.map((item: any) => ({
      logo:    item._embedded?.['wp:featuredmedia']?.[0]?.source_url || '',
      logoAlt: cleanT(item.title?.rendered),
      quote:   cleanT(item.acf?.testimonial || item.acf?.quote || item.acf?.review || item.content?.rendered || ''),
      author:  cleanT(item.acf?.author_name || item.acf?.name || item.title?.rendered),
      role:    cleanT(item.acf?.author_role || item.acf?.position || item.acf?.role || ''),
      link:    normalizeLink(item.acf?.case_study_url || item.link, item.slug),
    }));
    break;
  } catch(_) { continue; }
}

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=7200');
const offices = [
  { name: 'The Demski Group', address: '237 Delaware Ave #7', cityState: 'Olean, NY 14760', phone: '716-687-0840' },
  { address: '250 East 5th Street 15th floor', cityState: 'Cincinnati, OH 45202', phone: '513-643-8442' },
  { address: '1001 S. Main St. #8131', cityState: 'Kalispell, MT 59901', phone: '406-645-5084' },
];
