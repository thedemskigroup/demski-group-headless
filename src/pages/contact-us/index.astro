<script is:inline>
(function () {
  const slider = document.getElementById('tslider');
  const btnNext = document.getElementById('tslider-next');
  const btnPrev = document.getElementById('tslider-prev');
  if (!slider) return;

  const cards = Array.from(slider.querySelectorAll('.testimonial-card-new'));
  const gap = 14;

  cards.forEach(card => {
    const clone = card.cloneNode(true);
    clone.setAttribute('aria-hidden', 'true');
    slider.appendChild(clone);
  });

  cards.slice().reverse().forEach(card => {
    const clone = card.cloneNode(true);
    clone.setAttribute('aria-hidden', 'true');
    slider.prepend(clone);
  });

  function cardWidth() {
    return slider.querySelector('.testimonial-card-new').offsetWidth + gap;
  }

  const jumpToReal = () => {
    const all = slider.querySelectorAll('.testimonial-card-new');
    const target = all[cards.length];
    if (target) {
      const sRect = slider.getBoundingClientRect();
      const tRect = target.getBoundingClientRect();
      const padL = parseFloat(getComputedStyle(slider).paddingLeft) || 0;
      slider.scrollLeft += (tRect.left - sRect.left) - padL;
    } else {
      slider.scrollLeft = cardWidth() * cards.length;
    }
  };

  jumpToReal();
  requestAnimationFrame(() => requestAnimationFrame(jumpToReal));
  window.addEventListener('load', jumpToReal, { once: true });

  function alignedScrollOf(card) {
    return card.offsetLeft - slider.offsetLeft;
  }

  function nearestCardIndex() {
    const all = slider.querySelectorAll('.testimonial-card-new');
    let bestIdx = 0, bestDist = Infinity;
    for (let i = 0; i < all.length; i++) {
      const d = Math.abs(alignedScrollOf(all[i]) - slider.scrollLeft);
      if (d < bestDist) { bestDist = d; bestIdx = i; }
    }
    return bestIdx;
  }

  function goTo(idx, behavior) {
    const all = slider.querySelectorAll('.testimonial-card-new');
    const target = all[idx];
    if (!target) return;
    slider.scrollTo({ left: alignedScrollOf(target), behavior: behavior });
  }

  function next() {
    const idx = nearestCardIndex();
    goTo(idx + 1, 'smooth');
    setTimeout(() => {
      const cur = nearestCardIndex();
      if (cur >= cards.length * 2) {
        goTo(cur - cards.length, 'auto');
      }
    }, 500);
  }

  function prev() {
    const idx = nearestCardIndex();
    goTo(idx - 1, 'smooth');
    setTimeout(() => {
      const cur = nearestCardIndex();
      if (cur < cards.length) {
        goTo(cur + cards.length, 'auto');
      }
    }, 500);
  }

  btnNext && btnNext.addEventListener('click', next);
  btnPrev && btnPrev.addEventListener('click', prev);
})();
</script>

<script is:inline define:vars={{ serviceId: 'service_f4tf0yn', leadTemplate: 'template_c6hi8ir', confirmTemplate: 'template_7kz7hgj' }}>
(function () {
  const form = document.getElementById('cu-form');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    const name = form.querySelector('input[name="name"]').value.trim();
    const email = form.querySelector('input[name="email"]').value.trim();
    const phone = form.querySelector('input[name="phone"]').value.trim();
    const company = form.querySelector('input[name="company"]').value.trim();
    const website = form.querySelector('input[name="website"]').value.trim();
    const message = form.querySelector('textarea[name="message"]').value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      const emailInput = form.querySelector('input[name="email"]');
      emailInput.reportValidity();
      return;
    }
    if (typeof emailjs === 'undefined') {
      window.location.href = '/contact-us/?' + new URLSearchParams({ name, email, phone, company, website, message }).toString();
      return;
    }
    const submitBtn = form.querySelector('.cu-form-submit');
    if (submitBtn) submitBtn.disabled = true;
    const params = { user_name: name, user_email: email, user_phone: phone, user_company: company, user_website: website, user_message: message, cta_choice: 'Schedule a Free Consultation' };
    emailjs.send(serviceId, leadTemplate, params).catch(() => {});
    emailjs.send(serviceId, confirmTemplate, { user_name: name, user_email: email, cta_choice: 'Schedule a Free Consultation' }).catch(() => {});
    form.innerHTML = '<p style="font-family:\'Outfit\',sans-serif;color:#1a1a1a;font-size:17px;">Thanks! One of our experts will reach out shortly.</p>';
  });
})();
</script>
