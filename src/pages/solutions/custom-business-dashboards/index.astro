---
import Layout from '../../../layouts/Layout.astro';

const assetBase = '/solutions/sales-lead-tracking-tools';

const strategicBenefits = [
  ['fa-table-cells-large', 'Real-Time Data Visibility', 'Stop waiting for weekly reports. Custom dashboards surface live KPIs, trends, and operational metrics the moment they change — so your team always operates on current information.'],
  ['fa-square-check', 'Faster, Smarter Decisions', 'When the right data is in front of the right people at the right time, decision-making accelerates. Replace gut-feel choices with evidence-backed actions tied directly to your goals.'],
  ['fa-layer-group', 'Unified Data Across Systems', 'Most businesses run on 5–10 disconnected tools. We pull data from your CRM, ERP, marketing platforms, finance systems, and more into a single, coherent view.'],
  ['fa-laptop-code', 'Role-Based Dashboards', 'Executives need high-level trends. Operations teams need granular workflow data. Sales managers need pipeline metrics. We build dashboards that show each person exactly what they need.'],
  ['fa-shield-halved', 'Accountability & Performance Tracking', 'Build dashboards that track team and individual performance, monitor SLAs, and flag issues before they escalate — turning accountability into a system, not a conversation.']
];

const services = [
  ['fa-chart-line', 'Executive & KPI Dashboards', 'High-level dashboards built for leadership — revenue trends, growth metrics, departmental performance summaries, and forecasting all in one clean interface.'],
  ['fa-gears', 'Operational Dashboards', 'Monitor live workflows, task queues, production status, and team workloads. Spot bottlenecks instantly and keep operations running at full capacity.'],
  ['fa-chart-bar', 'Sales & Pipeline Dashboards', 'Track lead volume, deal stages, conversion rates, rep activity, and revenue forecasts. Give your sales team total clarity on where to focus their energy.'],
  ['fa-dollar-sign', 'Financial Dashboards', 'Real-time P&L tracking, budget vs. actuals, cash flow visualization, and expense monitoring — all connected directly to your accounting and ERP systems.'],
  ['fa-bullseye', 'Marketing Performance Dashboards', 'Consolidate campaign data from Google Ads, Meta, email platforms, and SEO tools into one dashboard showing true ROI across all channels.'],
  ['fa-database', 'Custom Data Warehouse & Reporting', 'For complex data needs, we build lightweight data warehouses or ETL pipelines that aggregate, clean, and structure your data before surfacing it in your dashboard.']
];

const coreServices = [
  ['fa-table-cells-large', 'Discovery & Data Mapping', 'We audit your existing data sources, identify what metrics matter most, and design a dashboard architecture that answers your most important business questions.'],
  ['fa-square-check', 'Data Integration & Pipeline Setup', 'We connect your tools — CRMs, ERPs, databases, APIs, spreadsheets — and build reliable pipelines that keep your dashboard populated with accurate, current data.'],
  ['fa-layer-group', 'Custom Dashboard Design & Build', 'No off-the-shelf templates. We design and develop dashboards that match your brand, your workflows, and your data — built to be fast, intuitive, and actionable.'],
  ['fa-laptop-code', 'Alerts, Automation & Anomaly Detection', `We configure threshold alerts, automated reports, and anomaly detection so you're always notified when something important changes — without having to check manually.`],
  ['fa-shield-halved', 'Training, Documentation & Support', 'We hand over fully documented systems, train your team, and offer ongoing support to iterate and expand your dashboards as your business grows.']
];

const contactTestimonials = [
  { quote: "The Demski Group is great to work with! They inherited a mess with our platform and have been able to fix the bugs and make the platform more user friendly. They are also very professional and timely as well as a pleasure to work with! We have worked with Andrew Demski for all of our IT needs.", name: "Delaine Mast", role: "CEO", link: "/our-clients/impact-team-tennis/" },
  { quote: "We spoke to a few different companies as we set out to find someone to create a website/database application to augment our desktop software. We chose The Demski Group in part because we found them very easy to talk to in our interview. That first impression stuck as we have a great relationship with them now.", name: "Mickey Rowe", role: "Manager", link: "/our-clients/biopac/" },
  { quote: "Code quality was very good and done in a fast, efficient manner. We are pleased with the excellent job from The Demski Group. The team was able to provide high-quality services throughout the project. They produced the deliverables in a timely manner and within budget.", name: "Thariq Kara", role: "CEO", link: "/our-clients/nu-borders/" }
];

const cases = [
  { tag: 'Biotechnology', name: 'BIOPAC Systems, Inc.', description: 'The Demski Group successfully delivered a scalable and efficient web application for Biopac, enabling users to perform and track scientific studies online.', image: 'Biopac-white.png', tone: 'dark', link: '/our-clients/biopac' },
  { tag: 'Sports', name: 'Impact Team Tennis', description: '', image: 'ImpactTennis-e1744403805766.png', tone: 'green', link: '/our-clients/impact-team-tennis/' },
  { tag: 'Health & Wellness', name: 'Prefusion Health', description: '', image: 'PrefusionHealth.png', tone: 'purple', link: '/our-clients/prefusion-health/' },
  { tag: 'Insurance', name: 'Adaptrack', description: '', image: 'ADAPTRACK.png', tone: 'rose', link: '/our-clients/' },
  { tag: 'Retail', name: 'Zoomifi', description: '', image: 'Zoomifi-2-e1744403389524.png', tone: 'pink', link: '/our-clients/zoomifi/' },
  { tag: 'Real Estate', name: 'Property Gauge', description: '', image: 'PropertyGauge.png', tone: 'sky', link: '/our-clients/property-gauge/' },
  { tag: 'Energy & Utilities', name: 'Corning', description: '', image: 'Corning-e1744401647484.png', tone: 'yellow', link: '/our-clients/corning-glass/' },
  { tag: 'Logistics', name: 'Bite', description: '', image: 'Bite-e1746208787498.png', tone: 'violet', link: '/our-clients/bite/' },
  { tag: 'Manufacturing', name: 'Saputo', description: '', image: 'Saputo.png', tone: 'sand', link: '/our-clients/' }
];
---

<Layout
  title="Custom Business Dashboards | Real-Time Data Visibility"
  description="Turn your business data into clear, actionable insights with custom dashboards built by the Demski Group. Connect every data source. Track every KPI."
  pageClass="cbd-page-class"
>
  <link rel="preload" href="https://demskigrdev.wpenginepowered.com/wp-content/uploads/2025/09/female-freelancer-working-with-statistics-charts-o-2025-02-17-23-29-14-utc-scaled.jpg" as="image" slot="head" />

  <style slot="head">
    .cbd-page-class {
      --blue: #005cb9; --orange: #f09300; --ink: #282828; --muted: #f0f0f0; --navy: #001629; --max: 1850px;
      font-family: 'Outfit', sans-serif; color: var(--ink);
    }
    .cbd-page-class .top-bar { background: var(--blue); min-height: 34px; padding: 6px 20px; font-size: 16px; line-height: 1; font-weight: 500; }
    .cbd-page-class header { box-shadow: none; padding: 13px 176px 11px 50px; align-items: center; }
    .cbd-page-class .logo img { height: 42px; }
    .cbd-page-class nav { gap: 28px; }
    .cbd-page-class nav a, .cbd-page-class .nav-trigger { font-size: 15px; font-weight: 500; }
    .cbd-page-class .nav-dropdown-menu { width: 320px; top: calc(100% + 14px); box-shadow: 0 4px 18px rgba(0,0,0,0.18); }
    .cbd-page-class .nav-dropdown-menu a { padding: 12px 16px; font-size: 14px; font-weight: 400; }
    .cbd-page-class .btn-cta, .cbd-page-class .footer-cta-btn { background: var(--orange) !important; border-color: var(--orange); border-radius: 6px; font-size: 15px !important; padding: 11px 18px !important; }

    .cbd-page { overflow-x: clip; }
    .cbd-section { max-width: var(--max); margin: 0 auto; padding: 60px 50px; }

    .eyebrow { display: inline-flex; align-items: center; gap: 10px; color: var(--blue); font-size: 14px; line-height: 1.2; font-weight: 500; margin: 0 0 20px; }
    .eyebrow::before { content: ''; width: 11px; height: 11px; border: 1.5px solid currentColor; border-radius: 3px; transform: rotate(45deg); flex-shrink: 0; }

    /* Hero */
    .hero {
      position: relative; max-width: 100%; min-height: 540px;
      margin-left: 50px; margin-right: 50px;
      padding-top: 112px; padding-bottom: 80px; padding-left: 113px; padding-right: 80px;
      background: linear-gradient(to right, rgba(0,0,0,0.74) 0%, rgba(0,0,0,0.20) 100%),
        url('https://demskigrdev.wpenginepowered.com/wp-content/uploads/2025/09/female-freelancer-working-with-statistics-charts-o-2025-02-17-23-29-14-utc-scaled.jpg') center 38% / cover no-repeat;
      color: #fff; display: flex; align-items: flex-start; justify-content: flex-start;
      border-radius: 24px; overflow: hidden;
    }
    .hero-content { flex: 0 1 610px; }
    .hero .eyebrow { color: rgba(255,255,255,0.92); font-size: 15px; margin-bottom: 20px; }
    .hero .eyebrow::before { border-color: rgba(255,255,255,0.70); }
    .hero h1 { max-width: 610px; margin: 0 0 22px; font-size: clamp(40px,4.2vw,60px); font-weight: 700; line-height: 1.18; letter-spacing: -0.5px; color: #fff; }
    .hero p { max-width: 500px; margin: 0 0 30px; margin-left: 100px; font-size: 16px; font-weight: 400; line-height: 1.6; color: rgba(255,255,255,0.88); }
    .hero-btn { display: inline-flex; align-items: center; gap: 12px; background: #f0f0f0; color: #1a1a1a; padding: 14px 26px; border-radius: 10px; font-size: 17px; font-weight: 500; text-decoration: none; transition: transform 0.18s ease, background 0.18s ease; white-space: nowrap; margin-left: 100px; }
    .hero-btn:hover { transform: translateY(-2px); background: #e0e0e0; }
    .hero-btn i { font-size: 14px; }
    .hero-badges { position: absolute; top: 135px; right: 137px; display: flex; flex-direction: column; align-items: flex-end; gap: 66px; }
    .hero-badges img { width: 142px; height: auto; object-fit: contain; display: block; }

    /* Intro grid */
    .intro-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 100px; align-items: center; min-height: 340px; }
    .section-title { margin: 0; color: #1b1c1d; font-size: clamp(26px,2.6vw,38px); font-weight: 600; line-height: 1.26; }
    .intro-grid .section-title { max-width: 440px; font-size: clamp(33px,3.85vw,55px); margin-left: 5%; }
    .copy { color: #282828; font-size: 16px; line-height: 1.65; }
    .copy p { margin: 0 0 18px; }
    .copy ul { margin: 10px 0 18px 20px; padding: 0; }
    .copy li { margin-bottom: 8px; color: #282828; font-size: 16px; line-height: 1.65; list-style: disc; }

    /* Accordion + image */
    .media-accordion { display: grid; grid-template-columns: 31% 1fr; gap: 60px; align-items: stretch; padding-top: 60px; padding-bottom: 60px; }
    .media-accordion .feature-image { order: -1; }
    .feature-image { width: 100%; height: 680px; border-radius: 25px; object-fit: cover; object-position: center; display: block; }
    .accordion-copy { padding-top: 4px; }
    .accordion-copy .section-title { max-width: 900px; margin-bottom: 35px; font-size: clamp(28px,3.2vw,46px); }
    .acc-list { width: 100%; }
    .acc-item { border-bottom: 1px solid rgba(2,20,40,0.35); }
    .acc-btn { width: 100%; display: grid; grid-template-columns: 56px 1fr 22px; gap: 16px; align-items: center; min-height: 62px; padding: 6px 0; cursor: pointer; background: transparent; border: none; text-align: left; font-family: inherit; box-sizing: border-box; -webkit-appearance: none; appearance: none; }
    .acc-icon-box { width: 56px !important; min-width: 56px !important; height: 46px !important; border-radius: 10px; display: flex !important; align-items: center; justify-content: center; background-color: #005cb9 !important; color: #fff !important; font-size: 18px; box-sizing: border-box; flex-shrink: 0; }
    .acc-icon-box i { color: #fff !important; font-size: 18px !important; }
    .acc-title { font-size: 20px; font-weight: 500; line-height: 1.3; color: #1b1c1d; }
    .acc-toggle { justify-self: end; width: 22px; height: 22px; border: 1.5px solid #0f1720; border-radius: 3px; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 300; color: #0f1720; flex-shrink: 0; transition: background 0.2s, color 0.2s, border-color 0.2s; line-height: 1; }
    .acc-toggle::before { content: '+'; }
    .acc-item.active .acc-toggle { background: #005cb9; border-color: #005cb9; color: #fff; }
    .acc-item.active .acc-toggle::before { content: '−'; }
    .acc-panel { max-height: 0; overflow: hidden; transition: max-height 0.28s ease; }
    .acc-item.active .acc-panel { max-height: 400px; }
    .acc-body { max-width: 900px; padding: 12px 0 20px 78px; font-size: 16px; line-height: 1.65; color: #333; }

    /* Services grid */
    .services-grid-section { display: grid; grid-template-columns: 31% 1fr; gap: 50px; padding-top: 50px; padding-bottom: 50px; }
    .services-grid-section .section-title { max-width: 300px; font-size: 40px; color: #1b1c1d; }
    .service-grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 40px 70px; padding-left: 100px; }
    .service-card i { display: block; margin-bottom: 14px; color: #005cb9; font-size: 28px; line-height: 1; }
    .service-card h3 { margin: 0 0 10px; font-size: 25px; font-weight: 500; line-height: 1.3; color: #282828; font-family: 'Outfit', sans-serif; }
    .service-card p { margin: 0; color: #000; font-size: 16px; line-height: 1.55; }

    /* Why Choose */
    .why-section-wrap { position: relative; padding: 0 70px; margin: 50px auto; max-width: 1416px; }
    .why-section { display: block; border-radius: 22px; overflow: hidden; background-color: #f0f0f0; }
    .why-copy { flex: 1; min-width: 0; padding: 56px 56px 52px; }
    .why-copy .eyebrow { color: #005cb9; margin-bottom: 16px; }
    .why-copy .section-title { margin-bottom: 26px; font-size: clamp(33px,3.85vw,55px); font-weight: 600; }
    .why-copy > p { color: #111; font-size: 16px; line-height: 1.7; margin-bottom: 10px; max-width: 830px; }
    .testimonial { margin-top: 30px; padding-left: 18px; border-left: 3px solid #001629; }
    .testimonial h3 { margin: 0 0 18px; font-size: clamp(22px,2.2vw,33px); font-weight: 600; line-height: 1.25; color: #1b1c1d; }
    .quote-mark { color: #005cb9; font-size: 26px; line-height: 1; margin-bottom: 14px; letter-spacing: -3px; }
    .testimonial blockquote { margin: 0 0 30px; max-width: 1040px; color: #282828; font-size: 28px; font-weight: 400; font-family: 'Outfit', sans-serif; line-height: 1.65; }
    .testimonial-footer { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; padding-top: 4px; }
    .testimonial-footer p { margin: 0; font-size: 14px; line-height: 1.55; color: #333; }
    .testi-fraction { text-align: center; font-size: 13px; color: #888; margin-top: 22px; }
    .text-link { color: #282828; text-decoration: none; font-weight: 600; white-space: nowrap; font-size: 14px; }
    .why-card { position: absolute; top: -14px; right: 56px; bottom: -14px; width: 355px; margin: 14px; background-color: #001629 !important; color: #fff; display: flex; flex-direction: column; border-radius: 20px; z-index: 2; }
    .why-card-img-frame { padding: 24px 22px 16px; flex-shrink: 0; }
    .why-card-img-frame img { width: 100%; height: 420px; object-fit: cover; object-position: center top; border-radius: 16px; display: block; }
    .why-card-body { padding: 22px 26px 42px; display: flex; flex-direction: column; align-items: center; flex: 1; }
    .why-card h3 { width: 100%; margin: 0 0 44px; color: #fff !important; font-size: 25px; font-weight: 600; line-height: 1.35; text-align: left; font-family: 'Outfit', sans-serif; }
    .button-light { display: flex; align-items: center; justify-content: center; gap: 10px; width: 90%; min-height: 41px; background-color: #fff; color: #021428; padding: 12px 16px; font-size: 19px; font-weight: 600; font-family: 'Outfit', sans-serif; border-radius: 10px; text-decoration: none; text-align: center; flex-wrap: wrap; transition: transform 0.2s ease; }
    .button-light:hover { transform: translateY(-3px); }

    /* Case studies */
    .case-section { padding-top: 60px; padding-bottom: 50px; }
    .case-section .section-title { max-width: 600px; margin-bottom: 14px; font-size: clamp(24px,2.8vw,40px); }
    .case-intro { max-width: 660px; margin: 0 0 36px; color: #000; font-size: 14px; line-height: 1.55; }
    .case-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
    .case-card { position: relative; min-height: 148px; padding: 32px 22px 18px; border-radius: 16px; background: #fff; box-shadow: 0 2px 14px rgba(0,0,0,0.14); overflow: hidden; display: flex; flex-direction: column; justify-content: center; transition: box-shadow 0.25s ease; }
    .case-card:hover { box-shadow: 0 9px 44px rgba(0,0,0,0.24); }
    .case-card.featured { grid-column: span 2; grid-row: span 2; min-height: 310px; background: #282828; color: #fff; justify-content: flex-start; }
    .case-tag { position: absolute; top: 0; left: 0; width: 136px; padding: 5px 10px; border-radius: 0 0 6px 0; background: #8ce9ac; color: #000; font-size: 12px; font-weight: 700; text-align: center; }
    .case-card.featured .case-tag { width: 270px; background: #001a34; color: #fff; }
    .case-card.purple .case-tag { background: #686de4; color: #fff; }
    .case-card.rose .case-tag { background: #f2969d; }
    .case-card.pink .case-tag { background: #e585d9; }
    .case-card.sky .case-tag { background: #91c8f3; }
    .case-card.yellow .case-tag { background: #f0e58c; }
    .case-card.violet .case-tag { background: #c47aeb; }
    .case-card.sand .case-tag { background: #f1c88b; }
    .case-card img { align-self: center; max-width: 75%; max-height: 92px; object-fit: contain; margin-top: 29px; }
    .case-card.featured img { align-self: flex-start; max-width: 322px; max-height: 115px; margin: 44px 0 16px; }
    .case-card p { margin: 0 0 8px; color: #fff; font-size: 14px; line-height: 1.5; }
    .case-card .case-link { align-self: flex-end; margin-top: auto; color: inherit; text-decoration: none; font-weight: 600; white-space: nowrap; font-size: 13px; display: inline-flex; align-items: center; gap: 4px; }
    .case-card:not(.featured) .case-link { color: #005cb9; }

    /* Contact */
    .contact-section { background-color: #001629; margin-top: 50px; }
    .contact-inner { display: grid; grid-template-columns: 62% 38%; max-width: var(--max); margin: 0 auto; min-height: 600px; align-items: stretch; }
    .contact-form-col { padding: 72px 64px; }
    .contact-form-col .section-title { color: #fff; font-size: clamp(28px,3.2vw,46px); margin-bottom: 44px; line-height: 1.2; font-weight: 600; }
    .contact-form { display: flex; flex-direction: column; gap: 28px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
    .contact-form input, .contact-form textarea { width: 100%; padding: 10px 0; border: none; border-bottom: 1px solid rgba(255,255,255,0.3); border-radius: 0; font-size: 14px; font-family: inherit; outline: none; background: transparent; color: #fff; transition: border-bottom-color 0.2s; }
    .contact-form input:focus, .contact-form textarea:focus { border-bottom-color: rgba(255,255,255,0.75); }
    .contact-form input::placeholder, .contact-form textarea::placeholder { color: rgba(255,255,255,0.45); }
    .contact-form textarea { resize: none; min-height: 80px; }
    .form-submit { align-self: flex-start; padding: 15px 44px; background: #fff; color: #001629; border: none; border-radius: 8px; font-size: 15px; font-weight: 600; font-family: inherit; cursor: pointer; margin-top: 12px; transition: background 0.2s; }
    .form-submit:hover { background: #f0f0f0; }
    .contact-right-col { background-color: #f0f0f0; border-radius: 25px; margin: 28px 28px 28px 0; padding: 40px 40px 0; display: flex; flex-direction: column; box-shadow: 0 4px 32px rgba(0,0,0,0.14); }
    .contact-right-label { font-size: 16px; font-weight: 600; color: #1a1a1a; margin: 0 0 22px; }
    .tc-carousel { position: relative; flex: 1; }
    .tc-slide { display: none; flex-direction: column; }
    .tc-slide.active { display: flex; }
    .tc-quote-icon { color: #005cb9; font-size: 26px; margin-bottom: 18px; line-height: 1; }
    .tc-text { color: #333; font-size: 16px; line-height: 1.72; margin: 0 0 20px; flex: 1; }
    .tc-footer { display: flex; justify-content: space-between; align-items: flex-end; gap: 12px; padding-top: 14px; border-top: 1px solid #e8e8e8; }
    .tc-author { font-size: 14px; font-weight: 700; color: #1a1a1a; line-height: 1.4; }
    .tc-author span { display: block; font-weight: 400; font-size: 13px; color: #888; }
    .tc-link { color: #1a1a1a; text-decoration: none; font-size: 13px; font-weight: 500; white-space: nowrap; }
    .tc-fraction-bar { text-align: center; font-size: 18px; font-weight: 600; color: #1a1a1a; padding: 8px 0 12px; margin-top: auto; margin-bottom: 28px; }
    .contact-right-img { width: 100%; height: 220px; object-fit: cover; object-position: center top; display: block; border-radius: 16px 16px 22px 22px; }
    .cbd-page-class footer { margin-top: 0; position: relative; z-index: 1; }

    /* Responsive */
    @media (max-width: 1200px) {
      .cbd-page-class header { padding: 14px 28px; }
      .intro-grid, .services-grid-section, .contact-inner { grid-template-columns: 1fr; }
      .media-accordion { grid-template-columns: 1fr; }
      .media-accordion .feature-image { display: none; }
      .service-grid { padding-left: 0; gap: 32px 40px; }
      .case-grid { grid-template-columns: 1fr 1fr; }
      .contact-form-col { padding: 44px 36px; }
      .contact-right-col { margin: 22px 22px 0 0; padding: 32px 32px 0; border-radius: 22px; }
      .why-section-wrap { padding: 0 20px; }
      .why-copy { padding: 42px 36px 38px; }
    }
    @media (max-width: 1100px) {
      .hero { flex-direction: column; align-items: flex-start; gap: 28px; }
      .hero-content { flex: none; max-width: 640px; }
      .hero p, .hero-btn { margin-left: 0; }
      .hero-badges { position: static; flex-direction: row; gap: 12px; margin-top: 28px; }
      .hero-badges img { width: 90px; }
    }
    @media (max-width: 768px) {
      .cbd-section { padding: 40px 20px; }
      .hero { min-height: auto; margin-left: 16px; margin-right: 16px; padding: 44px 32px; border-radius: 16px; }
      .hero h1 { font-size: clamp(30px,8vw,38px); }
      .hero p, .hero-btn { margin-left: 0; }
      .hero-badges { position: static; flex-wrap: wrap; gap: 12px; margin-top: 24px; }
      .hero-badges img { width: 110px; }
      .acc-btn { grid-template-columns: 48px 1fr 20px; gap: 12px; }
      .acc-icon-box { width: 48px !important; min-width: 48px !important; height: 38px !important; }
      .acc-title { font-size: 14px; }
      .acc-body { padding-left: 60px; font-size: 13px; }
      .service-grid, .case-grid { grid-template-columns: 1fr; }
      .case-card.featured { grid-column: span 1; }
      .why-copy { padding: 28px 20px; }
      .why-section-wrap { padding: 0 12px; margin: 30px 0; }
      .form-row { grid-template-columns: 1fr; }
      .contact-form-col { padding: 36px 22px; }
      .contact-right-col { margin: 20px 0 0 0; padding: 28px 22px 0; border-radius: 22px; }
    }
    @media (max-width: 600px) {
      .hero { margin-left: 12px; margin-right: 12px; padding: 36px 20px; border-radius: 14px; }
