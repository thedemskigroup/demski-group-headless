---
import Layout from '../../../layouts/Layout.astro';
import ContactSection from '../../../components/ContactSection.astro';

const assetBase = '/solutions/sales-lead-tracking-tools';

const deliverables = [
  ['fa-table-cells-large', 'Real-Time Lead Management', 'Centralize your inbound leads from every channel — web forms, email, phone, and live chat — into one unified interface. Track lead sources, assign ownership, and monitor performance in real time to reduce response times and boost conversions.'],
  ['fa-square-check', 'Custom Sales Pipelines', 'We build pipelines that match your actual sales process — not the other way around. Create deal stages that reflect your workflows, automate handoffs, and keep your team aligned from first touch to close.'],
  ['fa-layer-group', 'AI-Powered Prioritization', 'Leverage data-driven scoring and intelligent suggestions to surface your most promising opportunities. Our tools use AI to help your team focus on the leads most likely to convert, maximizing time and ROI.'],
  ['fa-laptop-code', 'Continuous Engagement Tools', 'Never let a lead fall through the cracks. We can integrate tools like SMS, live chat, and automated call routing (e.g. Twilio, Pusher) to ensure a real human touchpoint — even when your main rep is unavailable.'],
  ['fa-shield-halved', 'Mobile & Remote Access', "Sales doesn't just happen at a desk. Our solutions are fully responsive and mobile-ready, giving your team instant access to their pipeline from anywhere."]
];

const services = [
  ['fa-route', 'Sales Process Consulting', 'We work with your team to map your existing workflows, identify gaps, and design a smarter, streamlined process from first contact to close.'],
  ['fa-head-side-virus', 'Solution Design & Prototyping', 'Our team designs interfaces, data flows, and pipeline structures that fit your business model — including clickable prototypes for stakeholder feedback before development begins.'],
  ['fa-arrow-trend-up', 'Custom Software Development', 'We build scalable, secure systems tailored to your stack, integrating with CRMs like Salesforce or HubSpot, communication platforms, and internal tools.'],
  ['fa-code-branch', 'Systems Integration', 'Need to sync leads with your ERP or legacy software? We develop custom APIs and integrations that ensure smooth data flow and long-term compatibility.'],
  ['fa-headset', 'Implementation & Training', 'Once deployed, we guide your team through onboarding, workflow testing, and adoption. We also provide documentation and optional training sessions to keep everyone aligned.']
];

const strategicBenefits = [
  ['fa-table-cells-large', 'Greater Team Collaboration', 'With all lead and customer data in one place, your sales and marketing teams can work from a single source of truth — improving communication, accountability, and performance.'],
  ['fa-square-check', 'Higher Conversion Rates', 'From smarter lead scoring to intelligent follow-up tools, we help your team convert more leads into paying customers.'],
  ['fa-layer-group', 'Scalable, Secure Architecture', 'Our tools are built for growth, with secure user access controls and the flexibility to integrate with CRMs, ERPs, or proprietary systems through custom APIs.'],
  ['fa-laptop-code', 'Continuous Engagement Tools', 'Never let a lead fall through the cracks. We can integrate tools like SMS, live chat, and automated call routing (e.g. Twilio, Pusher) to ensure a real human touchpoint — even when your main rep is unavailable.'],
  ['fa-shield-halved', 'Mobile & Remote Access', "Sales doesn't just happen at a desk. Our solutions are fully responsive and mobile-ready, giving your team instant access to their pipeline from anywhere."]
];

const contactTestimonials = [
  { quote: "The Demski Group is great to work with! They inherited a mess with our platform and have been able to fix the bugs and make the platform more user friendly. They are also very professional and timely as well as a pleasure to work with! We have worked with Andrew Demski for all of our IT needs.", name: "Delaine Mast", role: "CEO", link: "/our-clients/impact-team-tennis/" },
  { quote: "We spoke to a few different companies as we set out to find someone to create a website/database application to augment our desktop software. We chose The Demski Group in part because we found them very easy to talk to in our interview. That first impression stuck as we have a great relationship with them now. We are currently planning to farm out another project and are not even considering looking for anyone else to take it on.", name: "Mickey Rowe", role: "Manager", link: "/our-clients/biopac/" },
  { quote: "Code quality was very good and done in a fast, efficient manner. We are pleased with the excellent job from The Demski Group. The team was able to provide high-quality services throughout the project. They produced the deliverables in a timely manner and within budget.", name: "Thariq Kara", role: "CEO", link: "/our-clients/nu-borders/" }
];

const cases = [
  { tag: 'Biotechnology', name: 'BIOPAC Systems, Inc.', description: 'The Demski Group successfully delivered a scalable and efficient web application for Biopac, enabling users to perform and track scientific studies online.', image: 'Biopac-white.png', tone: 'dark', link: '/our-clients/biopac' },
  { tag: 'Sports', name: 'Impact Team Tennis', description: '', image: 'ImpactTennis-e1744403805766.png', tone: 'green', link: '/our-clients/impact-team-tennis/' },
  { tag: 'Health & Wellness', name: 'Prefusion Health', description: '', image: 'PrefusionHealth.png', tone: 'purple', link: '/our-clients/prefusion-health/' },
  { tag: 'Insurance', name: 'Adaptrack', description: '', image: 'ADAPTRACK.png', tone: 'rose', link: '/our-clients/' },
  { tag: 'Retail', name: 'Zoomifi', description: '', image: 'Zoomifi-2-e1744403389524.png', tone: 'pink', link: '/our-clients/zoomifi/' },
  { tag: 'Real Estate', name: 'Property Gauge', description: '', image: 'PropertyGauge.png', tone: 'sky', link: '/our-clients/property-gauge/' },
  { tag: 'Energy & Utilities', name: 'Corning', description: '', image: 'Corning-e1744401647484.png', tone: 'yellow', link: '/our-clients/corning-glass/' },
  { tag: 'Logistics', name: 'Bite', description: '', image: 'Bite-e1746208787498.png', tone: 'violet', link: '/our-clients/bite/' },
  { tag: 'Manufacturing', name: 'Saputo', description: '', image: 'Saputo.png', tone: 'sand', link: '/our-clients/' }
];
export const prerender = true;
---

<Layout
  title="Custom Sales & Lead Tracking Tools | The Demski Group"
  description="Boost conversions and streamline your sales pipeline with custom lead tracking tools, intelligent automation, and real-time performance insights."
  pageClass="sales-solution-page"
>
  <!-- Preload hero background for this page (LCP candidate) -->
  <link rel="preload" href={`${assetBase}/a-group-of-people-working-man-and-woman-in-the-pla-2025-10-16-22-30-43-utc-scaled.jpg`} as="image" slot="head" />
  <style slot="head">
    /* ── Page tokens ── */
    .sales-solution-page {
      --blue: #005cb9;
      --orange: #f09300;
      --ink: #282828;
      --muted: #f0f0f0;
      --navy: #001629;
      --max: 1850px;
      font-family: 'Outfit', sans-serif;
      color: var(--ink);
    }

    /* ── Global nav overrides ── */
    .sales-solution-page .top-bar {
      background: var(--blue);
      min-height: 34px;
      padding: 6px 20px;
      font-size: 16px;
      line-height: 1;
      font-weight: 500;
    }

    .sales-solution-page header {
      box-shadow: none;
      padding: 13px 176px 11px 50px;
      align-items: center;
    }

    .sales-solution-page .logo img { height: 42px; }

    .sales-solution-page nav { gap: 28px; }

    .sales-solution-page nav a,
    .sales-solution-page .nav-trigger {
      font-size: 15px;
      font-weight: 500;
    }

    .sales-solution-page .nav-dropdown-menu {
      width: 320px;
      top: calc(100% + 14px);
      box-shadow: 0 4px 18px rgba(0,0,0,0.18);
    }

    .sales-solution-page .nav-dropdown-menu a {
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 400;
    }

    .sales-solution-page .btn-cta,
    .sales-solution-page .footer-cta-btn {
      background: var(--orange) !important;
      border-color: var(--orange);
      border-radius: 6px;
      font-size: 15px !important;
      padding: 11px 18px !important;
    }

    /* ── Page shell ── */
    .sales-page { overflow-x: clip; }

    .sales-section {
      max-width: var(--max);
      margin: 0 auto;
      padding: 60px 50px;
    }

    /* ── Eyebrow ── */
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--blue);
      font-size: 15px;
      font-family: 'Outfit', sans-serif;
      line-height: 1.2;
      font-weight: 500;
      margin: 0 0 20px;
    }

    .eyebrow::before {
      content: '';
      width: 11px;
      height: 11px;
      border: 1.5px solid currentColor;
      border-radius: 3px;
      transform: rotate(45deg);
      flex-shrink: 0;
    }
    .acc-eyebrow { font-size: 18px; font-family: 'Outfit', sans-serif; color: #0154B1; }

    /* ── Hero ── */
    .hero {
      position: relative;
      max-width: 100%;
      min-height: 540px;
      margin-left: 50px;
      margin-right: 50px;
      padding-top: 112px;
      padding-bottom: 80px;
      padding-left: 113px;
      padding-right: 80px;
      background:
        linear-gradient(to right, rgba(0,0,0,0.48) 0%, rgba(0,0,0,0.08) 100%),
        url('/solutions/sales-lead-tracking-tools/a-group-of-people-working-man-and-woman-in-the-pla-2025-10-16-22-30-43-utc-scaled.jpg') center 39% / cover no-repeat;
      color: #fff;
      display: flex;
      align-items: flex-start;
      justify-content: flex-start;
      border-radius: 24px;
      overflow: hidden;
    }

    .hero-content { flex: 0 1 610px; }

    .hero .eyebrow {
      color: #FFFFFF;
      font-size: 18px;
      font-family: 'Outfit', sans-serif;
      margin-bottom: 20px;
    }

    .hero .eyebrow::before { border-color: rgba(255,255,255,0.70); }

    .hero h1 {
      max-width: 610px;
      margin: 0 0 22px;
      font-size: clamp(40px, 4.2vw, 60px);
      font-weight: 700;
      line-height: 1.18;
      letter-spacing: -0.5px;
      color: #fff;
    }

    .hero p {
      max-width: 540px;
      margin: 0 0 30px;
      font-size: 18px;
      font-family: 'Outfit', sans-serif;
      font-weight: 400;
      line-height: 1.6;
      color: #FFFFFF;
    }

    .hero-btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: #f0f0f0;
      color: #1a1a1a;
      padding: 14px 26px;
      border-radius: 10px;
      font-size: 20px;
      font-weight: 500;
      text-decoration: none;
      transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease;
      white-space: nowrap;
    }

    .hero-btn:hover { transform: translateY(-3px); background: #0154b1; color: #fff; }
    .hero-btn i     { font-size: 14px; }
    .btn-icon-box { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: transparent; border-radius: 7px; border: none; box-shadow: none; flex-shrink: 0; }
    .btn-icon-box i { font-size: 13px; color: inherit; }
    .hero-btn:hover .btn-icon-box i { color: #fff; }

    .hero-badges {
      position: absolute;
      top: 135px;
      right: 137px;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 66px;
    }

    .hero-badges img {
      width: 142px;
      height: auto;
      object-fit: contain;
      display: block;
    }

    .button-orange,
    .button-light {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      border-radius: 6px;
      text-decoration: none;
      line-height: 1;
      transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
    }

    .button-orange {
      min-height: 40px;
      background: #f09300;
      color: #fff;
      padding: 10px 20px;
      font-size: 15px;
      font-weight: 500;
      border-radius: 6px;
    }

    .button-orange:hover { transform: translateY(-3px); }
    .button-light:hover  { }

    .trust-row { display: none; }

    /* ── Intro grid ── */
    .intro-grid {
      display: grid;
      grid-template-columns: 0.85fr 1.15fr;
      gap: 100px;
      align-items: center;
      min-height: 340px;
    }

    .section-title {
      margin: 0;
      color: #1b1c1d;
      font-size: clamp(26px, 2.6vw, 38px);
      font-weight: 600;
      line-height: 1.26;
      letter-spacing: 0;
    }

    .intro-grid .section-title { max-width: 500px; font-size: clamp(33px, 3.5vw, 50px); font-family: 'Outfit', sans-serif; margin-left: 5%; }

    .copy {
      color: #282828;
      font-size: 16px;
      line-height: 1.65;
    }

    .copy p { margin: 0 0 18px; }

    /* ── Accordion + image sections ── */
    .media-accordion {
      display: grid;
      grid-template-columns: 31% 1fr;
      gap: 60px;
      align-items: stretch;
      padding-top: 60px;
      padding-bottom: 60px;
    }

    .media-accordion .feature-image { order: -1; }

    .feature-image {
      width: 100%;
      height: 680px;
      min-height: unset;
      max-height: unset;
      border-radius: 25px;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .accordion-copy { padding-top: 4px; }

    .accordion-copy .section-title {
      max-width: 900px;
      margin-bottom: 55px;
      font-size: clamp(28px, 3.2vw, 46px);
    }

    /* ── Button-based accordion ── */
    .acc-list { width: 100%; }

    .acc-item { border-bottom: 1px solid rgba(2, 20, 40, 0.35); }

    .acc-btn {
      width: 100%;
      display: grid;
      grid-template-columns: 56px 1fr 22px;
      gap: 16px;
      align-items: center;
      min-height: 62px;
      padding: 6px 0;
      cursor: pointer;
      background: transparent;
      border: none;
      text-align: left;
      font-family: inherit;
      box-sizing: border-box;
      -webkit-appearance: none;
      appearance: none;
    }

    .acc-icon-box {
      width: 56px !important;
      min-width: 56px !important;
      height: 46px !important;
      border-radius: 10px;
      display: flex !important;
      align-items: center;
      justify-content: center;
      background-color: #005cb9 !important;
      color: #ffffff !important;
      font-size: 18px;
      box-sizing: border-box;
      flex-shrink: 0;
    }

    .acc-icon-box i {
      color: #ffffff !important;
      font-size: 18px !important;
      display: block;
    }

    .acc-title {
      font-size: 20px;
      font-weight: 500;
      line-height: 1.3;
      color: #1b1c1d;
    }

    .acc-toggle {
      justify-self: end;
      width: 22px;
      height: 22px;
      border: 1.5px solid #0f1720;
      border-radius: 3px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      font-weight: 300;
      color: #0f1720;
      flex-shrink: 0;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
      line-height: 1;
    }

    .acc-toggle::before { content: '+'; }

    .acc-item.active .acc-toggle {
      background: #005cb9;
      border-color: #005cb9;
      color: #fff;
    }

    .acc-item.active .acc-toggle::before { content: '−'; }

    .acc-panel {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.28s ease;
    }

    .acc-item.active .acc-panel { max-height: 400px; }

    .acc-body {
      max-width: 900px;
      padding: 12px 0 20px 78px;
      font-size: 16px;
      line-height: 1.65;
      color: #333;
    }

    /* ── Services grid ── */
    .services-grid-section {
      display: grid;
      grid-template-columns: 31% 1fr;
      gap: 50px;
      padding-top: 50px;
      padding-bottom: 50px;
    }

    .services-grid-section .section-title {
      max-width: 430px;
      font-size: 46px;
      color: #1b1c1d;
      font-family: 'Outfit', sans-serif;
    }

    .service-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 40px 70px;
      padding-left: 100px;
    }

    .service-card i {
      display: block;
      margin-bottom: 14px;
      color: #005cb9;
      font-size: 28px;
      line-height: 1;
    }

    .service-card h3 {
      margin: 0 0 10px;
      font-size: 25px;
      font-weight: 500;
      line-height: 1.3;
      color: #282828;
      font-family: 'Outfit', sans-serif;
    }

    .service-card p {
      margin: 0;
      color: #000;
      font-size: 16px;
      line-height: 1.55;
    }

    /* ── Why Choose ── */
    .why-section-wrap {
      position: relative;
      padding: 0;
      margin: 50px 100px;
    }

    .why-section {
      display: block;
      border-radius: 22px;
      overflow: hidden;
      background-color: #f0f0f0;
    }


    .why-copy {
      flex: 1;
      min-width: 0;
      padding: 56px 56px 52px;
    }

    .why-copy .eyebrow { color: #005cb9; margin-bottom: 16px; }

    .why-copy .section-title {
      margin-bottom: 26px;
      font-size: clamp(33px, 3.85vw, 55px);
      font-weight: 600;
    }

    .why-copy > p {
      color: #111;
      font-size: 16px;
      line-height: 1.7;
      margin-bottom: 10px;
      max-width: 830px;
    }

    .why-copy ul {
      margin: 14px 0 24px 22px;
      padding: 0;
    }

    .why-copy li {
      color: #111;
      font-size: 16px;
      line-height: 1.7;
      margin-bottom: 7px;
    }

    .testimonial {
      margin-top: 30px;
      padding-left: 18px;
      border-left: 3px solid #001629;
    }

    .testimonial h3 {
      margin: 0 0 18px;
      font-size: clamp(22px, 2.2vw, 33px);
      font-weight: 600;
      line-height: 1.25;
      color: #1b1c1d;
    }

    .quote-mark {
      color: #005cb9;
      font-size: 26px;
      line-height: 1;
      margin-bottom: 14px;
      letter-spacing: -3px;
    }

    .testimonial blockquote {
      margin: 0 0 30px;
      max-width: 1040px;
      color: #282828;
      font-size: 25px;
      font-weight: 400;
      font-family: 'Outfit', sans-serif;
      line-height: 1.65;
    }

    .testimonial-footer {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      padding-top: 4px;
    }

    .testimonial-footer p {
      margin: 0;
      font-size: 16px;
      line-height: 1.55;
      color: #333;
    }

    .testi-fraction {
      text-align: center;
      font-size: 16px;
      color: #888;
      margin-top: 22px;
    }

    .tc-fraction-bar { text-align: center; font-size: 20px; color: #000; padding: 14px 0 8px; position: relative; z-index: 2; transform: translateY(-100px); }

    .text-link {
      color: #282828;
      text-decoration: none;
      font-weight: 600;
      white-space: nowrap;
      font-size: 16px;
    }

    /* ── Why card: right navy column ── */
    .why-card {
      position: absolute;
      top: -14px;
      right: 0;
      bottom: -14px;
      width: 355px;
      margin: 14px 0 14px 14px;
      background-color: #001629 !important;
      color: #ffffff;
      display: flex;
      flex-direction: column;
      border-radius: 20px;
      z-index: 2;
    }

    .why-card-img-frame {
      padding: 24px 22px 16px;
      flex-shrink: 0;
    }

    .why-card-img-frame img {
      width: 100%;
      height: 420px;
      object-fit: cover;
      object-position: center top;
      border-radius: 16px;
      display: block;
    }

    .why-card-body {
      padding: 22px 26px 42px;
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 1;
    }

    .why-card h3 {
      width: 100%;
      margin: 0 0 44px;
      color: #ffffff !important;
      font-size: 25px;
      font-weight: 600;
      line-height: 1.35;
      text-align: left;
      font-family: 'Outfit', sans-serif;
    }

    .button-light {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 90%;
      min-height: 41px;
      background-color: #ffffff;
      color: #021428;
      padding: 12px 16px;
      font-size: 19px;
      font-weight: 600;
      font-family: 'Outfit', sans-serif;
      border-radius: 10px;
      text-decoration: none;
      text-align: center;
      white-space: normal;
      flex-wrap: wrap;
    }

    /* ── Case studies ── */
    .case-section {
      padding-top: 60px;
      padding-bottom: 50px;
    }

    .case-section .section-title {
      max-width: 800px;
      margin-bottom: 14px;
      font-size: 50px;
    }

    .case-intro {
      max-width: 660px;
      margin: 0 0 36px;
      color: #000;
      font-size: 16px;
      line-height: 1.55;
    }

    .case-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }

    .case-card {
      position: relative;
      min-height: 148px;
      padding: 32px 22px 18px;
      border-radius: 16px;
      background: #fff;
      box-shadow: 0 2px 14px rgba(0,0,0,0.14);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: center;
      transition: box-shadow 0.25s ease;
    }

    .case-card:hover {
      box-shadow: 0 9px 44px rgba(0,0,0,0.24);
    }

    .case-card.featured {
      grid-column: span 2;
      grid-row: span 2;
      min-height: 310px;
      background: #282828;
      color: #fff;
      justify-content: flex-start;
    }

    .case-tag {
      position: absolute;
      top: 0;
      left: 0;
      width: 136px;
      padding: 5px 10px;
      border-radius: 0 0 6px 0;
      background: #8ce9ac;
      color: #000;
      font-size: 16px;
      font-weight: 700;
      text-align: center;
    }

    .case-card.featured .case-tag {
      width: 270px;
      background: #001a34;
      color: #fff;
    }

    .case-card.purple .case-tag  { background: #686de4; color: #fff; }
    .case-card.rose .case-tag    { background: #f2969d; }
    .case-card.pink .case-tag    { background: #e585d9; }
    .case-card.sky .case-tag     { background: #91c8f3; }
    .case-card.yellow .case-tag  { background: #f0e58c; }
    .case-card.violet .case-tag  { background: #c47aeb; }
    .case-card.sand .case-tag    { background: #f1c88b; }

    .case-card img {
      align-self: center;
      max-width: 75%;
      max-height: 92px;
      object-fit: contain;
      margin-top: 29px;
    }

    .case-card.featured img {
      align-self: flex-start;
      max-width: 410px;     /* +15%: 280 → 322 */
      max-height: 135px;    /* +15%: 100 → 115 */
      margin: 44px 0 16px;  /* top: 28 + 15% of ~100px = 28+15 = 43 → 44 */
    }

    .case-card p {
      margin: 0 0 8px;
      color: #fff;
      font-size: 14px;
      line-height: 1.5;
