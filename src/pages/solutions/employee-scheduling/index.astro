---
import Layout from '../../../layouts/Layout.astro';
import ContactSection from '../../../components/ContactSection.astro';

const assetBase = '/solutions/sales-lead-tracking-tools';

const strategicBenefits = [
  ['fa-calendar-check', 'Eliminate Scheduling Conflicts & Gaps', 'Manual scheduling in spreadsheets or basic tools leads to double-bookings, uncovered shifts, and last-minute scrambles. A custom scheduling system enforces rules automatically — preventing conflicts before they happen and flagging gaps before they become problems.'],
  ['fa-clock', 'Save Hours of Administrative Time Every Week', 'Building schedules, processing time-off requests, tracking hours, and managing shift swaps takes significant manager time every week. Automation handles the routine work so your managers can focus on their actual jobs.'],
  ['fa-users', 'Give Employees Visibility & Control', 'Employees who can view their schedules, request time off, swap shifts, and receive reminders from their phone are more engaged and less likely to miss shifts. Self-service reduces back-and-forth and builds accountability.'],
  ['fa-chart-bar', 'Align Staffing Levels with Business Demand', 'Overstaffing drives up labor costs. Understaffing hurts service and burns out your team. Custom scheduling software can factor in historical demand, seasonality, and real-time data to optimize coverage at every shift.'],
  ['fa-shield-halved', 'Compliance, Overtime & Labor Law Management', 'Tracking hours, managing overtime thresholds, enforcing break requirements, and staying compliant with labor regulations is complex and high-risk. A custom system bakes your rules into the scheduling logic — reducing compliance exposure automatically.']
];

const services = [
  ['fa-calendar-days', 'Shift Scheduling & Rotation Management', 'Build and publish schedules for teams of any size across multiple locations — with rules for availability, certifications, seniority, and role requirements built in.'],
  ['fa-mobile-screen', 'Employee Self-Service & Mobile Access', 'Give your team a mobile-friendly portal to view schedules, submit availability, request time off, and swap shifts — with manager approvals built into the workflow.'],
  ['fa-stopwatch', 'Time & Attendance Tracking', 'Clock-in/clock-out systems, GPS-verified attendance, and automated timesheet generation that feeds directly into your payroll process — eliminating manual hours reconciliation.'],
  ['fa-rotate', 'Shift Swap & Coverage Management', 'Structured shift swap workflows that allow employees to find their own coverage within defined rules — reducing manager involvement while keeping schedules properly filled.'],
  ['fa-triangle-exclamation', 'Overtime & Compliance Monitoring', 'Automatic flags for overtime thresholds, break violations, and labor law requirements — with configurable rules that match your specific regulatory environment.'],
  ['fa-plug', 'Payroll & HR System Integration', 'Seamless connections to your existing payroll, HRIS, and accounting platforms so approved hours flow directly into payroll without re-entry or manual reconciliation.']
];

const coreServices = [
  ['fa-magnifying-glass', 'Discovery & Workflow Mapping', 'We document your current scheduling process, identify the friction points that cost your managers time and your business money, and design a system architecture that solves the right problems.'],
  ['fa-paintbrush', 'Rules Engine & Logic Design', 'We translate your scheduling rules — availability windows, role requirements, overtime limits, certification checks — into automated logic that enforces your policies without manual oversight.'],
  ['fa-code', 'Build, Integrate & Configure', 'We build your scheduling platform and connect it to your existing payroll, HR, and communication systems — ensuring data flows cleanly across your entire workforce management stack.'],
  ['fa-vial-circle-check', 'Testing, Pilot & Rollout', 'We run parallel testing alongside your existing process, gather feedback from managers and staff, and execute a staged rollout that minimizes disruption during the transition.'],
  ['fa-headset', 'Training & Ongoing Optimization', 'We train your team, provide documentation, and continue optimizing the system as your workforce grows, your rules evolve, and new needs emerge.']
];

const contactTestimonials = [
  { quote: "The Demski Group is great to work with! They inherited a mess with our platform and have been able to fix the bugs and make the platform more user friendly. They are also very professional and timely as well as a pleasure to work with! We have worked with Andrew Demski for all of our IT needs.", name: "Delaine Mast", role: "CEO", link: "/our-clients/impact-team-tennis/" },
  { quote: "We spoke to a few different companies as we set out to find someone to create a website/database application to augment our desktop software. We chose The Demski Group in part because we found them very easy to talk to in our interview. That first impression stuck as we have a great relationship with them now.", name: "Mickey Rowe", role: "Manager", link: "/our-clients/biopac/" },
  { quote: "Code quality was very good and done in a fast, efficient manner. We are pleased with the excellent job from The Demski Group. The team was able to provide high-quality services throughout the project. They produced the deliverables in a timely manner and within budget.", name: "Thariq Kara", role: "CEO", link: "/our-clients/nu-borders/" }
];

const cases = [
  { tag: 'Biotechnology',    name: 'BIOPAC Systems, Inc.',  description: 'The Demski Group successfully delivered a scalable and efficient web application for Biopac, enabling users to perform and track scientific studies online.', image: 'Biopac-white.png',                     tone: 'dark',   link: '/our-clients/biopac' },
  { tag: 'Sports',           name: 'Impact Team Tennis',    description: '', image: 'ImpactTennis-e1744403805766.png',       tone: 'green',  link: '/our-clients/impact-team-tennis/' },
  { tag: 'Health & Wellness',name: 'Prefusion Health',      description: '', image: 'PrefusionHealth.png',                   tone: 'purple', link: '/our-clients/prefusion-health/' },
  { tag: 'Insurance',        name: 'Adaptrack',             description: '', image: 'ADAPTRACK.png',                         tone: 'rose',   link: '/our-clients/' },
  { tag: 'Retail',           name: 'Zoomifi',               description: '', image: 'Zoomifi-2-e1744403389524.png',          tone: 'pink',   link: '/our-clients/zoomifi/' },
  { tag: 'Real Estate',      name: 'Property Gauge',        description: '', image: 'PropertyGauge.png',                     tone: 'sky',    link: '/our-clients/property-gauge/' },
  { tag: 'Energy & Utilities',name:'Corning',               description: '', image: 'Corning-e1744401647484.png',            tone: 'yellow', link: '/our-clients/corning-glass/' },
  { tag: 'Logistics',        name: 'Bite',                  description: '', image: 'Bite-e1746208787498.png',               tone: 'violet', link: '/our-clients/bite/' },
  { tag: 'Manufacturing',    name: 'Saputo',                description: '', image: 'Saputo.png',                            tone: 'sand',   link: '/our-clients/' }
];
---

<Layout
  title="Employee Scheduling & Time Tracking Software | The Demski Group"
  description="Custom employee scheduling and time tracking systems that eliminate manual processes, reduce labor costs, and keep your workforce running smoothly."
  pageClass="es-page-class"
>
  <link rel="preload" href="https://demskigrdev.wpenginepowered.com/wp-content/uploads/2025/07/business-team-creative-person-are-meeting-at-offic-2025-03-26-02-55-04-utc-scaled.jpg" as="image" slot="head" />

  <style slot="head">
    .es-page-class {
      --blue:#005cb9; --orange:#f09300; --ink:#282828; --muted:#f0f0f0; --navy:#001629; --max:1850px;
      font-family:'Outfit',sans-serif; color:var(--ink);
    }
    .es-page-class .top-bar{background:var(--blue);min-height:34px;padding:6px 20px;font-size:16px;line-height:1;font-weight:500}
    .es-page-class header{box-shadow:none;padding:13px 176px 11px 50px;align-items:center}
    .es-page-class .logo img{height:42px}
    .es-page-class nav{gap:28px}
    .es-page-class nav a,.es-page-class .nav-trigger{font-size:15px;font-weight:500}
    .es-page-class .nav-dropdown-menu{width:320px;top:calc(100% + 14px);box-shadow:0 4px 18px rgba(0,0,0,0.18)}
    .es-page-class .nav-dropdown-menu a{padding:12px 16px;font-size:14px;font-weight:400}
    .es-page-class .btn-cta,.es-page-class .footer-cta-btn{background:var(--orange)!important;border-color:var(--orange);border-radius:6px;font-size:15px!important;padding:11px 18px!important}

    .es-page{overflow-x:clip}
    .es-section{max-width:var(--max);margin:0 auto;padding:60px 50px}

    .eyebrow{display:inline-flex;align-items:center;gap:10px;color:var(--blue);font-size:15px;font-family:'Outfit', sans-serif;line-height:1.2;font-weight:500;margin:0 0 20px}
    .eyebrow::before{content:'';width:11px;height:11px;border:1.5px solid currentColor;border-radius:3px;transform:rotate(45deg);flex-shrink:0}
    .acc-eyebrow { font-size: 18px; font-family: 'Outfit', sans-serif; color: #0154B1; }

    .hero{
      position:relative;max-width:100%;min-height:540px;
      margin-left:50px;margin-right:50px;
      padding-top:112px;padding-bottom:80px;padding-left:113px;padding-right:80px;
      background:linear-gradient(to right,rgba(0,0,0,0.72) 0%,rgba(0,0,0,0.18) 100%),
        url('https://demskigrdev.wpenginepowered.com/wp-content/uploads/2025/07/business-team-creative-person-are-meeting-at-offic-2025-03-26-02-55-04-utc-scaled.jpg') center 40% / cover no-repeat;
      color:#fff;display:flex;align-items:flex-start;justify-content:flex-start;
      border-radius:24px;overflow:hidden;
    }
    .hero-content{flex:0 1 720px}
    .hero .eyebrow{color:#FFFFFF;font-size:18px;font-family:'Outfit', sans-serif;margin-bottom:20px}
    .hero .eyebrow::before{border-color:rgba(255,255,255,0.70)}
    .hero h1{max-width:720px;margin:0 0 22px;font-size:clamp(40px,4.2vw,60px);font-weight:700;line-height:1.18;letter-spacing:-0.5px;color:#fff}
    .hero p{max-width:540px;margin:0 0 30px;font-size:18px;font-family:'Outfit', sans-serif;font-weight:400;line-height:1.6;color:#FFFFFF}
    .hero-btn{display:inline-flex;align-items:center;gap:12px;background:#f0f0f0;color:#1a1a1a;padding:14px 26px;border-radius:10px;font-size:20px;font-weight:500;text-decoration:none;transition:transform 0.18s ease,background 0.18s ease,color 0.18s ease;white-space:nowrap}
    .hero-btn:hover{ transform: translateY(-3px);background:#0154b1;color:#fff}
    .hero-btn i{font-size:14px}
    .btn-icon-box {display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;background:transparent;border-radius:7px;border:none;box-shadow:none;flex-shrink:0;}
    .btn-icon-box i{font-size:13px;color:inherit;transition:color 0.2s ease}
    .hero-btn:hover .btn-icon-box i{color:#fff}
    .hero-badges{position:absolute;top:135px;right:137px;display:flex;flex-direction:column;align-items:flex-end;gap:66px}
    .hero-badges img{width:142px;height:auto;object-fit:contain;display:block}

    .intro-grid{display:grid;grid-template-columns:0.85fr 1.15fr;gap:100px;align-items:center;min-height:340px}
    .section-title{margin:0;color:#1b1c1d;font-size:clamp(26px,2.6vw,38px);font-weight:600;line-height:1.26}
    .intro-grid .section-title{max-width:500px;font-size:clamp(33px,3.5vw,50px);font-family:'Outfit',sans-serif;margin-left:5%}
    .copy{color:#282828;font-size:16px;line-height:1.65}
    .copy p{margin:0 0 18px}
    .copy ul{margin:10px 0 18px 20px;padding:0}
    .copy li{margin-bottom:8px;color:#282828;font-size:16px;line-height:1.65;list-style:disc}

    .trust-section{padding-top:50px;padding-bottom:50px}
    .trust-wrap{position:relative;background:#fff;border:20px solid #E1EFFC;border-radius:28px;padding:90px 60px 60px}
    .trust-banner{position:absolute;top:-88px;right:-21px;display:flex;align-items:stretch;background:#001629;border-radius:20px;overflow:hidden}
    .trust-banner-text{color:#fff;font-size:20px;font-weight:600;line-height:1.35;font-family:'Outfit',sans-serif;display:flex;align-items:center;justify-content:center;text-align:center;padding:23px 45px;width:360px;border-right:3px solid #fff}
    .trust-banner-logos{display:flex;align-items:center;padding:23px 52px 23px 45px}
    .trust-banner-logos img{height:106px;width:auto;object-fit:contain;display:block}
    .industries-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:48px 24px;justify-items:center;text-align:center}
    .industry-item{display:flex;flex-direction:column;align-items:center;gap:14px;text-decoration:none;color:#1b1c1d}
    .industry-item .industry-icon{font-size:20px;color:#005cb9;font-weight:300}
    .industry-item span{display:inline-flex;align-items:center;gap:6px;font-size:25px;font-weight:400;color:#282828;font-family:'Outfit',sans-serif}
    .industry-item span .arrow-box{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border:1.5px solid currentColor;border-radius:8px;font-size:12px;line-height:1;margin-left:8px}
    @media (max-width:900px){
      .industries-grid{grid-template-columns:repeat(2,1fr)}
      .trust-banner{position:static;margin-bottom:30px;flex-direction:column;align-items:flex-start;gap:16px}
      .trust-banner-text{border-right:none;border-bottom:1px solid rgba(255,255,255,0.25);padding-right:0;padding-bottom:16px;width:100%;max-width:none}
      .trust-banner-logos{padding-left:0}
      .trust-wrap{padding:30px}
    }
    @media (max-width:480px){
      .industries-grid{grid-template-columns:1fr;gap:32px}
      .industry-item span{font-size:22px}
      .trust-banner-logos{padding:16px 0;width:100%;justify-content:center}
      .trust-banner-logos img{height:auto;width:100%;max-width:296px}
    }

    .media-accordion{display:grid;grid-template-columns:31% 1fr;gap:60px;align-items:stretch;padding-top:60px;padding-bottom:60px}
    .media-accordion .feature-image{order:-1}
    .feature-image{width:100%;height:680px;border-radius:25px;object-fit:cover;object-position:center;display:block}
    .accordion-copy{padding-top:4px}
    .accordion-copy .section-title{max-width:900px;margin-bottom: 55px;font-size:clamp(28px,3.2vw,46px)}
    .acc-list{width:100%}
    .acc-item{border-bottom:1px solid rgba(2,20,40,0.35)}
    .acc-btn{width:100%;display:grid;grid-template-columns:56px 1fr 22px;gap:16px;align-items:center;min-height:62px;padding:6px 0;cursor:pointer;background:transparent;border:none;text-align:left;font-family:inherit;box-sizing:border-box;-webkit-appearance:none;appearance:none}
    .acc-icon-box{width:56px!important;min-width:56px!important;height:46px!important;border-radius:10px;display:flex!important;align-items:center;justify-content:center;background-color:#005cb9!important;color:#fff!important;font-size:18px;box-sizing:border-box;flex-shrink:0}
    .acc-icon-box i{color:#fff!important;font-size:18px!important}
    .acc-title{font-size:20px;font-weight:500;line-height:1.3;color:#1b1c1d}
    .acc-toggle{justify-self:end;width:22px;height:22px;border:1.5px solid #0f1720;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:300;color:#0f1720;flex-shrink:0;transition:background 0.2s,color 0.2s,border-color 0.2s;line-height:1}
    .acc-toggle::before{content:'+'}
    .acc-item.active .acc-toggle{background:#005cb9;border-color:#005cb9;color:#fff}
    .acc-item.active .acc-toggle::before{content:'−'}
    .acc-panel{max-height:0;overflow:hidden;transition:max-height 0.28s ease}
    .acc-item.active .acc-panel{max-height:400px}
    .acc-body{max-width:900px;padding:12px 0 20px 78px;font-size:16px;line-height:1.65;color:#333}

    .services-grid-section{display:grid;grid-template-columns:31% 1fr;gap:50px;padding-top:50px;padding-bottom:50px}
    .services-grid-section .section-title{max-width: 430px;font-size: 46px; font-family: 'Outfit', sans-serif;color:#1b1c1d}
    .service-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:40px 70px;padding-left:100px}
    .service-card i{display:block;margin-bottom:14px;color:#005cb9;font-size:28px;line-height:1}
    .service-card h3{margin:0 0 10px;font-size:25px;font-weight:500;line-height:1.3;color:#282828;font-family:'Outfit',sans-serif}
    .service-card p{margin:0;color:#000;font-size:16px;line-height:1.55}

    .why-section-wrap{position:relative;padding:0;margin:50px 100px}
    .why-section{display:block;border-radius:22px;overflow:hidden;background-color:#f0f0f0}
    .why-copy{flex:1;min-width:0;padding:56px 56px 52px}
    .why-copy .eyebrow{color:#005cb9;margin-bottom:16px}
    .why-copy .section-title{margin-bottom:26px;font-size:clamp(33px,3.85vw,55px);font-weight:600}
    .why-copy>p{color:#111;font-size:16px;line-height:1.7;margin-bottom:10px;max-width:830px}
    .testimonial{margin-top:30px;padding-left:18px;border-left:3px solid #001629}
    .testimonial h3{margin:0 0 18px;font-size:clamp(22px,2.2vw,33px);font-weight:600;line-height:1.25;color:#1b1c1d}
    .quote-mark{color:#005cb9;font-size:26px;line-height:1;margin-bottom:14px;letter-spacing:-3px}
    .testimonial blockquote{margin:0 0 30px;max-width:1040px;color:#282828;font-size: 25px;font-weight:400;font-family:'Outfit',sans-serif;line-height:1.65}
    .testimonial-footer{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;padding-top:4px}
    .testimonial-footer p{margin:0;font-size:14px;line-height:1.55;color:#333}
    .testi-fraction{text-align:center;font-size:13px;color:#888;margin-top:22px}
    .text-link{color:#282828;text-decoration:none;font-weight:600;white-space:nowrap;font-size:14px}
    .why-card{position:absolute;top:-14px;right:0;bottom:-14px;width:355px;margin:14px 0 14px 14px;background-color:#001629!important;color:#fff;display:flex;flex-direction:column;border-radius:20px;z-index:2}
    .why-card-img-frame{padding:24px 22px 16px;flex-shrink:0}
    .why-card-img-frame img{width:100%;height:420px;object-fit:cover;object-position:center top;border-radius:16px;display:block}
    .why-card-body{padding:22px 26px 32px 18px;display:flex;flex-direction:column;align-items:flex-start;flex:1}
    .why-card h3{margin:0 0 60px;color:#fff!important;font-size:25px;font-weight:600;line-height:1.35;text-align:left;font-family:'Outfit',sans-serif;white-space:nowrap}
    .button-light{display:inline-flex;align-items:center;justify-content:center;gap:10px;width:auto;min-height:41px;background-color:#fff;color:#282828;padding:12px 20px;font-size:20px;font-weight:500;font-family:'Outfit',sans-serif;border-radius:10px;text-decoration:none;text-align:center;white-space:nowrap}
    .button-light:hover{transform:translateY(-3px)}
    .why-card .button-light{font-size:20px;padding:12px 22px;min-height:auto}

    .case-section{padding-top:60px;padding-bottom:50px}
    .case-section .section-title{max-width: 800px;margin-bottom:14px;font-size: 50px}
    .case-intro{max-width:660px;margin:0 0 36px;color:#000;font-size: 16px;line-height:1.55}
    .case-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
    .case-card{position:relative;min-height:148px;padding:32px 22px 18px;border-radius:16px;background:#fff;box-shadow:0 2px 14px rgba(0,0,0,0.14);overflow:hidden;display:flex;flex-direction:column;justify-content:center;transition:box-shadow 0.25s ease}
    .case-card:hover{box-shadow:0 9px 44px rgba(0,0,0,0.24)}
    .case-card.featured{grid-column:span 2;grid-row:span 2;min-height:310px;background:#282828;color:#fff;justify-content:flex-start}
    .case-tag{position:absolute;top:0;left:0;width:136px;padding:5px 10px;border-radius:0 0 6px 0;background:#8ce9ac;color:#000;font-size: 16px;font-weight:700;text-align:center}
    .case-card.featured .case-tag{width:270px;background:#001a34;color:#fff}
    .case-card.purple .case-tag{background:#686de4;color:#fff}
    .case-card.rose   .case-tag{background:#f2969d}
    .case-card.pink   .case-tag{background:#e585d9}
    .case-card.sky    .case-tag{background:#91c8f3}
    .case-card.yellow .case-tag{background:#f0e58c}
    .case-card.violet .case-tag{background:#c47aeb}
    .case-card.sand   .case-tag{background:#f1c88b}
    .case-card img{align-self:center;max-width:75%;max-height:92px;object-fit:contain;margin-top:29px}
    .case-card.featured img{align-self:flex-start;max-width: 410px;max-height: 135px;margin:44px 0 16px}
    .case-card p{margin:0 0 8px;color:#fff;font-size:14px;line-height:1.5}
    .case-card .case-link{align-self:flex-end;margin-top:auto;color:inherit;text-decoration:none;font-weight:600;white-space:nowrap;font-size:13px;display:inline-flex;align-items:center;gap:4px}
    .case-card:not(.featured) .case-link{color:#005cb9}

    .contact-section{background-color:#001629;margin-top:50px}
    .contact-inner{display:grid;grid-template-columns:62% 38%;max-width:var(--max);margin:0 auto;min-height:600px;align-items:stretch}
    .contact-form-col{padding:72px 140px}
    .contact-form-col .section-title{color:#fff;font-size:clamp(28px,2.8vw,42px);margin-bottom:44px;line-height:1.2;font-weight:600;white-space:nowrap}
    .contact-form{display:flex;flex-direction:column;gap:30px}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:42px}
    .contact-form input,.contact-form textarea{width:100%;padding:12px 0;border:none;border-bottom:1.5px solid rgba(255,255,255,0.9);border-radius:0;font-size:15px;font-family:inherit;outline:none;background:transparent;color:#fff;transition:border-bottom-color 0.2s}
    .contact-form input:focus,.contact-form textarea:focus{border-bottom-color:rgba(255,255,255,0.9)}
    .contact-form input::placeholder,.contact-form textarea::placeholder{color:rgba(255,255,255,0.65)}
    .contact-form textarea{resize:none;min-height:40px}
    .form-submit{align-self:flex-start;padding:15px 44px;background:#fff;color:#001629;border:none;border-radius:8px;font-size:20px;font-weight:500;font-family:'Outfit',sans-serif;cursor:pointer;margin-top:12px;transition:background 0.2s}
    .form-submit:hover{background:#f0f0f0}
    .contact-right-col{background-color:#f0f0f0;border-radius:25px;margin:28px 28px 28px 0;padding:40px 40px 0;display:flex;flex-direction:column;box-shadow:0 4px 32px rgba(0,0,0,0.14)}
    .contact-right-label{font-size:16px;font-weight:600;color:#1a1a1a;margin:0 0 22px}
    .tc-carousel{position:relative;flex:1}
    .tc-slide{display:none;flex-direction:column}
    .tc-slide.active{display:flex}
    .tc-quote-icon{color:#005cb9;font-size:26px;margin-bottom:18px;line-height:1}
    .tc-text{color:#333;font-size:16px;line-height:1.72;margin:0 0 20px;flex:1}
    .tc-footer{display:flex;justify-content:space-between;align-items:flex-end;gap:12px;padding-top:14px;border-top:1px solid #e8e8e8}
    .tc-author{font-size:14px;font-weight:700;color:#1a1a1a;line-height:1.4}
    .tc-author span{display:block;font-weight:400;font-size:13px;color:#888}
    .tc-link{color:#1a1a1a;text-decoration:none;font-size:13px;font-weight:500;white-space:nowrap}
    .tc-fraction-bar { text-align: center; font-size: 20px; color: #000; padding: 14px 0 8px; position: relative; z-index: 2; transform: translateY(-100px); }
