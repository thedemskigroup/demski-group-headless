    }
    @media (max-width: 600px) {
      .wa-section { padding: 32px 16px; }
      .hero { margin-left: 12px; margin-right: 12px; padding: 36px 20px; border-radius: 14px; }
      .hero h1 { font-size: clamp(28px, 7.5vw, 36px); }
      .hero p { font-size: 15px; margin-left: 0; }
      .hero-btn { margin-left: 0; font-size: 15px; }
      .hero-badges {
        position: static;
        display: grid;
        grid-template-columns: 1fr 1fr;
        column-gap: 14px;
        row-gap: 18px;
        justify-items: center;
        align-items: center;
        margin-top: 28px;
        width: 100%;
        flex-wrap: initial;
      }
      .hero-badges img { width: 100%; max-width: 140px; height: auto; }
      .hero-badges img:nth-child(1) { grid-column: 1; grid-row: 1; }
      .hero-badges img:nth-child(2) { grid-column: 2; grid-row: 1; }
      .hero-badges img:nth-child(3) { grid-column: 1 / 3; grid-row: 2; justify-self: center; max-width: 140px; }
      .intro-grid .section-title { font-size: clamp(24px, 7vw, 32px); margin-left: 0; }
      .accordion-copy .section-title { font-size: clamp(20px, 6vw, 28px); }
      .services-grid-section .section-title { font-size: 28px; }
      .service-grid { grid-template-columns: 1fr; padding-left: 0; }
      .why-card { position: relative !important; top: auto !important; right: auto !important; bottom: auto !important; width: 100% !important; margin: 0 !important; border-radius: 0 0 14px 14px !important; }
      .why-copy { padding: 28px 18px 24px !important; }
      .why-copy .section-title { font-size: clamp(22px, 6vw, 30px); }
      .case-grid { grid-template-columns: 1fr; }
      .case-card.featured { grid-column: span 1; grid-row: span 1; }
      .contact-inner { grid-template-columns: 1fr; min-height: auto; }
      .contact-form-col { padding: 32px 18px; }
      .contact-right-col { margin: 0; padding: 24px 18px 0; border-radius: 0; }
      .testimonial blockquote { font-size: 14px; }
      .form-submit { width: 100%; text-align: center; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-btn, .button-light { transition: none; }
      .acc-panel { transition: none !important; }
    }
  </style>

