        font-size:13.5px!important;line-height:1.55!important;
        box-shadow:0 4px 14px rgba(1,84,177,0.25)!important;
        display:block!important;word-break:break-word!important;
      }
      #lead-bot .quick-btns,#lead-bot .budget-btns{
        display:flex!important;flex-direction:column!important;flex-wrap:nowrap!important;
        gap:7px!important;align-items:stretch!important;
        width:90%!important;margin-left:auto!important;margin-right:0!important;
      }
      #lead-bot .quick-btns.grid-btns,#lead-bot .budget-btns.grid-btns{
        display:grid!important;grid-template-columns:1fr 1fr!important;
        grid-auto-rows:minmax(44px,1fr)!important;
        align-items:stretch!important;
      }
      #lead-bot .quick-btns button,#lead-bot .budget-btns button{
        background:rgba(255,255,255,0.88)!important;color:#0154B1!important;
        border:1.5px solid #d4e4f7!important;
        padding:7px 12px!important;border-radius:8px!important;
        cursor:pointer!important;font-size:13px!important;
        font-family:'Outfit',sans-serif!important;font-weight:500!important;
        box-shadow:0 1px 4px rgba(0,0,0,0.05)!important;
        display:flex!important;align-items:center!important;justify-content:center!important;
        text-align:center!important;
        width:100%!important;height:100%!important;min-height:44px!important;
        transition:background 0.18s,color 0.18s,border-color 0.18s,transform 0.15s!important;
        line-height:1.3!important;box-sizing:border-box!important;
      }
      #lead-bot .quick-btns button:hover,#lead-bot .budget-btns button:hover{
        background:#0154B1!important;color:#fff!important;border-color:#0154B1!important;
        box-shadow:0 4px 14px rgba(1,84,177,0.22)!important;
        transform:translateY(-1px)!important;
      }
      #lead-bot .back-btn{
        background:rgba(255,255,255,0.88)!important;color:#0154B1!important;
        border:1.5px solid #d4e4f7!important;
        padding:7px 12px!important;border-radius:8px!important;
        cursor:pointer!important;font-size:13px!important;
        font-family:'Outfit',sans-serif!important;font-weight:500!important;
        display:flex!important;align-items:center!important;justify-content:center!important;gap:6px!important;
        transition:all 0.18s!important;line-height:1.4!important;
        width:100%!important;height:100%!important;min-height:44px!important;
        box-shadow:0 1px 4px rgba(0,0,0,0.05)!important;box-sizing:border-box!important;
      }
      #lead-bot .back-btn:hover{
        background:#0154B1!important;color:#fff!important;border-color:#0154B1!important;
        box-shadow:0 4px 14px rgba(1,84,177,0.22)!important;transform:translateY(-1px)!important;
      }
    `;
    document.head.appendChild(_s);

    const botMessages = document.getElementById("bot-messages");
    const botInput    = document.getElementById("bot-input");
    const USER_CONFIRM_TEMPLATE = "template_7kz7hgj";

    let step = 0, expanded = false, idleTimer = null, awaitingIdleResponse = false;
    let idleInterval = 60000;
    const IDLE_BUBBLE_ID = "idle-reminder-bubble";
    const IDLE_BTNS_ID   = "idleBtns";

    const intentFollowUp = {
      "New startup or app idea":   "Love it! Tell me more — what kind of app or product are you thinking about?",
      "Software for my business":  "Great! What problem are you trying to solve in your business?",
      "Digital marketing help":    "Nice! What are you hoping to improve: traffic, leads, or sales?",
      "Just exploring":            "That's totally fine! Can you tell me a bit about what you have in mind?"
    };

    emailjs.init("nedYqWwwPWVZZVX0_");

    function playChime() {
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const osc = ctx.createOscillator(); const gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = "sine";
        osc.frequency.setValueAtTime(880, ctx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(660, ctx.currentTime + 0.12);
        gain.gain.setValueAtTime(0.15, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.3);
        osc.start(ctx.currentTime); osc.stop(ctx.currentTime + 0.3);
      } catch(e) {}
    }

    function getParams() {
      const p = {};
      try { new URL(window.location.href).searchParams.forEach((v,k) => { p[k]=v; }); } catch(e){}
      return p;
    }
    const urlParams   = getParams();
    const savedParams = JSON.parse(localStorage.getItem("utmData")||"{}");
    localStorage.setItem("utmData", JSON.stringify({...savedParams,...urlParams}));
    const finalParams = JSON.parse(localStorage.getItem("utmData")||"{}");

    const leadData = {
      page: window.location.href, page_name: document.title,
      utm_source: finalParams.utm_source||"", utm_campaign: finalParams.utm_campaign||"",
      utm_medium: finalParams.utm_medium||"", utm_term: finalParams.utm_term||"",
      utm_content: finalParams.utm_content||"", gclid: finalParams.gclid||"",
      intent:"", intent_detail:"", project_description:"", budget:"", name:"", phone:"", email:"", cta_choice:""
    };

    window.addEventListener("load", () => {
      const launcher = document.getElementById("bot-launcher");
      const avatar = launcher.querySelector("img");
      const reveal = () => {
        launcher.style.display = "flex";
        setTimeout(() => {
          launcher.classList.add("launcher-visible");
          // setTimeout(() => { if (!expanded) showGreetingBubble(); }, 1000);
        }, 3000);
      };
      if (avatar.complete) reveal();
      else { avatar.addEventListener("load", reveal, { once: true }); avatar.addEventListener("error", reveal, { once: true }); }
    });

    function showGreetingBubble() {
      if (document.getElementById("greeting-bubble")) return;
      const b = document.createElement("div");
      b.id = "greeting-bubble";
      b.innerHTML = `<span class="bubble-close" onclick="dismissBubble()">&#x00D7;</span><p>Hi! Need help with software or app development?</p><button onclick="openFromBubble()">Let's Chat!</button>`;
      document.body.appendChild(b);
      requestAnimationFrame(() => requestAnimationFrame(() => b.classList.add("bubble-visible")));
      setTimeout(() => dismissBubble(), 8000);
    }

    function dismissBubble() {
      const b = document.getElementById("greeting-bubble");
      if (!b) return;
      b.classList.remove("bubble-visible"); b.classList.add("bubble-hide");
      setTimeout(() => { if (b.parentNode) b.remove(); }, 400);
    }

    function openFromBubble() {
      dismissBubble();
      setTimeout(() => {
        document.getElementById("lead-bot").style.display="block";
        window.startChat();
      }, 200);
    }

    window.startChat = function() {
      document.getElementById("welcome-screen").style.display = "none";
      const msgs = document.getElementById("bot-messages");
      msgs.classList.remove("chat-body--hidden");
      document.getElementById("chat-input-bar").style.display = "flex";
      document.getElementById("chat-cta-bar").style.display = "block";
      resetIdleTimer();
      setTimeout(() => { document.getElementById("bot-input").focus(); }, 100);
    };

    window.toggleBot = function() {
      const win = document.getElementById("lead-bot");
      const badge = document.getElementById("launcher-badge");
      const isOpen = win.style.display === "none";
      win.style.display = isOpen ? "block" : "none";
      if (isOpen) {
        dismissBubble();
        const hadBadge = badge.classList.contains("badge-visible");
        badge.classList.remove("badge-visible");
        setTimeout(() => {
          window.startChat();
          if (hadBadge) { showIdleReminder(); }
        }, 400);
      }
    };

    function removeIdleReminder() {
      document.getElementById(IDLE_BUBBLE_ID)?.remove();
      document.getElementById(IDLE_BTNS_ID)?.remove();
    }

    function showIdleReminder() {
      if (step >= 7) return;
      awaitingIdleResponse = true;
      const win = document.getElementById("lead-bot");
      if (win && win.style.display === "none") {
        document.getElementById("launcher-badge").classList.add("badge-visible");
      } else {
        removeIdleReminder();
        const wrap = document.createElement("div");
        wrap.id = IDLE_BUBBLE_ID;
        wrap.className = "bot-msg-wrap";
        wrap.setAttribute("style", BOT_WRAP_STYLE);
        wrap.innerHTML = `<img src="${AVATAR_SRC}" style="${AVATAR_STYLE}" alt="" onerror="this.style.display='none'" /><div class="bot-msg" style="${BOT_MSG_STYLE}">Hi, are you still there? 👋</div>`;
        botMessages.appendChild(wrap);
        botMessages.scrollTop = botMessages.scrollHeight;
        showIdleButtons();
      }
      idleInterval = Math.min(idleInterval * 2, 960000);
      scheduleIdleTimer();
    }

    function scheduleIdleTimer() {
      clearTimeout(idleTimer);
      if (step < 7) {
        idleTimer = setTimeout(showIdleReminder, idleInterval);
      }
    }

    function resetIdleTimer() {
      clearTimeout(idleTimer);
      idleInterval = 60000;
      removeIdleReminder();
      awaitingIdleResponse = false;
      scheduleIdleTimer();
    }

    function expandUI() {
      if (expanded) return; expanded = true;
      document.getElementById("chat-header").style.display = "none";
      document.getElementById("top-section").style.display = "block";
    }

    const AVATAR_SRC = "/avatar-alex.webp";
    const AVATAR_STYLE = "width:28px!important;height:28px!important;min-width:28px!important;max-width:28px!important;min-height:28px!important;max-height:28px!important;border-radius:50%!important;object-fit:cover!important;flex-shrink:0!important;display:block!important;border:2px solid #fff!important;align-self:flex-end;";
    const BOT_WRAP_STYLE = "display:flex!important;align-items:flex-end!important;gap:8px!important;max-width:88%!important;";
    const BOT_MSG_STYLE = "background:rgba(255,255,255,0.88)!important;padding:10px 14px!important;border-radius:4px 18px 18px 18px!important;font-size:13.5px!important;color:#1e2024!important;line-height:1.65!important;box-shadow:0 2px 8px rgba(0,0,0,0.06)!important;flex:1!important;display:block!important;word-break:break-word!important;";
    const USER_MSG_STYLE = "background:linear-gradient(135deg,#0154B1,#1a7fe8)!important;color:#fff!important;padding:10px 16px!important;border-radius:18px 18px 4px 18px!important;align-self:flex-end!important;max-width:76%!important;font-size:13.5px!important;line-height:1.55!important;box-shadow:0 4px 14px rgba(1,84,177,0.25)!important;display:block!important;word-break:break-word!important;";

    function addBotMessage(text) {
      const wrap = document.createElement("div"); wrap.className="bot-msg-wrap"; wrap.setAttribute("style", BOT_WRAP_STYLE);
      wrap.innerHTML=`<img src="${AVATAR_SRC}" style="${AVATAR_STYLE}" alt="" onerror="this.style.display='none'" /><div class="bot-msg" style="${BOT_MSG_STYLE}">${text}</div>`;
      botMessages.appendChild(wrap); botMessages.scrollTop = botMessages.scrollHeight;
    }
    function addUserMessage(text) {
      const d = document.createElement("div"); d.className="user-msg"; d.setAttribute("style", USER_MSG_STYLE); d.textContent=text;
      botMessages.appendChild(d); botMessages.scrollTop = botMessages.scrollHeight;
    }
    function showTyping() {
      const wrap = document.createElement("div"); wrap.className="cb-typing-wrap"; wrap.id="cb-typing"; wrap.setAttribute("style", BOT_WRAP_STYLE);
      wrap.innerHTML=`<img src="${AVATAR_SRC}" style="${AVATAR_STYLE}" alt="" onerror="this.style.display='none'" /><div class="cb-typing"><span></span><span></span><span></span></div>`;
      botMessages.appendChild(wrap); botMessages.scrollTop = botMessages.scrollHeight;
    }
    function hideTyping() { const t=document.getElementById("cb-typing"); if(t) t.remove(); }
    function botReply(msg, cb, delay) {
      showTyping();
      setTimeout(() => { hideTyping(); addBotMessage(msg); playChime(); if(cb) cb(); }, delay||1200);
    }

    function resumeStep() {
      awaitingIdleResponse = false; resetIdleTimer();
      if(step===1) { botReply("No problem! What type of solution are you looking for?", () => showIntentOptions(leadData.intent)); return; }
      if(step===2) { showProjectDescStep(); return; }
      if(step===3) { showBudgetStep(); return; }
      if(step===4) { document.getElementById("chat-input-bar").style.display="flex"; botReply("What's your name?"); return; }
      if(step===5) { document.getElementById("chat-input-bar").style.display="flex"; botReply("What's the best phone number to reach you?"); return; }
      if(step===6) { document.getElementById("chat-input-bar").style.display="flex"; botReply("What's the best email to reach you?"); return; }
      if(step===7) { botReply("Our team already has your details and will be in touch shortly!"); return; }
      botReply("No problem! Take your time.");
    }

    function showIdleButtons() {
      document.getElementById(IDLE_BTNS_ID)?.remove();
      const div = document.createElement("div"); div.className="quick-btns grid-btns"; div.id=IDLE_BTNS_ID;
      const yes = document.createElement("button"); yes.textContent="Yes, still here!";
      yes.onclick = () => { removeIdleReminder(); addUserMessage("Yes, still here!"); resumeStep(); };
      const no = document.createElement("button"); no.textContent="No, I'm done";
      no.onclick = () => { removeIdleReminder(); addUserMessage("No, I'm done"); awaitingIdleResponse=false; clearTimeout(idleTimer); botReply("No problem! Feel free to come back anytime."); };
      div.appendChild(yes); div.appendChild(no); botMessages.appendChild(div);
      botMessages.scrollTop = botMessages.scrollHeight;
    }

    const intentOptions = {
      "New startup or app idea":  ["Mobile App","Web App","SaaS Platform","eCommerce","Other"],
      "Software for my business": ["Automate Workflows","Customer Management","Reporting & Analytics","Employee Tools","Other"],
      "Digital marketing help":   ["Increase Website Traffic","Generate More Leads","Social Media Growth","Paid Advertising","Other"],
      "Just exploring":           ["Planning a Future Project","Comparing Vendors","Learning About Tech","Just Curious"]
    };

    function makeBackBtn(label, onClick) {
      const b = document.createElement("button"); b.className="back-btn";
      b.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;display:block;"><polyline points="15 18 9 12 15 6"/></svg><span>${label}</span>`;
      b.onclick = onClick; return b;
    }

    function showIntentOptions(intent) {
      const opts = intentOptions[intent] || ["Mobile App","Web App","Something else"];
      const div = document.createElement("div"); div.className="quick-btns grid-btns"; div.id="intentOptBtns";
      opts.forEach(o => {
        const b = document.createElement("button"); b.textContent = o;
        b.onclick = () => {
          document.getElementById("intentOptBtns")?.remove();
          addUserMessage(o); leadData.intent_detail = o;
          step = 2; showProjectDescStep();
        };
        div.appendChild(b);
      });
      const back = makeBackBtn("Back", () => {
        document.getElementById("intentOptBtns")?.remove();
        leadData.intent = ""; step = 0;
        botReply("No problem! What kind of project do you need help bringing to life?", () => {
          const s1 = document.createElement("div"); s1.className="quick-btns grid-btns"; s1.id="step1-btns";
          ["New startup or app idea","Software for my business","Digital marketing help","Just exploring"].forEach(v => {
            const b=document.createElement("button"); b.textContent=v; b.onclick=()=>window.handleStep1(v); s1.appendChild(b);
          });
          botMessages.appendChild(s1); botMessages.scrollTop=botMessages.scrollHeight;
        });
      });
      div.appendChild(back);
      botMessages.appendChild(div); botMessages.scrollTop = botMessages.scrollHeight;
    }

    window.handleStep1 = function(val) {
      expandUI();
      const btns = document.getElementById("step1-btns"); if(btns) btns.remove();
      addUserMessage(val); leadData.intent=val; step=1; resetIdleTimer();
      botReply(intentFollowUp[val]||"Can you tell me a bit about it or if you already have a design in mind?", () => showIntentOptions(val));
    };

    function showProjectDescStep() {
      step = 2; resetIdleTimer();
      botReply("Can you tell me a bit about your project? Feel free to share as much or as little as you'd like. Any details help!", () => {
        const inp = document.getElementById("chat-input-bar");
        inp.style.display = "flex";
        document.getElementById("bot-input").placeholder = "Describe your project...";
        setTimeout(() => { document.getElementById("bot-input").focus(); }, 50);
      });
    }

    function showBudgetStep() {
      step=3; resetIdleTimer();
      document.getElementById("bot-input").placeholder = "Type your answer...";
      botReply("Do you have a budget range in mind for this project?", () => {
        const div=document.createElement("div"); div.className="budget-btns grid-btns"; div.id="budgetBtns";
        ["Under $10k","$10k – $25k","$25k – $50k","$50k+","Not sure yet"].forEach(b => {
          const btn=document.createElement("button"); btn.textContent=b; btn.onclick=()=>handleBudget(b); div.appendChild(btn);
        });
        const back = makeBackBtn("Back", () => {
          document.getElementById("budgetBtns")?.remove();
          leadData.budget=""; step=2; showProjectDescStep();
        });
        div.appendChild(back);
        botMessages.appendChild(div); botMessages.scrollTop=botMessages.scrollHeight;
      });
    }

    function handleBudget(val) {
      const btns=document.getElementById("budgetBtns"); if(btns) btns.remove();
      addUserMessage(val); leadData.budget=val; showContactStep();
    }

    function showContactStep() {
      step=4; resetIdleTimer();
      document.getElementById("chat-input-bar").style.display = "flex";
      document.getElementById("bot-input").focus();
      botReply("Thanks, this helps a lot! Let me grab your details so our team can reach out.<br><br>What's your name?");
    }

    function showFinalCTA() {
      step=7; clearTimeout(idleTimer);
      botReply("Awesome! Based on what you've shared, the best next step is a quick call or Google Meet to go over your project!", () => {
        const div=document.createElement("div"); div.className="cta-btns"; div.id="ctaBtns";
        const book=document.createElement("button"); book.className="cta-btn-primary"; book.textContent="Book a Google Meet";
        book.onclick=()=>{ handleCTA("Book a Google Meet"); window.open("https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ3loQplPyCXe28FPP0trIgOCmhJqwKCXka1x3uCkblaAFtklpetKpkyi6glNBGxVR8jpOQenySG","_blank"); };
        const email=document.createElement("button"); email.className="cta-btn-secondary"; email.textContent="Send me info by email";
        email.onclick=()=>handleCTA("Send me info by email");
        div.appendChild(book); div.appendChild(email); botMessages.appendChild(div);
        botMessages.scrollTop=botMessages.scrollHeight;
      }, 1200);
    }

    function handleCTA(choice) {
      const btns=document.getElementById("ctaBtns"); if(btns) btns.remove();
      addUserMessage(choice); leadData.cta_choice=choice;
      botInput.disabled=true; botInput.placeholder="Chat complete";
      document.querySelector(".chat-input button").disabled=true;
      botReply(choice==="Book a Google Meet"
        ? "Great! We're opening Calendly now. Pick a time that works for you. A confirmation will also be sent to "+leadData.email+"!"
        : "Perfect! We'll send everything over to "+leadData.email+" shortly. Talk soon!");
      submitLead();
    }

    function submitLead() {
      const params = { intent:leadData.intent, intent_detail:leadData.intent_detail, project_description:leadData.project_description, budget:leadData.budget, name:leadData.name, phone:leadData.phone, email:leadData.email, cta_choice:leadData.cta_choice, page:leadData.page, page_name:leadData.page_name, utm_source:leadData.utm_source, utm_campaign:leadData.utm_campaign, utm_medium:leadData.utm_medium, utm_term:leadData.utm_term, utm_content:leadData.utm_content, gclid:leadData.gclid };
      emailjs.send("service_f4tf0yn","template_c6hi8ir", params).catch(()=>{});
      emailjs.send("service_f4tf0yn", USER_CONFIRM_TEMPLATE, { user_name:leadData.name, user_email:leadData.email, cta_choice:leadData.cta_choice }).catch(()=>{});
    }

    const offTopicKeywords = ["price","pricing","cost","how much","what do you","who are you","services","what is","can you","help","support","contact","discount","trial"];
    function isOffTopic(v) { return offTopicKeywords.some(k=>v.toLowerCase().includes(k)); }

    window.handleInput = function() {
      const val = botInput.value.trim(); if(!val) return;
      if(awaitingIdleResponse) { removeIdleReminder(); addUserMessage(val); botInput.value=""; resumeStep(); return; }
      addUserMessage(val); botInput.value=""; resetIdleTimer();
      if(step===0) {
        const lower = val.toLowerCase();
        let intentGuess = null;
        if(/startup|app idea|new product|mvp|launch/.test(lower)) intentGuess = "New startup or app idea";
        else if(/business|company|software|workflow|automate/.test(lower)) intentGuess = "Software for my business";
        else if(/market|seo|ads|traffic|social|leads/.test(lower)) intentGuess = "Digital marketing help";
        if(intentGuess) { window.handleStep1(intentGuess); return; }
        botReply("Thanks for reaching out! To point you in the right direction, what kind of project do you need help with?", () => {
          const s1=document.createElement("div"); s1.className="quick-btns grid-btns"; s1.id="step1-btns";
          ["New startup or app idea","Software for my business","Digital marketing help","Just exploring"].forEach(v=>{
            const b=document.createElement("button"); b.textContent=v; b.onclick=()=>window.handleStep1(v); s1.appendChild(b);
          });
          botMessages.appendChild(s1); botMessages.scrollTop=botMessages.scrollHeight;
        });
        return;
      }
      if(step===1) { document.getElementById("intentOptBtns")?.remove(); botReply("Got it! What type of solution are you looking for?", () => showIntentOptions(leadData.intent)); return; }
      if(step===2) {
        leadData.project_description = val;
        document.getElementById("bot-input").placeholder = "Type your answer...";
        botReply("That's really helpful, thank you!", () => showBudgetStep()); return;
      }
      if(step===3) { showBudgetStep(); return; }
      if((step===4||step===5||step===6)&&isOffTopic(val)) {
        botReply("Great question! Our team will cover all that on the call. For now: "+(step===4?"What's your name?":step===5?"What's your phone number?":"What's your email address?")); return;
      }
      if(step===4) { if(val.length<2||/^\d+$/.test(val)){botReply("Could you enter your full name please?");return;} leadData.name=val; step=5; botReply("Nice to meet you, "+val+"! What's the best phone number to reach you?"); return; }
      if(step===5) { const d=val.replace(/\D/g,""); if(d.length<7){botReply("That doesn't look like a valid phone number. Could you double-check?");return;} leadData.phone=val; step=6; botReply("Got it! And what's the best email address to reach you?"); return; }
      if(step===6) { if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)){botReply("That doesn't look right. Could you double-check your email address?");return;} leadData.email=val; showFinalCTA(); return; }
    };

    botInput.addEventListener("keypress", e => { if(e.key==="Enter") window.handleInput(); });
  })();
  </script>
  <!-- ══ END CHATBOT ══ -->

