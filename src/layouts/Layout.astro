          background:#f09300;color:#fff;border:1.1px solid #f09300;
          padding:10px 20px;border-radius:6px;font-size:16px;font-weight:600;
          text-decoration:none;white-space:nowrap;transition:all 0.3s ease;
          font-family:'Outfit',sans-serif;
        ">Schedule a Consultation</a>
        <button class="hamburger scroll-bar-hamburger" id="hamburgerScroll" aria-label="Menu" style="display:none;">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>

    <script>
      (function(){
        var bar = document.getElementById('scrollStickyBar');
        if (!bar) return;
        var header = document.querySelector('.site-header-wrap');
        var hamScroll = document.getElementById('hamburgerScroll');
        var mobileMenu = document.getElementById('mobileMenu');
        var hamMain = document.getElementById('hamburger');
        var closeBtn = document.getElementById('mobileClose');
        var shown = false;
        var ticking = false;
        var threshold = Math.max(80, (document.body.scrollHeight - window.innerHeight) * 0.04);

        // Smooth fade on header instead of display:none (prevents layout jump)
        if (header) header.style.transition = 'opacity 0.35s ease';

        function openMenu() {
          if (!mobileMenu) return;
          // Hide the sticky bar FIRST so its hamburger animation doesn't bleed through the drawer
          bar.style.visibility = 'hidden';
          // Drawer lives inside header wrap — restore opacity AND pointer events so clicks reach the menu
          if (header) { header.style.opacity = '1'; header.style.pointerEvents = ''; }
          mobileMenu.classList.add('open');
          hamScroll && hamScroll.classList.add('open');
          hamMain && hamMain.classList.add('open');
        }
        function closeMenu() {
          if (!mobileMenu) return;
          mobileMenu.classList.remove('open');
          hamScroll && hamScroll.classList.remove('open');
          hamMain && hamMain.classList.remove('open');
          // Restore sticky bar / header state based on current scroll
          if (shown) {
            bar.style.visibility = 'visible';
            if (header) { header.style.opacity = '0'; header.style.pointerEvents = 'none'; }
          } else {
            bar.style.visibility = 'visible';
            if (header) { header.style.opacity = '1'; header.style.pointerEvents = ''; }
          }
        }
        function toggleMenu() {
          if (mobileMenu && mobileMenu.classList.contains('open')) closeMenu();
          else openMenu();
        }
        if (hamScroll) hamScroll.addEventListener('click', toggleMenu);
        // Ensure close button reliably closes the drawer and restores state
        if (closeBtn) closeBtn.addEventListener('click', function(e){
          e.stopPropagation();
          closeMenu();
        });
        // Click outside the drawer also closes it
        document.addEventListener('click', function(e){
          if (!mobileMenu || !mobileMenu.classList.contains('open')) return;
          var inDrawer = mobileMenu.contains(e.target);
          var onHam = (hamScroll && hamScroll.contains(e.target)) || (hamMain && hamMain.contains(e.target));
          if (!inDrawer && !onHam) closeMenu();
        });

        function update() {
          var sy = window.scrollY;
          // Show: at threshold. Hide: 24px below threshold (hysteresis prevents rapid toggling)
          if (!shown && sy >= threshold) {
            shown = true;
            bar.style.transform = 'translateY(0)';
            if (header) { header.style.opacity = '0'; header.style.pointerEvents = 'none'; }
          } else if (shown && sy < threshold - 24) {
            shown = false;
            bar.style.transform = 'translateY(-100%)';
            if (header) { header.style.opacity = '1'; header.style.pointerEvents = ''; }
          }
          ticking = false;
        }

        // requestAnimationFrame throttle — max one update per frame (60fps)
        window.addEventListener('scroll', function(){
          if (!ticking) { requestAnimationFrame(update); ticking = true; }
        }, { passive: true });
      })();
    </script>


