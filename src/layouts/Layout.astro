      if (win && win.style.display !== "none" && step < 7) {
        idleTimer = setTimeout(() => {
          if (!idlePromptShown) { idlePromptShown=true; awaitingIdleResponse=true; addBotMessage("Hi, are you still there? 👀"); showIdleButtons(); }
        }, 60000);
      }
    }

    function expandUI() {
      if (expanded) return; expanded = true;
      document.getElementById("chat-header").style.display = "none";
      document.getElementById("top-section").style.display = "block";
    }

    function addBotMessage(text) {
      const wrap = document.createElement("div"); wrap.className="bot-msg-wrap";
      wrap.innerHTML=`<img src="/72e79b86-c143-495c-b6bb-c10553e75cd3.png" class="msg-avatar" alt="" width="26" height="26" style="width:26px;height:26px;min-width:26px;flex-shrink:0;border-radius:50%;object-fit:cover;" onerror="this.style.display='none'" /><div class="bot-msg">${text}</div>`;
      botMessages.appendChild(wrap); botMessages.scrollTop = botMessages.scrollHeight;
    }
    function addUserMessage(text) {
      const d = document.createElement("div"); d.className="user-msg"; d.textContent=text;
      botMessages.appendChild(d); botMessages.scrollTop = botMessages.scrollHeight;
    }
    function showTyping() {
      const d = document.createElement("div"); d.className="cb-typing"; d.id="cb-typing";
      d.innerHTML="<span></span><span></span><span></span>";
      botMessages.appendChild(d); botMessages.scrollTop = botMessages.scrollHeight;
    }
    function hideTyping() { const t=document.getElementById("cb-typing"); if(t) t.remove(); }
    function botReply(msg, cb, delay) {
      showTyping();
      setTimeout(() => { hideTyping(); addBotMessage(msg); if(cb) cb(); }, delay||1000);
    }

    function getResumeMessage() {
      if(step===7) return "Our team already has your details and will be in touch shortly! 🎉";
      if(step===1) return "No problem! Go ahead — what are you looking to accomplish?";
      if(step===2) return "No problem! When would you like to go live with the project?";
      if(step===3) return "No problem! Do you have a budget range in mind?";
      if(step===4) return "No problem! What's your name?";
      if(step===5) return "No problem! What's the best phone number to reach you?";
      if(step===6) return "No problem! What's the best email to reach you?";
      return "No problem! Take your time. 😊";
    }

    function showIdleButtons() {
      const div = document.createElement("div"); div.className="quick-btns"; div.id="idleBtns";
      const yes = document.createElement("button"); yes.textContent="Yes, still here!";
      yes.onclick = () => { document.getElementById("idleBtns").remove(); addUserMessage("Yes, still here!"); awaitingIdleResponse=false; botReply(getResumeMessage()); resetIdleTimer(); };
      const no = document.createElement("button"); no.textContent="No, I'm done";
      no.onclick = () => { document.getElementById("idleBtns").remove(); addUserMessage("No, I'm done"); awaitingIdleResponse=false; botReply("No problem! Feel free to come back anytime. 😊"); clearTimeout(idleTimer); };
      div.appendChild(yes); div.appendChild(no); botMessages.appendChild(div);
      botMessages.scrollTop = botMessages.scrollHeight;
    }

    const intentOptions = {
      "🚀 New startup or app idea":  ["📱 Mobile App","🌐 Web App","☁️ SaaS Platform","🛒 eCommerce","🔧 Other"],
      "🏢 Software for my business": ["⚙️ Automate Workflows","👥 Customer Management","📊 Reporting & Analytics","🗂️ Employee Tools","🔧 Other"],
      "📈 Digital marketing help":   ["📈 Increase Website Traffic","🎯 Generate More Leads","📣 Social Media Growth","💰 Paid Advertising","🔧 Other"],
      "🤔 Just exploring":           ["🔭 Planning a Future Project","🔍 Comparing Vendors","💡 Learning About Tech","👀 Just Curious"]
    };

    function showIntentOptions(intent) {
      const opts = intentOptions[intent] || ["Mobile App","Web App","Something else"];
      const div = document.createElement("div"); div.className="quick-btns"; div.id="intentOptBtns";
      opts.forEach(o => {
        const b = document.createElement("button"); b.textContent = o;
        b.onclick = () => {
          document.getElementById("intentOptBtns")?.remove();
          addUserMessage(o); leadData.intent_detail = o;
          botReply("Great choice! Let's figure out the best way to help. 😊", () => showTimelineStep());
        };
        div.appendChild(b);
      });
      botMessages.appendChild(div); botMessages.scrollTop = botMessages.scrollHeight;
    }

    window.handleStep1 = function(val) {
      expandUI();
      const btns = document.getElementById("step1-btns"); if(btns) btns.remove();
      addUserMessage(val); leadData.intent=val; step=1; resetIdleTimer();
      botReply(intentFollowUp[val]||"Tell me more about what you're looking for!", () => showIntentOptions(val));
    };

    function showTimelineStep() {
      step=2; resetIdleTimer();
      botReply("When would you like to go live with the project?", () => {
        const div = document.createElement("div"); div.className="quick-btns"; div.id="timelineBtns";
        ["⚡ ASAP (ready to start now)","📅 1–3 months","🗓️ 3–6 months","🔮 6+ months","🤷 Not sure yet"].forEach(t => {
          const b=document.createElement("button"); b.textContent=t; b.onclick=()=>handleTimeline(t); div.appendChild(b);
        });
        botMessages.appendChild(div); botMessages.scrollTop=botMessages.scrollHeight;
      });
    }

    function handleTimeline(val) {
      const btns=document.getElementById("timelineBtns"); if(btns) btns.remove();
      addUserMessage(val); leadData.timeline=val; showBudgetStep();
    }

    function showBudgetStep() {
      step=3; resetIdleTimer();
      botReply("Do you have a budget range in mind for this project?", () => {
        const div=document.createElement("div"); div.className="budget-btns"; div.id="budgetBtns";
        ["⭐ Under $10k","⭐⭐ $10k – $25k","⭐⭐⭐ $25k – $50k","⭐⭐⭐⭐ $50k+","🤷 Not sure yet"].forEach(b => {
          const btn=document.createElement("button"); btn.textContent=b; btn.onclick=()=>handleBudget(b); div.appendChild(btn);
        });
        botMessages.appendChild(div); botMessages.scrollTop=botMessages.scrollHeight;
      });
    }

    function handleBudget(val) {
      const btns=document.getElementById("budgetBtns"); if(btns) btns.remove();
      addUserMessage(val); leadData.budget=val; showContactStep();
    }

    function showContactStep() {
      step=4; resetIdleTimer();
      botReply("Thanks, this helps a lot! 😊 Let me grab your details so a team member can reach out.<br><br>What's your name?");
    }

    function showFinalCTA() {
      step=7; clearTimeout(idleTimer);
      botReply("Awesome! Based on what you've shared, the best next step is a quick call or Google Meet to go over your project! 🎉", () => {
        const div=document.createElement("div"); div.className="cta-btns"; div.id="ctaBtns";
        const book=document.createElement("button"); book.className="cta-btn-primary"; book.textContent="📅 Book a Google Meet";
        book.onclick=()=>{ handleCTA("Book a Google Meet"); window.open("https://calendly.com/shreya-ethixweb/30min","_blank"); };
        const email=document.createElement("button"); email.className="cta-btn-secondary"; email.textContent="📩 Send me info by email";
        email.onclick=()=>handleCTA("Send me info by email");
        div.appendChild(book); div.appendChild(email); botMessages.appendChild(div);
        botMessages.scrollTop=botMessages.scrollHeight;
      }, 1200);
    }

    function handleCTA(choice) {
      const btns=document.getElementById("ctaBtns"); if(btns) btns.remove();
      addUserMessage(choice); leadData.cta_choice=choice;
      botInput.disabled=true; botInput.placeholder="Chat complete";
      document.querySelector(".chat-input button").disabled=true;
      botReply(choice==="Book a Google Meet"
        ? "Great! We're opening Calendly now 🎉 — pick a time that works for you. A confirmation will also be sent to "+leadData.email+"! 😊"
        : "Perfect! We'll send everything over to "+leadData.email+" shortly. Talk soon! 😊");
      submitLead();
    }

    function submitLead() {
      const params = { intent:leadData.intent, intent_detail:leadData.intent_detail, timeline:leadData.timeline, budget:leadData.budget, name:leadData.name, phone:leadData.phone, email:leadData.email, cta_choice:leadData.cta_choice, page:leadData.page, page_name:leadData.page_name, utm_source:leadData.utm_source, utm_campaign:leadData.utm_campaign, utm_medium:leadData.utm_medium, utm_term:leadData.utm_term, utm_content:leadData.utm_content, gclid:leadData.gclid };
      emailjs.send("service_f4tf0yn","template_c6hi8ir", params).then(r=>console.log("Lead sent",r.status)).catch(e=>console.log("Lead failed",e));
      emailjs.send("service_f4tf0yn", USER_CONFIRM_TEMPLATE, { user_name:leadData.name, user_email:leadData.email, cta_choice:leadData.cta_choice }).then(r=>console.log("Confirm sent",r.status)).catch(e=>console.log("Confirm failed",e));
    }

    const offTopicKeywords = ["price","pricing","cost","how much","what do you","who are you","services","what is","can you","help","support","contact","discount","trial"];
    function isOffTopic(v) { return offTopicKeywords.some(k=>v.toLowerCase().includes(k)); }

    window.handleInput = function() {
      const val = botInput.value.trim(); if(!val) return;
      if(awaitingIdleResponse) { awaitingIdleResponse=false; addUserMessage(val); botInput.value=""; botReply(getResumeMessage()); resetIdleTimer(); return; }
      addUserMessage(val); botInput.value=""; resetIdleTimer();
      if(step===0) { botReply("Please use the buttons above to get started! 👆"); return; }
      if(step===1||step===2||step===3) { botReply("Please choose one of the options above 😊"); return; }
      if((step===4||step===5||step===6)&&isOffTopic(val)) {
        botReply("Great question! Our team will cover all that on the call. For now: "+(step===4?"What's your name?":step===5?"What's your phone number?":"What's your email address?")); return;
      }
      if(step===4) { if(val.length<2){botReply("Could you enter your full name please? 😊");return;} leadData.name=val; step=5; botReply("Nice to meet you, "+val.split(" ")[0]+"! 😊 What's the best phone number to reach you?"); return; }
      if(step===5) { const d=val.replace(/\D/g,""); if(d.length<7){botReply("That doesn't look like a valid phone number — could you double-check? 😊");return;} leadData.phone=val; step=6; botReply("Got it! And what's the best email address to reach you?"); return; }
      if(step===6) { if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val)){botReply("That doesn't look right — could you double-check your email address?");return;} leadData.email=val; showFinalCTA(); return; }
    };

    botInput.addEventListener("keypress", e => { if(e.key==="Enter") window.handleInput(); });
  })();
  </script>
  <!-- ══ END CHATBOT ══ -->

  </body>
</html>
