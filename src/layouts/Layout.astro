        font-size:13.5px!important;line-height:1.65!important;
        box-shadow:0 2px 8px rgba(0,0,0,0.06)!important;
        flex:1!important;display:block!important;word-break:break-word!important;
      }
      #lead-bot .user-msg{
        background:linear-gradient(135deg,#0154B1,#1a7fe8)!important;
