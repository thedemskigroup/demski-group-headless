      transition: all 0.2s; width: 100%; text-align: center;
    }
    .cta-btn-primary {
      background: linear-gradient(135deg, #F09300, #f5a623);
      color: #fff; box-shadow: 0 4px 14px rgba(240,147,0,0.35);
    }
    .cta-btn-primary:hover { background: linear-gradient(135deg, #d98200, #e8961a); transform: translateY(-1px); }
    .cta-btn-secondary { background: #f0f6ff; color: #0154B1; border: 1.5px solid #cce0f5; }
    .cta-btn-secondary:hover { background: #0154B1; color: #fff; border-color: #0154B1; }

    /* ─── Input area ─── */
    .chat-input {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 12px 10px;
      border-top: 1px solid rgba(255,255,255,0.3); background: rgba(255,255,255,0.45); flex-shrink: 0;
    }
    .chat-input input {
      flex: 1; border: 1.5px solid rgba(255,255,255,0.5); outline: none; border-radius: 24px;
      padding: 10px 16px; font-family: 'Outfit', sans-serif; font-size: 13.5px;
      color: #111827; background: rgba(255,255,255,0.82);
      transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }
    .chat-input input:focus {
      border-color: #0154B1; background: rgba(255,255,255,0.95);
      box-shadow: 0 0 0 3px rgba(1,84,177,0.1);
    }
    .chat-input input::placeholder { color: #aab0bc; }
    .chat-input button {
      width: 38px; height: 38px; border-radius: 50%;
      background: linear-gradient(135deg, #0154B1, #1a7fe8);
      color: #fff; border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; transition: all 0.2s;
      box-shadow: 0 3px 10px rgba(1,84,177,0.32);
    }
    .chat-input button:hover { transform: scale(1.08); box-shadow: 0 5px 16px rgba(1,84,177,0.38); }
    .chat-input button:active { transform: scale(0.95); }

    /* ─── Schedule CTA ─── */
    .sticky-schedule-btn {
      display: block; text-align: center;
      background: linear-gradient(135deg, #F09300, #f5a623);
      color: #fff; font-weight: 700; font-size: 13.5px;
      font-family: 'Outfit', sans-serif;
      text-decoration: none; padding: 13px; letter-spacing: 0.2px;
      transition: filter 0.2s; flex-shrink: 0;
    }
    .sticky-schedule-btn:hover { filter: brightness(0.92); color: #fff; }

    /* ─── Mobile ─── */
    @media(max-width:480px){
      #lead-bot { bottom: 0; right: 0; left: 0; width: 100%; animation: none; }
      .chat-card { width: 100%; border-radius: 24px 24px 0 0; max-height: 88vh; border: none; overflow: hidden; }
      .chat-body { max-height: 42vh !important; }
      .quick-btns.grid-btns, .budget-btns.grid-btns { display: grid !important; grid-template-columns: 1fr 1fr !important; }
      .quick-btns button, .budget-btns button { font-size: 12px !important; padding: 9px 10px !important; }
      .chat-input input { font-size: 13px; box-sizing: border-box; }
      #greeting-bubble { right: 8px; bottom: 100px; max-width: calc(100vw - 80px); }
      #bot-launcher { bottom: 16px; right: 16px; width: 60px; height: 60px; }
      #bot-launcher img { width: 54px; height: 54px; }
      .online-dot { bottom: 2px; right: 2px; width: 12px; height: 12px; }
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js" defer></script>
  <script defer>
  (function(){
    /* Inject button styles last so they beat every global override */
    const _s = document.createElement('style');
    _s.textContent = `
